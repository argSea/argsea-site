---
// The hobby graveyard: static header, then the HobbyGraveyard island owns
// the register rows, the manila record modal, the fireflies, the cat's paw
// rounds, and leave-a-flower (localStorage). Data stays on getHobbies()/
// getSuggestions() with the expanded Hobby shape; the raw characteristics
// ("Fl W 3s" and friends) stay per the standing exemption in the identity doc.
import BaseLayout from '../layouts/BaseLayout.astro';
import HobbyGraveyard from '../components/islands/HobbyGraveyard';
import { getHobbies, getSuggestions, getSiteCopy, getFigurehead } from '../lib/api';

const hobbies = await getHobbies();
const suggestions = await getSuggestions();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();
---
<BaseLayout title="The hobby graveyard · argsea.com" active="hobbies" quipKey="quipHobbies">
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">Hobbies · past and present</span>
		<h1 class="head__title fade-up fade-up--2">The hobby graveyard</h1>
		<p class="head__intro fade-up fade-up--3">Up the hill from the tower. Every hobby kept a small light here once; the station buries its keepers properly.</p>
		<p class="head__subintro fade-up fade-up--4">In memory of the keepers of Flannan Isle, who actually vanished. Everyone below just wandered off.</p>
	</section>

	<HobbyGraveyard
		client:load
		hobbies={hobbies}
		suggestions={suggestions.map((s) => s.value)}
		catEnabled={copy.eggs.cat}
		catPages={copy.catPages}
		catSpots={copy.catSpots}
		catDesigns={catDesigns}
	/>
</BaseLayout>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 22px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 10px;
	}

	.head__kicker {
		margin-bottom: 8px;
		font-size: 12px;
		letter-spacing: .18em;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(32px, 5.5vw, 46px);
		color: var(--text-strong);
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 600px;
		line-height: 1.6;
	}

	.head__subintro {
		margin: 0;
		font-size: 14px;
		font-style: italic;
		color: var(--text-dim);
		max-width: 540px;
		line-height: 1.55;
	}
</style>
