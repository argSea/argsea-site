---
// The ship's log: a static header, then the ShipsLog island owns the wandering
// chart (projected marks, wakes, the Flannan memorial), the log list, the
// bearing card with its flares, and the in-memoriam modal. Data stays on
// getHobbies()/getSuggestions(); a hobby with a null coord rides the log only,
// never the chart.
import BaseLayout from '../layouts/BaseLayout.astro';
import ShipsLog from '../components/islands/ShipsLog';
import { getHobbies, getSuggestions, getSiteCopy, getFigurehead } from '../lib/api';

const hobbies = await getHobbies();
const suggestions = await getSuggestions();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();
---
<BaseLayout title="The ship's log · argsea.com" active="hobbies" quipKey="quipHobbies">
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">Hobbies · past and adrift</span>
		<h1 class="head__title fade-up fade-up--2">Off course, not overboard</h1>
		<p class="head__intro fade-up fade-up--3">Every hobby I ever picked up is still out there somewhere. None of them sank. The chart just needs updating, and the keeper is slow with the ink.</p>
		<p class="head__subintro fade-up fade-up--4">Filed with the harbor watch, who logs every overdue ship as "expected on the next fair wind," never "lost."</p>
	</section>

	<ShipsLog
		client:load
		hobbies={hobbies}
		suggestions={suggestions.map((s) => s.value)}
		catEnabled={copy.eggs.cat}
		catPages={copy.catPages}
		catSpots={copy.catSpots}
		catDesigns={catDesigns}
	/>
</BaseLayout>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 16px;
	}

	.head__kicker {
		margin-bottom: 0;
		font-size: 12px;
		letter-spacing: .18em;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(34px, 5.8vw, 50px);
		color: var(--text-strong);
		line-height: 1.08;
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 620px;
		line-height: 1.6;
	}

	.head__subintro {
		margin: 0;
		font-size: 14px;
		font-style: italic;
		color: var(--text-dim);
		max-width: 560px;
		line-height: 1.55;
	}
</style>
