---
// The ship's log: a static header, then the ShipsLog island owns the wandering
// chart (projected marks, wakes, the Flannan memorial), the log list, the
// bearing card with its flares, and the in-memoriam modal. Data stays on
// getHobbies()/getSuggestions(); a hobby with a null coord rides the log only,
// never the chart.
import BaseLayout from '../layouts/BaseLayout.astro';
import ShipsLog from '../components/islands/ShipsLog';
import { getHobbies, getSuggestions, getSiteCopy, getFigurehead, getCarvings, getNotes, getDoodles, getKeeperProfile } from '../lib/api';
import { boltedSvg } from '../lib/carvings';

const hobbies = await getHobbies();
const suggestions = await getSuggestions();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();

// The journal, so a bearing card can pull up a tied entry in place (the note
// tie is the same noteIds convention a light uses); the sign-off is the
// keeper's, for that pulled-up entry's foot.
const notes = await getNotes();
const doodles = await getDoodles();
const keeper = await getKeeperProfile();

// The diorama's ten carving spots, resolved here because ShipsLog is an
// island and can't reach src/lib/api.ts itself (the towerSvg precedent).
const carvings = await getCarvings();
const bolted = {
	chartRose:       boltedSvg('chart-rose', carvings),
	seaSerpent:      boltedSvg('sea-serpent', carvings),
	mooredLamp:      boltedSvg('moored-lamp', carvings),
	adriftBoat:      boltedSvg('adrift-boat', carvings),
	adriftWake:      boltedSvg('adrift-wake', carvings),
	maroonedPalm:    boltedSvg('marooned-palm', carvings),
	portAnchor:      boltedSvg('port-anchor', carvings),
	signalFlare:     boltedSvg('signal-flare', carvings),
	compassRoseStar: boltedSvg('compass-rose-star', carvings),
	sailTent:        boltedSvg('sail-tent', carvings),
};
---
<BaseLayout title="The ship's log · Justin Smith" active="hobbies" quipKey="quipHobbies">
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">Hobbies · past and adrift</span>
		<h1 class="head__title fade-up fade-up--2">Off course, not overboard</h1>
		<p class="head__intro fade-up fade-up--3">Every hobby I ever picked up is still out there somewhere. None of them sank. The chart just needs updating, and the keeper is slow with the ink.</p>
		<p class="head__subintro fade-up fade-up--4">Filed with the harbor watch, who logs every overdue ship as "expected on the next fair wind," never "lost."</p>
	</section>

	<ShipsLog
		client:load
		hobbies={hobbies}
		suggestions={suggestions.map((s) => s.value)}
		notes={notes}
		doodles={doodles}
		signoff={keeper.signoff}
		catEnabled={copy.eggs.cat}
		catPages={copy.catPages}
		catSpots={copy.catSpots}
		catDesigns={catDesigns}
		bolted={bolted}
	/>
</BaseLayout>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 16px;
	}

	.head__kicker {
		margin-bottom: 0;
		font-size: 12px;
		letter-spacing: .18em;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(34px, 5.8vw, 50px);
		color: var(--text-strong);
		line-height: 1.08;
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 620px;
		line-height: 1.6;
	}

	.head__subintro {
		margin: 0;
		font-size: 14px;
		font-style: italic;
		color: var(--text-dim);
		max-width: 560px;
		line-height: 1.55;
	}
</style>
