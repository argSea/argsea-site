---
// Projects, now the lights: static header, then the LightsBoard island owns
// the filter pills, count line, the night coast, and the light-list register.
// boat/tower-stub are carving spots inside that island; it can't reach
// src/lib/api.ts itself, so their bolted markup is resolved here and passed
// down as props.
import BaseLayout from '../layouts/BaseLayout.astro';
import LightsBoard from '../components/islands/LightsBoard';
import { getProjects, getNotes, getSiteCopy, getFigurehead, getKeeperProfile, getCarvings } from '../lib/api';
import { boltedSvg } from '../lib/carvings';

const projects = await getProjects();
const notes = await getNotes();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();
const keeper = await getKeeperProfile();
const carvings = await getCarvings();
const boatSvg = boltedSvg('boat', carvings);
const towerSvg = boltedSvg('tower-stub', carvings);
---
<BaseLayout title="The lights · argsea.com" active="projects" quipKey="quipProjects">
	<!-- Real furniture, not backdrop: each piece carries data-plx so the
	     mousemove script below can move it independently. The ambient sky
	     ramp stays a page::before background (see the style block); this sits
	     on top of it and behind everything else, same z-index:-1 layer. -->
	<div class="sky" aria-hidden="true">
		<!-- Behind everything else, including the milky way: the mock's own
		     starOn toggle default (true) with nothing yet to turn it off. -->
		<div class="sky__stars" data-plx="4"></div>
		<div class="sky__milkyway" data-plx="3">
			<div class="sky__milkyway-inner">
				<div class="sky__milkyway-band"></div>
				<!-- the specks stay sharp; only the band above is blurred -->
				<div class="sky__milkyway-specks"></div>
			</div>
		</div>
		<span class="sky__twinkle" style="left: 6%; top: 180px; animation-duration: 4.2s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 16%; top: 44px; animation-delay: 1s; animation-duration: 5.1s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 29%; top: 238px; width: 2.5px; height: 2.5px; animation-delay: .5s; animation-duration: 6s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 41%; top: 90px; animation-delay: 2s; animation-duration: 4.6s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 58%; top: 198px; animation-delay: 1.4s; animation-duration: 5.5s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 72%; top: 30px; animation-delay: .8s; animation-duration: 6.4s" data-plx="4"></span>
		<span class="sky__twinkle" style="left: 90%; top: 150px; animation-delay: 2.4s; animation-duration: 5.8s" data-plx="4"></span>
		<div class="sky__cirrus sky__cirrus--a" data-plx="5"></div>
		<div class="sky__cirrus sky__cirrus--b" data-plx="5"></div>
		<div class="sky__moon-halo" data-plx="7"></div>
		<div class="sky__moon-ring" data-plx="7"></div>
		<div class="sky__moon-disc" data-plx="7">
			<span class="sky__crater sky__crater--a"></span>
			<span class="sky__crater sky__crater--b"></span>
			<span class="sky__crater sky__crater--c"></span>
		</div>
	</div>
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">Projects · the light list</span>
		<h1 class="head__title fade-up fade-up--1">The lights</h1>
		<p class="head__intro fade-up fade-up--2">The view from the lamp room. Every system I keep burning is out there on the coast, logged by its <em>characteristic</em>: the blink that tells you which light you're looking at. Click one to read its entry.</p>
	</section>
	<LightsBoard client:load projects={projects} notes={notes} signoff={keeper.signoff} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} boatSvg={boatSvg} towerSvg={towerSvg} />
</BaseLayout>

<script>
	// Mouse parallax for the sky furniture only: a small, self-contained
	// listener rather than a React island, since nothing here needs state.
	// Gated on pointer:fine + motion so touch devices and reduced-motion
	// readers never pay for it. Astro ships page <script> as a module, which
	// only ever runs once per load, so there's no repeat-mount to leak a
	// second listener from.
	if (matchMedia('(pointer: fine)').matches && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
		let mouseX = 0;
		let mouseY = 0;
		let raf = 0;

		const applyParallax = () => {
			raf = 0;
			const dx = mouseX / window.innerWidth - 0.5;
			const dy = mouseY / window.innerHeight - 0.5;
			// translate is its own CSS property, composed alongside transform
			// rather than replacing it, so this never fights the keyframe
			// transforms already animating the cirrus/craters/twinklers.
			document.querySelectorAll<HTMLElement>('[data-plx]').forEach((el) => {
				const factor = Number(el.dataset.plx) || 0;
				el.style.translate = `${(-dx * factor).toFixed(1)}px ${(-dy * factor * 0.6).toFixed(1)}px`;
			});
		};

		window.addEventListener('mousemove', (event) => {
			mouseX = event.clientX;
			mouseY = event.clientY;
			if (!raf) {
				raf = requestAnimationFrame(applyParallax);
			}
		});
	}
</script>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 0;
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.head__kicker {
		margin-bottom: -8px;
		font-size: 12px;
		letter-spacing: .18em;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(32px, 5.5vw, 46px);
		color: var(--text-strong);
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 620px;
		line-height: 1.6;
	}

	.head__intro em {
		font-style: italic;
		color: var(--text-soft);
	}

	/* The whole page is the night canvas: the header copy and filter pills
	   render on top of a sky that deepens from the nav down to the top of
	   the coast, which then carries the darkening the rest of the way itself
	   (see .coast in LightsBoard.css) so it stays tied to section order, not
	   how tall the page happens to be. The moon halo lives up here too, so no
	   overflow edge ever slices it flat. */
	/* z-index:0 (not just position:relative) matters here: without it .page
	   isn't its own stacking context, so ::before's z-index:-1 below escapes
	   to the root context and paints behind body's own background instead of
	   just behind .page's content, i.e. invisible. That's the actual reason
	   the moon "got lost." */
	:global(.page) {
		position: relative;
		z-index: 0;
	}

	:global(.page)::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		/* The moon moved to real .sky elements below (it needs its own DOM
		   node to carry data-plx for the mousemove parallax); this pseudo now
		   only draws the ambient ramp. */
		/* Held flat at #101a3e past 260px, exactly the mock's skyStyle: the
		   panorama's own top stop is that same #101a3e, so wherever the coast
		   begins (its y shifts with header wrapping), sky meets pano with no
		   edge. A previous version kept descending toward the register tone
		   here and drew a hard full-width seam across the pano's top. The
		   only other place this ramp ever shows, the footer band, gets the
		   scene's opaque terminal below instead. */
		background: linear-gradient(180deg, #0d0f1c 0%, #0e1226 120px, #101a3e 260px, #101a3e 100%);
	}

	/* The mock's footer sits inside the scene on its #0a0d1a terminal; ours
	   is a shared transparent component, so on this page it takes that same
	   backdrop or the flat #101a3e sky above would glow through it. Safe to
	   write unscoped: this stylesheet only ships with /projects. */
	:global(.site-footer) {
		background: #0a0d1a;
	}

	/* --- sky furniture: real elements (not the ramp above) so mousemove
	   parallax can move each piece by its own data-plx factor. Anchored the
	   same way the old moon gradient was (right 9%/top 176px, translate
	   -50%/-50% to recenter on that point) so its position stays proven
	   across viewports without retuning. Sits behind the header copy, same
	   z-index:-1 layer as .page::before, painted after it so the furniture
	   reads on top of the ramp. */
	.sky {
		position: absolute;
		inset: 0;
		z-index: -1;
		/* Everything in here deliberately pokes past the page (the stars'
		   -24px inset, the moon halo's negative top, sailBy riding to 108%),
		   so the layer must clip or that overflow feeds .page's scrollable
		   area and the page grows a second, inner scrollbar. */
		overflow: hidden;
		pointer-events: none;
	}

	.sky__stars {
		position: absolute;
		inset: -24px;
		background: var(--stars-bg);
	}

	.sky__milkyway {
		position: absolute;
		left: -15%;
		top: 26px;
		width: 140%;
		height: 130px;
	}

	.sky__milkyway-inner {
		position: absolute;
		inset: 0;
		transform: rotate(-11deg);
	}

	.sky__milkyway-band {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent, rgba(180, 190, 240, .05) 34%, rgba(207, 214, 245, .09) 50%, rgba(180, 190, 240, .045) 66%, transparent);
		filter: blur(10px);
	}

	.sky__milkyway-specks {
		position: absolute;
		left: 6%;
		top: 46%;
		width: 1.5px;
		height: 1.5px;
		background: transparent;
		box-shadow:
			24px 6px 0 rgba(222, 228, 250, .4), 70px -8px 0 rgba(222, 228, 250, .26),
			120px 12px 0 rgba(222, 228, 250, .34), 180px -4px 0 rgba(222, 228, 250, .22),
			240px 8px 0 rgba(222, 228, 250, .4), 305px -10px 0 rgba(222, 228, 250, .28),
			375px 4px 0 rgba(222, 228, 250, .36), 450px -6px 0 rgba(222, 228, 250, .22),
			530px 10px 0 rgba(222, 228, 250, .32), 615px -2px 0 rgba(222, 228, 250, .26),
			705px 6px 0 rgba(222, 228, 250, .36), 800px -8px 0 rgba(222, 228, 250, .22),
			900px 2px 0 rgba(222, 228, 250, .3), 1010px -5px 0 rgba(222, 228, 250, .24),
			1130px 7px 0 rgba(222, 228, 250, .3);
	}

	.sky__twinkle {
		position: absolute;
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: #e8ebfa;
		animation: skyTwinkle ease-in-out infinite;
	}

	@keyframes skyTwinkle {
		0%, 100% { opacity: .2; }
		50%      { opacity: .85; }
	}

	.sky__cirrus {
		position: absolute;
		left: -8%;
		border-radius: 50%;
		filter: blur(4px);
		background: linear-gradient(180deg, rgba(200, 208, 245, .1), rgba(200, 208, 245, .015));
	}

	.sky__cirrus--a {
		top: 38px;
		width: 190px;
		height: 14px;
		animation: sailBy 280s linear -60s infinite;
	}

	.sky__cirrus--b {
		top: 92px;
		width: 130px;
		height: 11px;
		animation: sailBy 340s linear -210s infinite;
	}

	/* The warm cream moon, back after the shipped cool/low/large one was
	   scrapped: each layer sits at its own top/right box, not centered on a
	   shared anchor point, so these numbers are the mock's own directly. */
	.sky__moon-halo {
		position: absolute;
		top: -103px;
		right: calc(8% - 159px);
		width: 340px;
		height: 340px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(236, 231, 216, .12) 0%, transparent 66%);
	}

	.sky__moon-ring {
		position: absolute;
		top: 35px;
		right: calc(8% - 21px);
		width: 64px;
		height: 64px;
		border-radius: 50%;
		border: 1px solid rgba(236, 231, 216, .13);
		filter: blur(1.2px);
	}

	.sky__moon-disc {
		position: absolute;
		top: 56px;
		right: 8%;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: radial-gradient(circle at 38% 32%, #f6f1e2, #ddd6bf 62%, #c4bda6);
		box-shadow: 0 0 24px 7px rgba(236, 231, 216, .32);
		overflow: hidden;
	}

	.sky__crater {
		position: absolute;
		border-radius: 50%;
		background: rgba(160, 150, 120, .4);
	}

	.sky__crater--a { left: 5px;  top: 7px; width: 4.5px; height: 4.5px; }
	.sky__crater--b { left: 12px; top: 12px; width: 3px;   height: 3px;   background: rgba(160, 150, 120, .35); }
	.sky__crater--c { left: 11px; top: 4px;  width: 2px;   height: 2px;   background: rgba(160, 150, 120, .3); }
</style>
