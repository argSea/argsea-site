---
// 404 — run aground. Centered "Notice to Mariners" copy above the grounded
// scene: the listing boat on a sand-toned shoal, a warning buoy, a circling
// gull, and two layers of choppy water. No lighthouse beam — cut by design
// ruling; don't reintroduce it. The placard's "last position" is the light
// list egg; the harbor cat heckles from the placard's top edge. Astro emits
// this as dist/404.html; serving it for unknown routes is nginx config at
// cutover.
import BaseLayout from '../layouts/BaseLayout.astro';
import HarborCat from '../components/islands/HarborCat';
import LightList from '../components/islands/LightList';
import { getSiteCopy } from '../lib/api';

const copy = await getSiteCopy();
// The wreck always has an audience — no 1-in-3 roll here, only the toggles
const catAboard = copy.eggs.cat && copy.catLocs.p404;
const lighthouses = copy.eggs.lights ? copy.lighthouses : [];
---
<BaseLayout title="404 · run aground · argsea.com" active="none" quipKey="quip404">
	<section class="shallows">
		<div class="firefly ff-1"></div>
		<div class="firefly ff-2"></div>
		<div class="firefly ff-3"></div>

		<div class="gull">
			<svg width="26" height="10" viewBox="0 0 26 10" fill="none"><path d="M1 8 Q6.5 1 13 6 Q19.5 1 25 8" stroke="#8f9be0" stroke-width="1.4" fill="none" stroke-linecap="round" /></svg>
		</div>

		<div class="copy">
			<div class="section-label fade-up fade-up--1">404 · run aground</div>
			<h1 class="copy__headline fade-up fade-up--2">You've drifted into the shallows.</h1>

			<!-- clearance below the headline stays: the perched cat must never collide with the copy -->
			<div class="placard">
				{catAboard && <HarborCat client:visible context="wreck" />}
				<div class="placard__ribbon">⚠ Notice to Mariners</div>
				<p class="placard__report">The page you set course for is not on any chart. Your vessel has run onto the shoals — no page lies beyond this point.</p>
				<div class="placard__meta">
					{lighthouses.length > 0
						? <LightList client:visible lighthouses={lighthouses} />
						: <span>last position: 404</span>}
					<span>depth: 0 fathoms</span>
				</div>
			</div>

			<div class="copy__actions fade-up fade-up--4">
				<a href="/" class="btn btn--primary">back to harbor</a>
				<a href="/projects" class="btn btn--outline">chart a new course</a>
			</div>
		</div>

		<!-- the grounded scene -->
		<div class="scene">
			<div class="shoal"></div>
			<div class="shoal-crest"></div>

			<!-- dotted route line that dies at the sand -->
			<svg class="route" viewBox="0 0 300 70" fill="none" preserveAspectRatio="none"><path d="M0 6 Q90 -8 170 34 T292 58" stroke="rgba(240,217,168,.5)" stroke-width="2" stroke-dasharray="2 7" stroke-linecap="round" fill="none" /></svg>
			<div class="route-end"></div>

			<div class="wreck">
				<svg width="150" height="130" viewBox="0 0 150 130" fill="none" style="overflow:visible">
					<!-- mast + snapped top -->
					<path d="M75 66 V16" stroke="#5f6ec4" stroke-width="3" stroke-linecap="round" />
					<path d="M75 16 L70 6" stroke="#5f6ec4" stroke-width="2.4" stroke-linecap="round" opacity=".8" />
					<!-- torn sail -->
					<path d="M75 20 L108 54 L75 54 Z" fill="#f0d9a8" opacity=".92" />
					<path d="M92 38 L108 54 L96 54 Z" fill="#131628" />
					<!-- hull -->
					<path d="M18 66 L132 66 L112 96 L38 96 Z" fill="#93a0e8" />
					<path d="M18 66 L132 66 L127 73 L23 73 Z" fill="#a9b4f0" />
					<!-- planking -->
					<path d="M34 80 h82 M40 88 h70" stroke="#5f6ec4" stroke-width="1.4" opacity=".55" />
					<!-- a little cabin -->
					<rect x="62" y="54" width="26" height="12" rx="1.5" fill="#5f6ec4" />
				</svg>
			</div>

			<div class="buoy">
				<svg width="30" height="46" viewBox="0 0 30 46" fill="none" style="overflow:visible">
					<ellipse class="buoy__lamp" cx="15" cy="8" rx="4" ry="4" fill="#f0d9a8" />
					<path d="M15 12 V20" stroke="#5f6ec4" stroke-width="1.6" />
					<path d="M6 22 L24 22 L21 40 L9 40 Z" fill="#c05a4a" />
					<path d="M7.4 30 L22.6 30" stroke="#f0d9a8" stroke-width="4" />
					<path d="M6 22 L24 22" stroke="#e8ebfa" stroke-width="1.4" opacity=".6" />
				</svg>
			</div>

			<div class="chop chop--front"></div>
			<div class="chop chop--back"></div>
		</div>
	</section>
</BaseLayout>

<style>
	.shallows {
		position: relative;
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-end;
		padding: clamp(40px, 7vw, 72px) var(--gutter) 0;
		overflow: hidden;
	}

	.ff-1 { left: 16%;  top: 14%; width: 4px; height: 4px; background: var(--gold);       box-shadow: 0 0 12px 3px rgba(240, 217, 168, .3);  animation: drift 12s ease-in-out infinite; }
	.ff-2 { right: 18%; top: 22%; width: 3px; height: 3px; background: var(--periwinkle); box-shadow: 0 0 10px 3px rgba(147, 160, 232, .3);  animation: drift 15s ease-in-out 2s infinite; }
	.ff-3 { left: 30%;  top: 26%; width: 3px; height: 3px; background: var(--periwinkle); box-shadow: 0 0 10px 3px rgba(147, 160, 232, .25); animation: drift 10s ease-in-out 1s infinite; }

	.gull {
		position: absolute;
		left: 26%;
		top: 30%;
		opacity: .55;
		animation: gullFly 9s ease-in-out infinite alternate;
	}

	@keyframes gullFly {
		0%   { transform: translate(0, 0); }
		50%  { transform: translate(40px, -16px); }
		100% { transform: translate(80px, 4px); }
	}

	.copy {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
		text-align: center;
		margin-bottom: clamp(20px, 4vw, 36px);
	}

	.copy__headline {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(32px, 6vw, 54px);
		line-height: 1.12;
		color: var(--text-strong);
		max-width: 640px;
		text-wrap: balance;
	}

	/* Resting tilt is a base transform: reduced-motion strips the entry, keeps the pose */
	.placard {
		position: relative;
		max-width: 440px;
		margin-top: 38px;
		background: #171a2e;
		border: 1px solid rgba(150, 160, 220, .3);
		border-radius: 12px;
		padding: 22px 26px 24px;
		box-shadow: 0 20px 48px rgba(0, 0, 0, .5);
		transform: rotate(-1deg);
		animation: placardIn .8s ease .25s both;
	}

	@keyframes placardIn {
		from { opacity: 0; transform: translateY(18px) rotate(-1.2deg); }
		to   { opacity: 1; transform: translateY(0) rotate(-1deg); }
	}

	.placard__ribbon {
		position: absolute;
		top: -11px;
		left: 50%;
		transform: translateX(-50%);
		background: var(--gold);
		color: var(--btn-text-dark);
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: .14em;
		text-transform: uppercase;
		padding: 4px 12px;
		border-radius: 999px;
		white-space: nowrap;
	}

	.placard__report {
		margin: 8px 0 0;
		font-size: 16.5px;
		line-height: 1.65;
		color: var(--text-soft);
	}

	.placard__meta {
		margin-top: 16px;
		padding-top: 14px;
		border-top: 1px dashed rgba(150, 160, 220, .25);
		display: flex;
		justify-content: space-between;
		gap: 12px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--text-dim);
	}

	.copy__actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 4px;
	}

	/* --- the grounded scene --- */

	.scene {
		position: relative;
		width: min(720px, 94vw);
		height: clamp(150px, 22vw, 200px);
		flex: none;
	}

	/* Sand-toned shoal (design ruling: warm and desaturated so "shallows" reads) */
	.shoal {
		position: absolute;
		bottom: 34px;
		left: 50%;
		transform: translateX(-50%);
		width: 64%;
		height: 70px;
		border-radius: 50%;
		background: radial-gradient(ellipse at 50% 40%, #59503a 0%, #3a3548 55%, transparent 78%);
		opacity: .9;
	}

	.shoal-crest {
		position: absolute;
		bottom: 52px;
		left: 50%;
		transform: translateX(-50%);
		width: 40%;
		height: 28px;
		border-radius: 50%;
		background: radial-gradient(ellipse at 50% 40%, #6e6248 0%, transparent 75%);
	}

	.route {
		position: absolute;
		bottom: 60px;
		left: 6%;
		width: 44%;
		height: 70px;
		overflow: visible;
	}

	.route-end {
		position: absolute;
		bottom: 56px;
		left: calc(6% + 44% - 6px);
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--gold);
		box-shadow: 0 0 10px 2px rgba(240, 217, 168, .5);
	}

	/*
	 * The centering translateX and the listing tilt live in the base transform
	 * AND both keyframe poses, so reduced-motion (which strips the animation)
	 * leaves the boat grounded exactly where it should be.
	 */
	.wreck {
		position: absolute;
		bottom: 44px;
		left: 50%;
		transform-origin: 50% 90%;
		transform: translateX(-50%) rotate(15deg);
		animation: listing 6s ease-in-out infinite;
	}

	@keyframes listing {
		0%, 100% { transform: translateX(-50%) rotate(15deg); }
		50%      { transform: translateX(-50%) rotate(18.5deg); }
	}

	.buoy {
		position: absolute;
		bottom: 46px;
		right: 10%;
		transform-origin: 50% 100%;
		transform: rotate(-6deg);
		animation: buoyBob 3.4s ease-in-out infinite;
	}

	@keyframes buoyBob {
		0%, 100% { transform: translateY(0) rotate(-6deg); }
		50%      { transform: translateY(-7px) rotate(5deg); }
	}

	.buoy__lamp {
		animation: buoyLamp 2.2s ease-in-out infinite;
	}

	@keyframes buoyLamp {
		0%, 100% { opacity: .35; }
		50%      { opacity: 1; }
	}

	/* Choppy water in front, two layers drifting opposite ways */
	.chop {
		position: absolute;
		left: -2%;
		width: 104%;
		height: 20px;
	}

	.chop--front {
		bottom: 8px;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2264%22%20height=%2220%22%3E%3Cpath%20d=%22M0%2012%20Q%208%202,%2016%2012%20T%2032%2012%20T%2048%2012%20T%2064%2012%22%20stroke=%22rgba(147,160,232,0.45)%22%20stroke-width=%222%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
		animation: chop 5s linear infinite;
	}

	.chop--back {
		bottom: 0;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2264%22%20height=%2220%22%3E%3Cpath%20d=%22M0%2012%20Q%208%204,%2016%2012%20T%2032%2012%20T%2048%2012%20T%2064%2012%22%20stroke=%22rgba(95,110,196,0.55)%22%20stroke-width=%222%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
		animation: chopBack 7s linear infinite;
	}

	@keyframes chop {
		0%   { background-position-x: 0; }
		100% { background-position-x: -64px; }
	}

	@keyframes chopBack {
		0%   { background-position-x: 0; }
		100% { background-position-x: 64px; }
	}
</style>
