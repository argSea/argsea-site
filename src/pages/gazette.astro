---
// The Gull Post: the easter-egg morning edition, reached by poking the watch
// cat ten times (WatchCat phases the page to paper, then navigates here). Its
// own paper stock, nav, and footer, not the site's dark shell, so it stands
// alone rather than under BaseLayout. Design canon: design/Hello Gazette.dc.html,
// transcribed verbatim, including its renderVals derivations: the lead is the
// flagship (its own gazette block, falling back to title/shortDesc/body for a
// light that never made the paper), the below-fold pair is the next two lit
// non-flagship lights in list order, the rail is the newest three notes, the
// notices line and classifieds come off the hobbies register, and the filler
// ad ports the copy singleton's dictionary verbatim.
//
// The folio date is the build date and the folio wx is the latest journal
// entry's conditions (the cross-repo pin, not the mock's own "wx" field); the
// delivery gull is the delivery-gull carving spot, its fixture the
// byte-identical builtin fallback. The fonts and the shared tokens come in
// the same order every other page takes them (BaseLayout: fonts, then
// global.css), so this standalone page joins the shared CSS graph the same
// way rather than perturbing its chunk order; the page's own is:global below
// then repaints the body to paper. The dark-theme chrome (nav, footer, cat)
// simply isn't rendered here.
import '@fontsource/gloock';
import '@fontsource-variable/newsreader/standard.css';
import '@fontsource-variable/newsreader/standard-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

import { getProjects, getNotes, getKeeperProfile, getCarvings, getHobbies, getSiteCopy, type Project } from '../lib/api';
import { boltedSvg, innerMarkup } from '../lib/carvings';
import { registryNo } from '../lib/lightChar';
import { mediaUrl } from '../lib/media';

const projects = await getProjects();
const allNotes = await getNotes();
const keeper = await getKeeperProfile();
const hobbies = await getHobbies();
const copy = await getSiteCopy();

// A light still burns if it was never assigned one (null defaults to a
// burning fixed white) or its own light carries no extinguished year.
const isLit = (project: Project) => !project.light || !project.light.extinguished;

// The lead is the flagship; the two below-fold stories are the next two
// lights still lit, in list order, so a retired light never runs twice.
const flagship = projects.find((project) => project.flagship) ?? null;
const litNonFlagship = projects.filter((project) => project.id !== flagship?.id && isLit(project));
const [second, third] = litNonFlagship.slice(0, 2);

// Each story's first picture: the gallery leads, the legacy single photo is
// the last resort. The site's real image machinery, not the mock's slots.
const firstImage = (project: Project | null | undefined) =>
	(project?.images && project.images.length > 0 ? project.images[0] : project?.image) ?? null;

// The lead's gazette block; a flagship that never made the paper falls back
// to its own title/short desc/body, the fallback order the mock names.
const leadHeadline = flagship?.gazette?.headline ?? flagship?.title ?? '';
const leadDeck = flagship?.gazette?.deck ?? flagship?.shortDesc ?? '';
const leadDateline = flagship?.gazette?.dateline ?? 'from the station';
const leadOngoing = flagship ? isLit(flagship) : false;
const leadHasGazette = !!flagship?.gazette;
const leadP1 = flagship?.gazette?.p1 ?? '';
const leadP2 = flagship?.gazette?.p2 ?? '';
const leadCaption = flagship?.gazette?.caption ?? '';
const leadFacts = (flagship?.facts ?? []).slice(0, 4);
const leadImage = firstImage(flagship);

// The full-log route when the flagship has a published log, else the coast.
const leadHref = flagship?.hasLog ? `/projects/${flagship.slug}` : '/projects';

// The below-fold pair carries only a headline and a first paragraph, same
// fallback rule as the lead, minus the deck/dateline/facts the lead alone runs.
const secondHeadline = second?.gazette?.headline ?? second?.title ?? '';
const secondHasGazette = !!second?.gazette;
const secondP1 = second?.gazette?.p1 ?? '';
const secondCaption = second?.gazette?.caption ?? '';
const secondImage = firstImage(second);

const thirdHeadline = third?.gazette?.headline ?? third?.title ?? '';
const thirdHasGazette = !!third?.gazette;
const thirdP1 = third?.gazette?.p1 ?? '';
const thirdCaption = third?.gazette?.caption ?? '';
const thirdImage = firstImage(third);

// The three newest journal entries fill the rail; each row is a title + its
// date-stamped dek, teaser lowercased into the sub-line, single-sourced from
// the journal so it can't drift.
const lowerFirst = (value: string) => value.charAt(0).toLowerCase() + value.slice(1);
const railNotes = allNotes.slice(0, 3).map((note) => ({
	title: note.title,
	sub: `${note.date} · ${lowerFirst(note.teaser)}`,
}));

// The notices line and the classifieds both come off the hobbies register:
// the classifieds sell the first clause of what each non-moored one left
// behind, the notice names whichever hobby is chasing the highest gauge.
const STATE_LABELS: Record<string, string> = { moored: 'moored', adrift: 'adrift', marooned: 'marooned', port: 'made port', inkspill: 'bearing smudged' };
const classifieds = hobbies
	.filter((hobby) => hobby.state !== 'moored')
	.map((hobby) => `${hobby.name.toUpperCase()}, ${STATE_LABELS[hobby.state] ?? hobby.state}. ${hobby.floats.split(' · ')[0]}`)
	.join(' · ');
const rankedByGauge = hobbies.filter((hobby) => hobby.gauge != null).sort((a, b) => (b.gauge ?? 0) - (a.gauge ?? 0));
const tinker = rankedByGauge[0]?.name.toLowerCase() ?? 'the home lab';
const presently = copy.gazette?.presently || 'keeping the light';
const vol = copy.gazette?.vol || 'vol. XXXIX · harbor edition';

// The filler ad ports the argsea dictionary verbatim off the copy singleton,
// the same source and "argc" mono treatment as the footer's own dictionary line.
const dictSegments = copy.dict
	.split(/\b(argc)\b/)
	.map((text) => ({ text, isArgc: text === 'argc' }));

// Folio date = build date; folio wx = the latest journal entry's conditions.
const WEEKDAYS = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
const MONTHS = ['january', 'february', 'march', 'april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december'];
const now = new Date();
const folioDate = `${WEEKDAYS[now.getDay()]}, ${MONTHS[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
const folioWx = `wx: ${allNotes[0]?.conditions ?? 'light steady · no incidents'}`;

// The delivery gull carving; its fixture svg is the byte-identical fallback.
const gullSvg = boltedSvg('delivery-gull', await getCarvings());
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>The Gull Post · argsea.com</title>
	</head>
	<body>
		<div class="gazette">
			<div class="gazette__sheet">

				<!-- folio line -->
				<div class="gazette__folio">
					<span class="gazette__folio-item">{vol}</span>
					<span class="gazette__folio-item">{folioDate}</span>
					<span class="gazette__folio-item">{folioWx}</span>
				</div>

				<!-- masthead -->
				<div class="gazette__masthead">
					<!-- the delivery gull, cap and all · payment expected on the spot -->
					<svg class="gazette__gull" width="46" height="44" viewBox="0 0 46 44" fill="none" stroke="rgba(32,35,60,.85)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" data-bolted={gullSvg ? 'delivery-gull' : undefined}>
						{gullSvg ? (
							<Fragment set:html={innerMarkup(gullSvg)} />
						) : (
							<>
								<path d="M14 41 v-5 M20 41 v-5" stroke-width="1.4"></path>
								<path d="M11 36 C8 30 9 23 15 20 C22 16.5 30 19 31 26 C31.8 32 27 36 20 36 Z" fill="#f1ecdd"></path>
								<path d="M17 24 C22 21 28 23 29 28 C26 30 19 30 16 27 Z" fill="rgba(32,35,60,.18)" stroke="none"></path>
								<path d="M15 20 C14 14 18 10 23 10 C27 10 30 13 30 17" fill="#f1ecdd"></path>
								<path d="M30 16.5 L36 18 L30 19.5" fill="#c9a96a" stroke="rgba(32,35,60,.85)"></path>
								<circle cx="25.5" cy="15" r="1.1" fill="rgba(32,35,60,.85)" stroke="none"></circle>
								<path d="M16.5 11.5 C17 7.5 21 5.5 25 6.5 C28 7.2 29.5 9.5 29.5 11.5 L31.5 11.5 C32.2 11.5 32.2 12.8 31.5 12.8 L18 12.8 Z" fill="rgba(32,35,60,.75)" stroke="none"></path>
							</>
						)}
					</svg>
					<div class="gazette__title">The Gull Post</div>
					<div class="gazette__strap">all the lights fit to keep · delivered by seabird, payment expected on the spot · price: one flare</div>
				</div>

				<!-- section nav -->
				<div class="gazette__nav">
					<a href="/projects" class="gazette__nav-link">The Light List</a>
					<a href="/notes" class="gazette__nav-link">The Journal</a>
					<a href="/hobbies" class="gazette__nav-link">The Wandering Chart</a>
					<a href={`mailto:${keeper.email}`} class="gazette__nav-link">Harbor Contact</a>
				</div>

				{flagship && (
					<>
					<!-- front page: lead + rail -->
					<div class="gazette__front">

						<!-- lead story -->
						<div class="gazette__lead">
							<span class="gazette__kicker">the light list · no. {registryNo(flagship.order)} · flagship</span>
							<div class="gazette__headline">{leadHeadline}</div>
							<div class="gazette__dek">{leadDeck}</div>
							<div class="gazette__byline">
								<span class="gazette__byline-by">By the Keeper</span>
								<span class="gazette__byline-meta">reporting {leadDateline} · est. {flagship.firstLit}{leadOngoing ? ', ongoing' : ''}</span>
							</div>
							<div class="gazette__lead-cols">
								<div class="gazette__lead-body">
									{leadHasGazette ? (
										<>
										<div class="gazette__para">{leadP1}</div>
										{leadP2 && <div class="gazette__para">{leadP2}</div>}
										</>
									) : (
										<div class="gazette__para" set:html={flagship.body} />
									)}
									{flagship.moral && <div class="gazette__moral">{flagship.moral}</div>}
									<a href={leadHref} class="gazette__jump">continued in the full log → page {registryNo(flagship.order)}</a>
								</div>
								<div class="gazette__lead-aside">
									<div class="gazette__figure">
										<div class="gazette__figure-frame">
											{leadImage
												? <img src={mediaUrl(leadImage)} alt={flagship.title} />
												: <div class="gazette__figure-paper" aria-hidden="true"></div>}
										</div>
										<span class="gazette__figure-caption">{leadCaption}</span>
									</div>
									<div class="gazette__numbers">
										<span class="gazette__numbers-head">by the numbers</span>
										{leadFacts.map((fact) => (
											<div class="gazette__numbers-row">
												<span class="gazette__numbers-label">{fact.heading}</span>
												<span class="gazette__numbers-value">{fact.fact}</span>
											</div>
										))}
									</div>
								</div>
							</div>
						</div>

						<!-- right rail -->
						<div class="gazette__rail">
							<div class="gazette__rail-block">
								<span class="gazette__rail-head">from the keeper's journal</span>
								{railNotes.map((note, index) => (
									<a href="/notes" class:list={['gazette__rail-item', { 'gazette__rail-item--ruled': index > 0 }]}>
										<span class="gazette__rail-title">{note.title}</span>
										<span class="gazette__rail-dek">{note.sub}</span>
									</a>
								))}
							</div>
							<div class="gazette__rail-block">
								<span class="gazette__rail-head">notices · the current watch</span>
								<div class="gazette__notice">The keeper is presently <span class="gazette__notice-em">{presently}</span>, <a href="/notes" class="gazette__notice-link">logging in the journal</a>, and <a href="/hobbies" class="gazette__notice-link">tinkering with {tinker}</a>. The light remains lit. The lighthouse cat was unavailable for comment.</div>
							</div>
							<div class="gazette__rail-block">
								<span class="gazette__rail-head">classified · hobbies</span>
								<div class="gazette__classified">{classifieds}</div>
								<a href="/hobbies" class="gazette__rail-more">the full wandering chart →</a>
							</div>
							<!-- filler ad · the argsea dictionary, verbatim off the copy singleton -->
							<div class="gazette__ad">
								<span class="gazette__ad-label">advertisement · run every edition, unpaid</span>
								<div class="gazette__ad-copy">
									<span class="gazette__ad-word">argsea</span>
									<span class="gazette__ad-pron">/ˈɑːrɡ·siː/ · noun</span>
									{dictSegments.map((segment) => (segment.isArgc ? <span class="gazette__ad-argc">{segment.text}</span> : segment.text))}
								</div>
							</div>
						</div>
					</div>

					<!-- below the fold: the next two lit lights -->
					<div class="gazette__below">
						<div class="gazette__story gazette__story--ruled">
							<span class="gazette__kicker">the light list · no. {second ? registryNo(second.order) : '004'} · est. {second?.firstLit ?? '2016'}</span>
							<div class="gazette__subhead">{secondHeadline}</div>
							<div class="gazette__story-body">
								<div class="gazette__story-figure">
									<div class="gazette__story-figure-frame">
										{secondImage
											? <img src={mediaUrl(secondImage)} alt={second?.title ?? ''} />
											: <div class="gazette__figure-paper" aria-hidden="true"></div>}
									</div>
									<span class="gazette__figure-caption">{secondCaption}</span>
								</div>
								<div class="gazette__story-text">
									{secondHasGazette
										? <div class="gazette__para gazette__para--sm">{secondP1}</div>
										: <div class="gazette__para gazette__para--sm" set:html={second?.body ?? ''} />}
									{second?.moral && <div class="gazette__moral gazette__moral--sm">{second.moral}</div>}
									<a href="/projects" class="gazette__jump">see the light →</a>
								</div>
							</div>
						</div>
						<div class="gazette__story">
							<span class="gazette__kicker">the light list · no. {third ? registryNo(third.order) : '006'} · est. {third?.firstLit ?? '2018'}</span>
							<div class="gazette__subhead">{thirdHeadline}</div>
							<div class="gazette__story-body">
								<div class="gazette__story-figure">
									<div class="gazette__story-figure-frame">
										{thirdImage
											? <img src={mediaUrl(thirdImage)} alt={third?.title ?? ''} />
											: <div class="gazette__figure-paper" aria-hidden="true"></div>}
									</div>
									<span class="gazette__figure-caption">{thirdCaption}</span>
								</div>
								<div class="gazette__story-text">
									{thirdHasGazette
										? <div class="gazette__para gazette__para--sm">{thirdP1}</div>
										: <div class="gazette__para gazette__para--sm" set:html={third?.body ?? ''} />}
									{third?.moral && <div class="gazette__moral gazette__moral--sm">{third.moral}</div>}
									<a href="/projects" class="gazette__jump">see the light →</a>
								</div>
							</div>
						</div>
					</div>
					</>
				)}

				<!-- foot folio -->
				<div class="gazette__foot">
					<span class="gazette__foot-item">the gull post · printed at the lighthouse</span>
					<span class="gazette__foot-note">corrections are logged in the journal, where they belong</span>
					<a href="/" class="gazette__foot-back">back to the standing edition →</a>
				</div>

			</div>
		</div>
	</body>
</html>

<style is:global>
	html {
		background: #e7e0cd;
	}

	body {
		margin: 0;
		background: #ece5d2;
		font-family: 'Newsreader Variable', 'Newsreader', serif;
		color: #20233c;
	}

	.gazette a {
		color: #8a6d3b;
		text-decoration: none;
	}

	.gazette a:hover {
		color: #20233c;
	}
</style>

<style>
	.gazette {
		min-height: 100vh;
		display: flex;
		justify-content: center;
		padding: clamp(10px, 3vw, 36px);
		box-sizing: border-box;
	}

	.gazette__sheet {
		width: min(1180px, 100%);
		background: #f1ecdd;
		box-shadow: 0 20px 60px rgba(32, 35, 60, .25);
		padding: clamp(20px, 4vw, 48px) clamp(18px, 4vw, 52px);
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
	}

	/* folio line */
	.gazette__folio {
		display: flex;
		justify-content: space-between;
		gap: 14px;
		flex-wrap: wrap;
		border-bottom: 1px solid rgba(32, 35, 60, .55);
		padding-bottom: 7px;
	}

	.gazette__folio-item {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11px;
		letter-spacing: .12em;
		text-transform: uppercase;
		color: #5c5644;
	}

	/* masthead */
	.gazette__masthead {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		padding: 26px 0 18px;
		border-bottom: 3px double rgba(32, 35, 60, .75);
		position: relative;
	}

	.gazette__gull {
		position: absolute;
		right: 6%;
		bottom: -3px;
	}

	.gazette__title {
		font-family: 'Gloock', serif;
		font-size: clamp(40px, 7vw, 74px);
		line-height: 1;
		letter-spacing: .01em;
		text-align: center;
	}

	.gazette__strap {
		font-size: 15px;
		font-style: italic;
		color: #5c5644;
		text-align: center;
	}

	/* section nav */
	.gazette__nav {
		display: flex;
		justify-content: center;
		gap: clamp(14px, 3vw, 34px);
		flex-wrap: wrap;
		padding: 9px 0;
		border-bottom: 1px solid rgba(32, 35, 60, .55);
	}

	.gazette__nav-link {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11.5px;
		letter-spacing: .14em;
		text-transform: uppercase;
	}

	/* front page grid */
	.gazette__front {
		display: grid;
		grid-template-columns: minmax(0, 2.6fr) minmax(0, 1fr);
		border-bottom: 1px solid rgba(32, 35, 60, .55);
	}

	.gazette__lead {
		padding: 22px 26px 24px 0;
		border-right: 1px solid rgba(32, 35, 60, .35);
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.gazette__kicker {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11px;
		letter-spacing: .16em;
		text-transform: uppercase;
		color: #8a6d3b;
	}

	.gazette__headline {
		font-family: 'Gloock', serif;
		font-size: clamp(28px, 4.6vw, 46px);
		line-height: 1.08;
		text-wrap: balance;
	}

	.gazette__dek {
		font-size: 19px;
		font-style: italic;
		line-height: 1.45;
		color: #494e70;
		text-wrap: pretty;
	}

	.gazette__byline {
		display: flex;
		gap: 12px;
		align-items: baseline;
		flex-wrap: wrap;
		border-top: 1px solid rgba(32, 35, 60, .25);
		border-bottom: 1px solid rgba(32, 35, 60, .25);
		padding: 6px 0;
	}

	.gazette__byline-by {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11.5px;
		letter-spacing: .1em;
		text-transform: uppercase;
		color: #5c5644;
	}

	.gazette__byline-meta {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11.5px;
		color: #8a7f63;
	}

	.gazette__lead-cols {
		display: flex;
		gap: 26px;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.gazette__lead-body {
		flex: 1.2 1 300px;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.gazette__para {
		font-size: 16.5px;
		line-height: 1.65;
		text-wrap: pretty;
	}

	.gazette__para--sm {
		font-size: 15.5px;
		line-height: 1.6;
	}

	.gazette__moral {
		font-size: 15px;
		font-style: italic;
		color: #494e70;
	}

	.gazette__moral--sm {
		font-size: 14px;
	}

	.gazette__jump {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12.5px;
		letter-spacing: .06em;
	}

	.gazette__lead-aside {
		flex: 1 1 240px;
		max-width: 340px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.gazette__figure {
		display: flex;
		flex-direction: column;
		gap: 7px;
	}

	.gazette__figure-frame {
		width: 100%;
		aspect-ratio: 3 / 2;
		overflow: hidden;
		background: #ddd5c0;
		border: 1px solid rgba(32, 35, 60, .35);
	}

	.gazette__figure-frame img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.gazette__figure-paper {
		width: 100%;
		height: 100%;
	}

	.gazette__figure-caption {
		font-size: 13px;
		font-style: italic;
		color: #5c5644;
		line-height: 1.45;
	}

	.gazette__numbers {
		border: 1px solid rgba(32, 35, 60, .45);
		padding: 14px 16px;
		display: flex;
		flex-direction: column;
		gap: 9px;
		background: rgba(32, 35, 60, .04);
	}

	.gazette__numbers-head {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 11px;
		letter-spacing: .16em;
		text-transform: uppercase;
		color: #5c5644;
		border-bottom: 1px solid rgba(32, 35, 60, .3);
		padding-bottom: 7px;
	}

	.gazette__numbers-row {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.gazette__numbers-label {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 10.5px;
		letter-spacing: .12em;
		text-transform: uppercase;
