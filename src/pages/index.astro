---
// Hello: hero, wave-with-boat (and its coast-in-miniature beacons), the
// flagship + featured cards, journal strip, the keeper's stores, hobbies
// preview, contact band. The dictionary lives in the shared Footer now, read
// from copy.dict (no dedicated dictionary block on this page anymore). The
// flagship card is the `flagship` flag; the two small cards are the
// `featured` flag in list order, never title matching, falling back to the
// next two by order so the section never shows the flagship alone. It opens
// the Light List entry in place; hero copy comes from the SiteCopy
// singleton; the say-hi email is the keeper's; the keeper's stores is
// approved copy hardcoded by design. The journal strip is the newest notes,
// static links out to /notes, and disappears once there are none. The
// hobbies preview is data-driven: still-burning hobbies fill "currently
// learning", resting ones become graveyard chips.
import BaseLayout from '../layouts/BaseLayout.astro';
import LighthouseMark from '../components/LighthouseMark.astro';
import WaveDivider from '../components/WaveDivider.astro';
import HomeLights from '../components/islands/HomeLights';
import JournalStrip from '../components/JournalStrip.astro';
import JournalStripDirector from '../components/islands/JournalStripDirector';
import NextHobbyChip from '../components/islands/NextHobbyChip';
import { getProjects, getSiteCopy, getKeeperProfile, getHobbies, getFigurehead, getNotes, getDoodles, getSuggestions } from '../lib/api';

const projects = await getProjects();
const allNotes = await getNotes();

// Flagship = the flagship flag; the two small cards = featured flag order,
// never title matching. Falls back to the next two by order when nothing
// else is featured, so the section never shows the flagship alone.
const flagship = projects.find((project) => project.flagship) ?? null;
const nonFlagship = projects.filter((project) => project.id !== flagship?.id);
const featuredExplicit = nonFlagship.filter((project) => project.featured);
const featuredTwo = (featuredExplicit.length > 0 ? featuredExplicit : nonFlagship).slice(0, 2);

// getNotes() sorts newest-first; cap at three so a growing journal never
// crowds the strip below the mantel
const journalPreview = allNotes.slice(0, 3);
const journalDoodles = await getDoodles();
const copy = await getSiteCopy();
const keeper = await getKeeperProfile();
const catDesigns = await getFigurehead();
const suggestions = await getSuggestions();

// The smuggler's cove: the copy singleton's egg toggles gate what gets wired.
// Bottle off (or an emptied proverb list) leaves the boat sailing, unpokeable.
// The cat's per-page/per-spot picking lives client-side (the director + the
// overlay islands share one pick); the frontmatter just forwards the toggles.
const proverbs = copy.eggs.bottle ? copy.bottleProverbs : [];

const stores = [
	{ label: 'languages',      items: 'java · python · node.js · go · php' },
	{ label: 'data & queues',  items: 'mongodb · redis · rabbitmq · varnish' },
	{ label: 'infrastructure', items: 'kubernetes · docker · nginx · linux' },
];

// The list arrives order-sorted: still-burning hobbies are the mantel,
// resting ones the graveyard. Tilts alternate so the headstones don't all
// lean the same way.
const hobbies = await getHobbies();
const learning = hobbies.filter((hobby) => hobby.kind === 'alive');
const resting = hobbies.filter((hobby) => hobby.kind !== 'alive');

const tilts = [-2, 1.5, -1, 2.2, -1.5, 1.8];
const graveyardChips = resting.map((hobby, index) => ({
	text: `${hobby.name} · ${hobby.disposition}`,
	tilt: tilts[index % tilts.length],
}));
---
<BaseLayout title="Justin Smith · argsea.com" active="hello" quipKey="quipHello">
	<!-- hero -->
	<section class="hero">
		<div class="firefly ff-1"></div>
		<div class="firefly ff-2"></div>
		<div class="firefly ff-3"></div>
		<div class="firefly ff-4"></div>
		<div class="postmark-circle">
			<div class="postmark-circle__text">PITTSBURGH<br />PA · EST 2014<br />ARGSEA.COM</div>
		</div>
		<div class="hero__copy">
			<div class="section-label fade-up fade-up--1">{copy.heroKicker}</div>
			<h1 class="hero__headline fade-up fade-up--2">{copy.heroHeadline}</h1>
			<p class="hero__body fade-up fade-up--3">{copy.heroBody}</p>
			<div class="hero__actions fade-up fade-up--4">
				<a href="/projects" class="btn btn--primary">the projects</a>
				<a href={`mailto:${keeper.email}`} class="btn btn--outline">say hi</a>
			</div>
		</div>
	</section>

	<WaveDivider projects={projects} proverbs={proverbs} />

	<!-- selected work: the flagship card, then up to two featured cards -->
	<section class="postcards">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Selected work</span>
				<span class="section-aside">lights I keep burning</span>
			</span>
			<a href="/projects" class="mono-link">the whole coast →</a>
		</div>
		<HomeLights client:load flagship={flagship} featured={featuredTwo} notes={allNotes} signoff={keeper.signoff} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} />
	</section>

	<JournalStrip notes={journalPreview} doodles={journalDoodles} />
	<JournalStripDirector client:idle notes={journalPreview} doodles={journalDoodles} projects={projects} signoff={keeper.signoff} />

	<!-- the keeper's stores: no destination page, so the section head carries no link -->
	<section class="stores">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Tools</span>
				<span class="section-aside">the keeper's stores, kept in the tower</span>
			</span>
		</div>
		<div class="stores__grid">
			{stores.map((column) => (
				<div class="stores__col">
					<span class="stores__label">{column.label}</span>
					<span class="stores__items">{column.items}</span>
				</div>
			))}
		</div>
	</section>

	<!-- hobbies preview: still-burning hobbies fill the mantel, resting ones the graveyard -->
	<section class="hobbies-preview">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Hobbies</span>
				<span class="section-aside">past and present, abridged</span>
			</span>
			<a href="/hobbies" class="mono-link">the full graveyard →</a>
		</div>
		<div class="hobbies-preview__grid">
			<div class="panel panel--learning">
				<span class="panel__label panel__label--gold">Currently learning</span>
				<div class="panel__rows">
					{learning.map((hobby) => (
						<div class="panel__row"><span class="panel__name">{hobby.name}</span><span class="panel__tags">{(hobby.tags ?? []).join(' · ')}</span></div>
					))}
				</div>
				<span class="panel__aside">One tweak from perfect, forever.</span>
			</div>
			<div class="panel panel--graveyard">
				<div class="grave-lantern" aria-hidden="true">
					<span class="grave-lantern__post"></span>
					<span class="grave-lantern__box"></span>
					<span class="grave-lantern__core"></span>
					<span class="grave-lantern__halo"></span>
				</div>
				<span class="panel__label">The hobby graveyard</span>
				<div class="panel__chips">
					{graveyardChips.map((chip) => (
						<span class="grave-chip" style={`--tilt:${chip.tilt}deg`}>{chip.text}</span>
					))}
				</div>
				<div class="grave-firefly grave-firefly--a" aria-hidden="true"><span class="grave-firefly__halo"></span><span class="grave-firefly__dot"></span></div>
				<div class="grave-firefly grave-firefly--b" aria-hidden="true"><span class="grave-firefly__halo"></span><span class="grave-firefly__dot"></span></div>
				<div class="grave-firefly grave-firefly--c" aria-hidden="true"><span class="grave-firefly__halo"></span><span class="grave-firefly__dot"></span></div>
				<span class="panel__aside panel__aside--dim">Nothing here is dead. It's just resting until the next season of me.</span>
			</div>
		</div>
		<div class="hobbies-preview__foot">
			<span class="mono-comment">// the graveyard only grows. that's fine.</span>
			<NextHobbyChip client:load values={suggestions.map((s) => s.value)} variant="headstone" />
		</div>
	</section>

	<!-- contact band -->
	<section class="contact">
		<LighthouseMark width={30} height={34} />
		<div class="contact__headline">Need a hand keeping your lights on?</div>
		<div class="contact__aside">Backend, architecture, planning, or just to talk shop.</div>
		<div class="contact__actions">
			<a href={`mailto:${keeper.email}`} class="btn btn--roomy btn--gold">say hi</a>
			<a href="/resume.pdf" class="btn btn--roomy btn--outline">resume ↗</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* --- hero --- */
	.hero {
		position: relative;
		padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 64px);
		overflow: hidden;
	}

	.ff-1 { right: 14%; top: 90px;  width: 5px; height: 5px; background: var(--gold);       box-shadow: 0 0 14px 4px rgba(240, 217, 168, .4);  animation: drift 11s ease-in-out infinite; }
	.ff-2 { right: 32%; top: 220px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .35); animation: drift 14s ease-in-out 2s infinite; }
	.ff-3 { right: 9%;  top: 320px; width: 4px; height: 4px; background: var(--gold);       box-shadow: 0 0 12px 3px rgba(240, 217, 168, .3);  animation: drift 9s ease-in-out 1s infinite; }
	.ff-4 { left: 8%; bottom: 60px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .3);  animation: drift 13s ease-in-out 3s infinite; }

	/* Resting tilt is a base transform: reduced-motion strips the sway, keeps the pose */
	.postmark-circle {
		position: absolute;
		right: clamp(24px, 6vw, 72px);
		top: 76px;
		width: 110px;
		height: 110px;
		border: 1.5px dashed rgba(147, 160, 232, .4);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: rotate(12deg);
		animation: postmarkSway 9s ease-in-out infinite;
	}

	.postmark-circle__text {
		text-align: center;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .14em;
		color: var(--periwinkle);
		line-height: 1.7;
	}

	@keyframes postmarkSway {
		0%, 100% { transform: rotate(9deg); }
		50%      { transform: rotate(15deg); }
	}

	@media (max-width: 760px) {
		.postmark-circle { display: none; }
	}

	.hero__copy {
		display: flex;
		flex-direction: column;
		gap: 24px;
		max-width: 720px;
	}

	.hero__headline {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(34px, 6.5vw, 58px);
		line-height: 1.1;
		color: var(--text-strong);
		text-wrap: balance;
	}

	.hero__body {
		margin: 0;
		font-size: clamp(17px, 2.4vw, 20px);
		line-height: 1.6;
		color: var(--text-body);
		font-weight: 300;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		align-items: center;
		margin-top: 4px;
	}

	/* --- postcards preview --- */
	.postcards {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	/* --- the keeper's stores --- */
	.stores {
		padding: 0 var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.stores__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 18px 28px;
	}

	.stores__col {
		display: flex;
		flex-direction: column;
		gap: 8px;
		border-top: 1px solid var(--border-card);
		padding-top: 12px;
	}

	.stores__label {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: .12em;
		color: var(--periwinkle-deep);
		text-transform: uppercase;
	}

	.stores__items {
		font-family: var(--font-mono);
		font-size: 13.5px;
		color: var(--text-soft);
		line-height: 1.8;
	}

	/* --- hobbies preview --- */
	.hobbies-preview {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(24px, 4vw, 32px);
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.hobbies-preview__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 22px;
		align-items: stretch;
	}

	.panel {
		padding: 24px 26px;
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		transition: transform .25s;
	}

	.panel:hover {
		transform: rotate(0deg);
	}

	.panel--learning {
		background: rgba(240, 217, 168, .06);
		border: 1.5px dashed rgba(240, 217, 168, .4);
		transform: rotate(-.3deg);
	}

	.panel--graveyard {
		position: relative;
		background: var(--card-alt);
		border: 1px solid rgba(150, 160, 220, .18);
		transform: rotate(.3deg);
	}

	.panel__label {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: .12em;
		color: var(--periwinkle);
		text-transform: uppercase;
	}

	.panel__label--gold {
		color: var(--gold);
	}

	.panel__rows {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.panel__row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.panel__name {
		font-family: var(--font-display);
		font-size: 20px;
		color: var(--text-strong);
	}

	.panel__tags {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--periwinkle);
	}

	.panel__aside {
		font-size: 14.5px;
		color: var(--text-body);
		font-style: italic;
	}

	.panel__aside--dim {
		color: var(--text-dim);
	}

	.panel__chips {
		display: flex;
		gap: 10px 9px;
		flex-wrap: wrap;
		align-items: flex-end;
	}

	/* Headstones: rounded tops over flat bottoms, a static per-chip tilt
	   pivoting from the ground, and a soft shadow pooled underneath. */
	.grave-chip {
		padding: 7px 14px 6px;
		border: 1px solid var(--border-chip);
		border-bottom-color: rgba(150, 160, 220, .16);
		border-radius: 11px 11px 2px 2px;
		font-family: var(--font-mono);
		font-size: 12.5px;
		color: var(--text-body);
		transform: rotate(var(--tilt));
		transform-origin: 50% 100%;
		box-shadow: 0 6px 6px -4px rgba(0, 0, 0, .55);
	}

	/* The keeper's lantern, watching over the graveyard from the card's corner */
	.grave-lantern__post {
		position: absolute;
		top: 14px;
		right: 18px;
		width: 3px;
		height: 26px;
		background: #2a2f52;
	}

	.grave-lantern__box {
		position: absolute;
		top: 8px;
		right: 15px;
		width: 9px;
		height: 10px;
		background: #141225;
		border: 1px solid rgba(240, 217, 168, .5);
		border-radius: 2px;
	}

	.grave-lantern__core {
		position: absolute;
		top: 10.5px;
		right: 17px;
		width: 5px;
		height: 5.5px;
		border-radius: 50%;
		background: var(--gold);
		box-shadow: 0 0 9px 2px rgba(240, 217, 168, .65);
		animation: lampPulse 6s ease-in-out infinite;
	}

	.grave-lantern__halo {
		position: absolute;
		top: -24px;
		right: -28px;
		width: 130px;
		height: 110px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(240, 196, 120, .15), transparent 62%);
		filter: blur(2px);
		animation: lampPulse 6s ease-in-out infinite;
		pointer-events: none;
	}

	@keyframes lampPulse {
		0%, 100% { opacity: .55; }
		50%      { opacity: 1; }
	}

	/* Three fireflies roaming the graveyard card; hidden outright under
	   reduced motion rather than left frozen mid-roam. */
	.grave-firefly {
		position: absolute;
		pointer-events: none;
		z-index: 2;
	}

	.grave-firefly--a { left: 20%; top: 54%; animation: fireflyRoam 11s ease-in-out infinite; }
	.grave-firefly--b { left: 58%; top: 36%; animation: fireflyRoam 14s ease-in-out -5s infinite reverse; }
	.grave-firefly--c { left: 74%; top: 66%; animation: fireflyRoam 9s ease-in-out -2s infinite; }

	.grave-firefly__halo {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 46px;
		height: 46px;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: radial-gradient(circle, rgba(240, 196, 120, .26), transparent 65%);
		filter: blur(2px);
		animation: lampPulse 3.2s ease-in-out infinite;
	}

	.grave-firefly__dot {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 3px;
		height: 3px;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: var(--gold);
		box-shadow: 0 0 6px 2px rgba(240, 217, 168, .55);
		animation: lampPulse 3.2s ease-in-out infinite;
	}

	@keyframes fireflyRoam {
		0%, 100% { translate: 0 0; }
		18%      { translate: 34px -18px; }
		38%      { translate: 9px -40px; }
		55%      { translate: -28px -14px; }
		72%      { translate: -44px 10px; }
		86%      { translate: -12px 20px; }
	}

	@media (prefers-reduced-motion: reduce) {
		.grave-firefly {
			display: none;
		}
	}

	.hobbies-preview__foot {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	/* --- contact band --- */
	.contact {
		padding: clamp(40px, 7vw, 72px) var(--gutter) clamp(28px, 5vw, 48px);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 18px;
		text-align: center;
	}

	.contact__headline {
		font-family: var(--font-display);
		font-size: clamp(24px, 4.5vw, 34px);
		color: var(--text-strong);
		max-width: 560px;
		line-height: 1.2;
		text-wrap: balance;
	}

	.contact__aside {
		font-size: 17px;
		color: var(--text-body);
		font-style: italic;
		max-width: 460px;
	}

	.contact__actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 4px;
	}
</style>
