---
// Hello — hero, wave-with-boat, postcards preview, cargo manifest, hobbies
// preview, contact band, and the dictionary entry. The postcards preview is
// the mantel: the featured projects, or the first three by order so the
// section never empties. It opens the postcard-back overlay in place; hero
// copy and the dictionary come from the SiteCopy singleton; the say-hi email
// is the keeper's; the cargo manifest is approved copy hardcoded by design. The
// hobbies preview is data-driven: active hobbies fill "currently learning",
// resting ones become graveyard chips.
import BaseLayout from '../layouts/BaseLayout.astro';
import LighthouseMark from '../components/LighthouseMark.astro';
import WaveDivider from '../components/WaveDivider.astro';
import HomePostcards from '../components/islands/HomePostcards';
import { getProjects, getSiteCopy, getKeeperProfile, getHobbies } from '../lib/api';

const projects = await getProjects();
// The list arrives order-sorted; the cap is defensive — the admin owns the
// mantel-fits-three rule, the site just refuses to overflow it
const featured = projects.filter((project) => project.featured);
const preview = (featured.length > 0 ? featured : projects).slice(0, 3);
const copy = await getSiteCopy();
const keeper = await getKeeperProfile();

// The smuggler's hold: the copy singleton's egg toggles gate what gets wired.
// Bottle off (or an emptied proverb list) leaves the boat sailing, unpokeable.
// The cat's per-page/per-spot picking lives client-side (the director + the
// overlay islands share one pick); the frontmatter just forwards the toggles.
const proverbs = copy.eggs.bottle ? copy.bottleProverbs : [];

// Dictionary presentation: the copy is one plain-text string; the numbered
// sense markers ("1." …) get the periwinkle-deep treatment from the design.
const dictSegments = copy.dict
	.split(/(\d+\.)(?=\s)/)
	.map((text) => ({ text, isMarker: /^\d+\.$/.test(text) }));

const manifest = [
	{ label: 'languages',      items: 'java · python · node.js · go · php' },
	{ label: 'data & queues',  items: 'mongodb · redis · rabbitmq · varnish' },
	{ label: 'infrastructure', items: 'kubernetes · docker · nginx · linux' },
];

// The list arrives order-sorted: active hobbies are the mantel, resting ones
// the graveyard. Sways cycle through hand-tuned timings so the chips don't beat
// in unison.
const hobbies = await getHobbies();
const learning = hobbies.filter((hobby) => hobby.active);
const resting = hobbies.filter((hobby) => !hobby.active);

const sways = [
	'swayChip 5s ease-in-out infinite',
	'swayChip 6s ease-in-out 1s infinite',
	'swayChip 5.5s ease-in-out .5s infinite',
	'swayChip 6.5s ease-in-out 1.5s infinite',
];
const graveyardChips = resting.map((hobby, index) => ({
	text: `${hobby.name} ${hobby.epitaph}`.trim(),
	sway: sways[index % sways.length],
}));
---
<BaseLayout title="Justin Smith · argsea.com" active="hello" quipKey="quipHello">
	<!-- hero -->
	<section class="hero">
		<div class="firefly ff-1"></div>
		<div class="firefly ff-2"></div>
		<div class="firefly ff-3"></div>
		<div class="firefly ff-4"></div>
		<div class="postmark-circle">
			<div class="postmark-circle__text">PITTSBURGH<br />PA · EST 2014<br />ARGSEA.COM</div>
		</div>
		<div class="hero__copy">
			<div class="section-label fade-up fade-up--1">{copy.heroKicker}</div>
			<h1 class="hero__headline fade-up fade-up--2">{copy.heroHeadline}</h1>
			<p class="hero__body fade-up fade-up--3">{copy.heroBody}</p>
			<div class="hero__actions fade-up fade-up--4">
				<a href="/projects" class="btn btn--primary">the projects</a>
				<a href={`mailto:${keeper.email}`} class="btn btn--outline">say hi</a>
			</div>
		</div>
	</section>

	<WaveDivider proverbs={proverbs} />

	<!-- postcards from production -->
	<section class="postcards">
		<div class="row-head">
			<span class="section-label">Postcards from production</span>
			<a href="/projects" class="mono-link">all projects →</a>
		</div>
		<HomePostcards client:load projects={preview} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} />
	</section>

	<!-- the cargo manifest -->
	<section class="manifest">
		<div class="manifest__head">
			<span class="section-label">The cargo manifest</span>
			<span class="manifest__aside">tools currently aboard</span>
		</div>
		<div class="manifest__grid">
			{manifest.map((column) => (
				<div class="manifest__col">
					<span class="manifest__label">{column.label}</span>
					<span class="manifest__items">{column.items}</span>
				</div>
			))}
		</div>
	</section>

	<!-- hobbies preview: active hobbies fill the mantel, resting ones the graveyard -->
	<section class="hobbies-preview">
		<div class="row-head">
			<span class="section-label">Hobbies, past & present</span>
			<a href="/hobbies" class="mono-link">the full graveyard →</a>
		</div>
		<div class="hobbies-preview__grid">
			<div class="panel panel--learning">
				<span class="panel__label panel__label--gold">Currently learning</span>
				<div class="panel__rows">
					{learning.map((hobby) => (
						<div class="panel__row"><span class="panel__name">{hobby.name}</span><span class="panel__tags">{(hobby.tags ?? []).join(' · ')}</span></div>
					))}
				</div>
				<span class="panel__aside">One tweak from perfect, forever.</span>
			</div>
			<div class="panel panel--graveyard">
				<span class="panel__label">The hobby graveyard</span>
				<div class="panel__chips">
					{graveyardChips.map((chip) => (
						<span class="grave-chip" style={`animation:${chip.sway}`}>{chip.text}</span>
					))}
				</div>
				<span class="panel__aside panel__aside--dim">Nothing here is dead. It's just resting until the next season of me.</span>
			</div>
		</div>
		<div class="mono-comment">// the graveyard only grows. that's fine.</div>
	</section>

	<!-- contact band -->
	<section class="contact">
		<LighthouseMark width={30} height={34} />
		<div class="contact__headline">Need a hand keeping your lights on?</div>
		<div class="contact__aside">Backend, architecture, planning — or just to talk shop.</div>
		<div class="contact__actions">
			<a href={`mailto:${keeper.email}`} class="btn btn--roomy btn--gold">say hi</a>
			<a href="/resume.pdf" class="btn btn--roomy btn--outline">resume ↗</a>
		</div>
	</section>

	<!-- the name, explained -->
	<section class="dictionary">
		<div class="dictionary__entry">
			<div class="dictionary__head">
				<span class="dictionary__word">argsea</span>
				<span class="dictionary__pron">/ˈɑːrɡ·siː/ · noun</span>
			</div>
			<div class="dictionary__defs">
				{dictSegments.map((segment) => segment.isMarker ? <span class="num">{segment.text}</span> : segment.text)}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* --- hero --- */
	.hero {
		position: relative;
		padding: clamp(56px, 9vw, 96px) var(--gutter) clamp(40px, 6vw, 64px);
		overflow: hidden;
	}

	.ff-1 { right: 14%; top: 90px;  width: 5px; height: 5px; background: var(--gold);       box-shadow: 0 0 14px 4px rgba(240, 217, 168, .4);  animation: drift 11s ease-in-out infinite; }
	.ff-2 { right: 32%; top: 220px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .35); animation: drift 14s ease-in-out 2s infinite; }
	.ff-3 { right: 9%;  top: 320px; width: 4px; height: 4px; background: var(--gold);       box-shadow: 0 0 12px 3px rgba(240, 217, 168, .3);  animation: drift 9s ease-in-out 1s infinite; }
	.ff-4 { left: 8%; bottom: 60px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .3);  animation: drift 13s ease-in-out 3s infinite; }

	/* Resting tilt is a base transform: reduced-motion strips the sway, keeps the pose */
	.postmark-circle {
		position: absolute;
		right: clamp(24px, 6vw, 72px);
		top: 76px;
		width: 110px;
		height: 110px;
		border: 1.5px dashed rgba(147, 160, 232, .4);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: rotate(12deg);
		animation: postmarkSway 9s ease-in-out infinite;
	}

	.postmark-circle__text {
		text-align: center;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .14em;
		color: var(--periwinkle);
		line-height: 1.7;
	}

	@keyframes postmarkSway {
		0%, 100% { transform: rotate(9deg); }
		50%      { transform: rotate(15deg); }
	}

	@media (max-width: 760px) {
		.postmark-circle { display: none; }
	}

	.hero__copy {
		display: flex;
		flex-direction: column;
		gap: 24px;
		max-width: 720px;
	}

	.hero__headline {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(34px, 6.5vw, 58px);
		line-height: 1.1;
		color: var(--text-strong);
		text-wrap: balance;
	}

	.hero__body {
		margin: 0;
		font-size: clamp(17px, 2.4vw, 20px);
		line-height: 1.6;
		color: var(--text-body);
		font-weight: 300;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		align-items: center;
		margin-top: 4px;
	}

	/* --- shared section head row --- */
	.row-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 8px;
	}

	/* --- postcards preview --- */
	.postcards {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	/* --- cargo manifest --- */
	.manifest {
		padding: 0 var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.manifest__head {
		display: flex;
		align-items: baseline;
		gap: 14px;
		flex-wrap: wrap;
	}

	.manifest__aside {
		font-size: 15px;
		color: var(--periwinkle-deep);
		font-style: italic;
	}

	.manifest__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 18px 28px;
	}

	.manifest__col {
		display: flex;
		flex-direction: column;
		gap: 8px;
		border-top: 1px solid var(--border-card);
		padding-top: 12px;
	}

	.manifest__label {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: .12em;
		color: var(--periwinkle-deep);
		text-transform: uppercase;
	}

	.manifest__items {
		font-family: var(--font-mono);
		font-size: 13.5px;
		color: var(--text-soft);
		line-height: 1.8;
	}

	/* --- hobbies preview --- */
	.hobbies-preview {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(24px, 4vw, 32px);
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.hobbies-preview__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 22px;
		align-items: stretch;
	}

	.panel {
		padding: 24px 26px;
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		transition: transform .25s;
	}

	.panel:hover {
		transform: rotate(0deg);
	}

	.panel--learning {
		background: rgba(240, 217, 168, .06);
		border: 1.5px dashed rgba(240, 217, 168, .4);
		transform: rotate(-.3deg);
	}

	.panel--graveyard {
		background: var(--card-alt);
		border: 1px solid rgba(150, 160, 220, .18);
		transform: rotate(.3deg);
	}

	.panel__label {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: .12em;
		color: var(--periwinkle);
		text-transform: uppercase;
	}

	.panel__label--gold {
		color: var(--gold);
	}

	.panel__rows {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.panel__row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.panel__name {
		font-family: var(--font-display);
		font-size: 20px;
		color: var(--text-strong);
	}

	.panel__tags {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--periwinkle);
	}

	.panel__aside {
		font-size: 14.5px;
		color: var(--text-body);
		font-style: italic;
	}

	.panel__aside--dim {
		color: var(--text-dim);
	}

	.panel__chips {
		display: flex;
		gap: 9px;
		flex-wrap: wrap;
	}

	.grave-chip {
		padding: 6px 14px;
		border: 1px solid var(--border-chip);
		border-radius: 999px;
		font-family: var(--font-mono);
		font-size: 12.5px;
		color: var(--text-body);
	}

	/* --- contact band --- */
	.contact {
		padding: clamp(40px, 7vw, 72px) var(--gutter) clamp(28px, 5vw, 48px);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 18px;
		text-align: center;
	}

	.contact__headline {
		font-family: var(--font-display);
		font-size: clamp(24px, 4.5vw, 34px);
		color: var(--text-strong);
		max-width: 560px;
		line-height: 1.2;
		text-wrap: balance;
	}

	.contact__aside {
		font-size: 17px;
		color: var(--text-body);
		font-style: italic;
		max-width: 460px;
	}

	.contact__actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 4px;
	}

	/* --- dictionary entry --- */
	.dictionary {
		display: flex;
		justify-content: center;
		padding: 0 var(--gutter) clamp(28px, 5vw, 44px);
	}

	.dictionary__entry {
		max-width: 520px;
		border-top: 1px solid rgba(150, 160, 220, .18);
		padding-top: 24px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.dictionary__head {
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
	}

	.dictionary__word {
		font-family: var(--font-display);
		font-size: 22px;
		color: var(--text-strong);
	}

	.dictionary__pron {
		font-family: var(--font-mono);
		font-size: 12.5px;
		color: var(--periwinkle-deep);
	}

	.dictionary__defs {
		font-size: 15.5px;
		line-height: 1.7;
		color: var(--text-body);
	}

	.dictionary__defs .num {
		color: var(--periwinkle-deep);
	}
</style>
