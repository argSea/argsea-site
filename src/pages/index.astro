---
// Hello: the keeper's landing (design/Hello.dc.html, the banked canon). The
// hero fuses the eyebrow/headline with the "now" panel off the current watch
// (an empty watch collapses the panel, never the headline, same plumbing as
// this page always used); three flagship rows (the flagship flag first, then
// the next two by order); the journal's newest three as feature cards; the
// wandering chart's two highest gauges and its lowest, worn behind the skills
// gag until it clicks over; and the sea footer's tug, bottles, and gull post
// send-off. Sections the old watch/register page carried that this canon
// dropped (the coast strip, the light-list register, the season print rack)
// stay dropped: this is a from-scratch rebuild of the page, not a patch.
import BaseLayout from '../layouts/BaseLayout.astro';
import BottleBoat from '../components/islands/BottleBoat';
import LightBadge from '../components/islands/LightBadge';
import { getProjects, getSiteCopy, getKeeperProfile, getHobbies, getNotes, getDoodles, getCarvings, getWatch, type Hobby, type HobbyState } from '../lib/api';
import { boltedSvg, innerMarkup } from '../lib/carvings';
import { codeFor, registryNo, DEFAULT_LIGHT } from '../lib/lightChar';
import { mediaUrl } from '../lib/media';

const projects = await getProjects();
const allNotes = await getNotes();
const copy = await getSiteCopy();
const keeper = await getKeeperProfile();
const hobbies = await getHobbies();
const doodles = await getDoodles();
const watch = await getWatch();
const carvings = await getCarvings();

const heroDoodleSvg = boltedSvg('hero-doodle', carvings);
const mooredLampSvg = boltedSvg('moored-lamp', carvings);
const adriftBoatSvg = boltedSvg('adrift-boat', carvings);
const maroonedPalmSvg = boltedSvg('marooned-palm', carvings);
const portAnchorSvg = boltedSvg('port-anchor', carvings);
const boatSvg = boltedSvg('boat', carvings);
const bottleSvg = boltedSvg('bottle', carvings);

// --- the current watch: the same plumbing this page has always read (an
// empty letter is the wire's "no watch kept", so the panel collapses; the
// headline above it never does).
const watchKept = watch.letter !== '';
const watchParagraphs = watch.letter.split(/\n\s*\n/).map((block) => block.trim()).filter((block) => block !== '');
const MONTHS = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
const keptAt = new Date(watch.keptAt);
const keptValid = !Number.isNaN(keptAt.getTime());
const keptLine = keptValid ? `kept ${keptAt.getUTCDate()} ${MONTHS[keptAt.getUTCMonth()]}` : '';

// A bearing's destination by kind: a light steers into its full log when one
// is lit (else the coast at large), a hobby to the chart, a note to the
// journal; kind "none" stays plain text, never a link. Same rule this page
// has always used for the watch's bearings.
const bearingHref = (bearing: (typeof watch.bearings)[number]): string | null => {
	if ('light' === bearing.kind) {
		const light = projects.find((project) => project.id === bearing.targetId);
		return light?.hasLog ? `/projects/${light.slug}` : '/projects';
	}
	if ('hobby' === bearing.kind) {
		return '/hobbies';
	}
	if ('note' === bearing.kind) {
		return '/notes';
	}
	return null;
};
const chips = watch.bearings.map((bearing) => ({ verb: bearing.verb, name: bearing.name, href: bearingHref(bearing) }));

// --- 01 Projects: the flagship flag floats first (a stable sort keeps every
// other light in its already-order-sorted place), the next two ride along;
// no. numbering is the site's real registry number, not the row's own index,
// so a light keeps the same no. everywhere it appears.
const flags = [...projects]
	.sort((a, b) => (b.flagship ? 1 : 0) - (a.flagship ? 1 : 0))
	.slice(0, 3)
	.map((project, index) => {
		const light = project.light ?? DEFAULT_LIGHT;
		const photo = project.images && project.images.length > 0 ? project.images[0] : project.image;
		return {
			project,
			no:    registryNo(project.order),
			flip:  index % 2 === 1,
			light,
			char:  codeFor(light),
			photo,
			log:   project.hasLog ? `/projects/${project.slug}` : '/projects',
			facts: project.facts ?? [],
		};
	});

// --- 02 Notes: the journal's newest three, each with its doodle resolved by
// id (doodleCaption is always "" when there's no doodle, so it never shows
// detached from one).
const journal = allNotes.slice(0, 3).map((note) => ({
	note,
	doodle: note.doodleId ? doodles.find((doodle) => doodle.id === note.doodleId) ?? null : null,
}));

// --- 03 Hobbies, worn behind the skills gag: two highest gauges, then the
// lowest. high, high, flat on my face. A build against an API where nothing
// carries a gauge yet must not show an empty grid under an orphaned "Skills"
// head, so the whole section (gag included) stands down when nothing's picked.
const STATE_LABEL: Record<HobbyState, string> = {
	moored:   'moored',
	adrift:   'adrift',
	marooned: 'marooned',
	port:     'made port',
	inkspill: 'bearing smudged',
};

function verdictFor(gauge: number): string {
	if (gauge >= 90) return 'As good as it gets, according to me.';
	if (gauge >= 80) return 'Peaked. Retired undefeated.';
	if (gauge >= 60) return 'Respectable, if nobody watches too closely.';
	if (gauge >= 40) return 'Enthusiasm outlived the follow-through.';
	if (gauge >= 20) return 'The spirit was willing.';
	return 'The shoes remain.';
}

const gaugedHobbies = hobbies
	.filter((hobby): hobby is Hobby & { gauge: number } => hobby.gauge != null)
	.sort((a, b) => b.gauge - a.gauge);
const pickedHobbies = gaugedHobbies.slice(0, 2);
if (gaugedHobbies.length > 2) {
	pickedHobbies.push(gaugedHobbies[gaugedHobbies.length - 1]);
}
const hasGaugedHobbies = pickedHobbies.length > 0;
const gaugeCards = pickedHobbies.map((hobby, index) => ({
	hobby,
	verdict:    verdictFor(hobby.gauge),
	delay:      `${(index * 0.12).toFixed(2)}s`,
	stateLabel: STATE_LABEL[hobby.state],
	href:       `/hobbies?bearing=${encodeURIComponent(hobby.name)}`,
}));

// --- the sea footer's tug: the keeper's stores drawers become the manifest's
// barges (each drawer's tools its crates), ≤3 to match the tug's own rig; an
// empty bench (no drawers shelved yet) falls back to the canon's own manifest.
const DEFAULT_BARGES: string[][] = [
	['rust', 'python', 'typescript'],
	['linux', 'docker', 'kubernetes'],
	['postgres'],
];
const barges = copy.stores && copy.stores.length > 0
	? copy.stores.slice(0, 3).map((drawer) => drawer.tools ?? [])
	: DEFAULT_BARGES;

// The smuggler's cove: the copy singleton's egg toggles gate what gets wired.
// An emptied proverb list (or the egg off) leaves the sea quiet.
const proverbs = copy.eggs.bottle ? copy.bottleProverbs : [];

const withScheme = (link: string) => /^https?:\/\//.test(link) ? link : `https://${link}`;

// The chart ambience's soundings: some of the depths on the paper are real
// project years, if you look. Passed to the page script build-time (there is
// no async ARGSEA_DATA to poll for here).
const chartYears = projects.map((project) => project.firstLit);
---
<BaseLayout title="Justin Smith · home waters" active="hello" quipKey="quipHello">
	<canvas id="window-scape" aria-hidden="true" data-years={JSON.stringify(chartYears)}></canvas>
	<a class="gull-mark" id="gull-mark" href="/gazette" aria-label="a passing gull with news" style="left:-120px;top:-120px">
		<svg width="38" height="26" viewBox="0 0 38 26" fill="none" aria-hidden="true">
			<path d="M3 14 Q10 6 19 12 Q28 6 35 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"></path>
			<path d="M14 20 q5 -3 10 0" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity=".5" fill="none"></path>
		</svg>
		<span>the gull post</span>
	</a>

	<div class="wrap">
		<!-- ================= hero: the letter fused with the current watch ================= -->
		<section class:list={['hero', { 'hero--watch': watchKept }]}>
			<div>
				<div class="role rv" style="margin-top:0">{copy.heroKicker}</div>
				<h1 class="rv" style="--d:.08s">{copy.heroHeadline}</h1>
				<p class="pitch rv" style="--d:.16s">{copy.heroBody}</p>
				<div class="doors rv" style="--d:.24s">
					<a href="/resume.pdf">resume ↗</a>
					<a href={`mailto:${keeper.email}`}>say hello</a>
					<a href="/helm">set sail</a>
				</div>
			</div>

			{watchKept && (
				<aside class="now rv" style="--d:.2s">
					<!-- carving spot: hero-doodle -->
					<svg class="doodle" data-carving="hero-doodle" width="72" height="86" viewBox="0 0 72 86" fill="none" aria-hidden="true" style="top:-77px" data-bolted={heroDoodleSvg ? 'hero-doodle' : undefined}>
						{heroDoodleSvg ? (
							<Fragment set:html={innerMarkup(heroDoodleSvg)} />
						) : (
							<>
								<path d="M28 78 C29 60 30 42 31 30 L41 30 C42 44 43 60 44 78" stroke="#93a0e8" stroke-width="1.6" stroke-linecap="round"></path>
								<path d="M29 44 L43 43 M28.5 58 L43.5 57" stroke="#93a0e8" stroke-width="1.4" stroke-linecap="round"></path>
								<path d="M31 30 L29 22 L43 22 L41 30" stroke="#93a0e8" stroke-width="1.6" stroke-linejoin="round"></path>
								<path d="M31 22 L36 13 L41 22" stroke="#93a0e8" stroke-width="1.6" stroke-linejoin="round"></path>
								<circle cx="36" cy="20" r="2.6" fill="var(--lamp)" style="animation:morseHi 4s linear infinite"></circle>
								<path d="M14 80 Q36 72 58 80" stroke="#5f6ec4" stroke-width="1.6" stroke-linecap="round"></path>
								<path d="M8 16 L20 20 M64 16 L52 20" stroke="var(--lamp)" stroke-width="1.2" stroke-linecap="round" opacity=".5" style="animation:morseHi 4s linear infinite"></path>
							</>
						)}
					</svg>
					<div class="now-head">
						<span class="tick">Now · the current watch</span>
						{keptLine && <span class="kept">{keptLine}</span>}
					</div>
					<div class="letter">
						{watchParagraphs.map((paragraph) => <p>{paragraph}</p>)}
						{keeper.signoff && <p class="sig">{keeper.signoff}</p>}
						{watch.rotation && <p class="aband">{watch.rotation}</p>}
					</div>
					{chips.length > 0 && (
						<div class="chips">
							{chips.map((chip, index) => (
								<Fragment>
									{index > 0 && ' · '}
									{chip.verb}{' '}
									{chip.href ? <a href={chip.href}><b>{chip.name}</b></a> : <b>{chip.name}</b>}
								</Fragment>
							))}
						</div>
					)}
				</aside>
			)}
		</section>

		<!-- ================= 01 Projects: the flagship rows ================= -->
		{flags.length > 0 && (
			<section class="sec">
				<div class="sec-head rv"><span class="tick">01</span><h2>Projects</h2><span class="rule"></span></div>

				{flags.map((flag) => (
					<div class:list={['flagship', 'rv', { flip: flag.flip }]}>
						<a class:list={['shot', { 'shot--empty': !flag.photo }]} href={flag.log} aria-label={flag.project.title}>
							{/* a print that 404s hides itself and marks the frame empty, same "show empty paper, not a broken glyph" rule the register/overlay/case-study prints already follow */}
							{flag.photo && <img src={mediaUrl(flag.photo)} alt={flag.project.title} loading="lazy" onerror="this.closest('.shot').classList.add('shot--empty');this.remove()" />}
							<span class="archive">from the station archive · no. {flag.no}</span>
						</a>
						<div class="info">
							<span class="fl-facts"><LightBadge client:visible light={flag.light} />no. {flag.no} · {flag.char} · est. {flag.project.firstLit}</span>
							<b>{flag.project.title.toLowerCase()}</b>
							<div class="fbox">
								<p>{flag.project.shortDesc}</p>
								{flag.facts.length > 0 && (
									<dl class="facts">
										{flag.facts.map((fact) => (
											<div class="frow"><dt>{fact.heading}</dt><dd>{fact.fact}</dd></div>
										))}
									</dl>
								)}
								{flag.project.moral && <p class="moral">{flag.project.moral}</p>}
								<span class="tags">{flag.project.tags.map((tag) => <i>{tag}</i>)}</span>
							</div>
							<a class="fulllog" href={flag.log}>read the full log →</a>
						</div>
					</div>
				))}
			</section>
		)}

		<!-- ================= 02 Notes: the journal's newest three ================= -->
		{journal.length > 0 && (
			<section class="sec">
				<div class="sec-head rv"><span class="tick">02</span><h2>Notes</h2><span class="rule"></span></div>
				{journal.map(({ note, doodle }) => (
					<a class="feat rv" href="/notes">
						<div class="feat-main">
							<span class="feat-kick">from the journal · {note.conditions}</span>
							<b>{note.title}</b>
							<p>{note.teaser}</p>
							<span class="feat-foot">read the entry →</span>
						</div>
						{doodle && (
							<div class="feat-doodle">
								<svg width="90" height="90" viewBox={doodle.viewBox} fill="none">
									{doodle.shapes.map((shape) => (
										shape.type === 'path' ? (
											<path d={shape.d} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={shape.linecap as 'butt' | 'round' | 'square' | 'inherit' | undefined} stroke-linejoin={shape.linejoin as 'miter' | 'round' | 'bevel' | 'inherit' | undefined} />
										) : shape.type === 'ellipse' ? (
											<ellipse cx={shape.cx} cy={shape.cy} rx={shape.rx} ry={shape.ry} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} />
										) : shape.type === 'rect' ? (
											<rect x={shape.x} y={shape.y} width={shape.w} height={shape.h} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} />
										) : (
											<line x1={shape.x1} y1={shape.y1} x2={shape.x2} y2={shape.y2} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={shape.linecap as 'butt' | 'round' | 'square' | 'inherit' | undefined} />
										)
									))}
								</svg>
								{note.doodleCaption && <span class="cap">{note.doodleCaption}</span>}
							</div>
						)}
					</a>
				))}
			</section>
		)}

		<!-- ================= 03 Hobbies: worn behind the skills gag ================= -->
		{hasGaugedHobbies && (
			<section class="sec">
				<div class="sec-head rv"><span class="tick">03</span><h2 id="hobby-title">Skills</h2><span class="rule"></span></div>
				<!-- the fake skills live in a template so crawlers and parsers only ever read the truth -->
				<template id="skills-fake-tpl">
					<div class="gauge in"><span class="gtop"><b>javascript</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:95%"></span></span><span class="gmeta"><span>10+ years</span><span class="gnum-fake">95%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>react</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:92%"></span></span><span class="gmeta"><span>8 years</span><span class="gnum-fake">92%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>typescript</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:93%"></span></span><span class="gmeta"><span>7 years</span><span class="gnum-fake">93%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>node.js</b><span class="gstate">Advanced</span></span><span class="gbar"><span class="gfill" style="width:90%"></span></span><span class="gmeta"><span>9 years</span><span class="gnum-fake">90%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>python</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:94%"></span></span><span class="gmeta"><span>10+ years</span><span class="gnum-fake">94%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>aws</b><span class="gstate">Advanced</span></span><span class="gbar"><span class="gfill" style="width:88%"></span></span><span class="gmeta"><span>6 years</span><span class="gnum-fake">88%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>docker</b><span class="gstate">Advanced</span></span><span class="gbar"><span class="gfill" style="width:91%"></span></span><span class="gmeta"><span>7 years</span><span class="gnum-fake">91%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>kubernetes</b><span class="gstate">Advanced</span></span><span class="gbar"><span class="gfill" style="width:87%"></span></span><span class="gmeta"><span>5 years</span><span class="gnum-fake">87%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>ci/cd</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:92%"></span></span><span class="gmeta"><span>8 years</span><span class="gnum-fake">92%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>agile methodologies</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:97%"></span></span><span class="gmeta"><span>10+ years</span><span class="gnum-fake">97%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>communication</b><span class="gstate">Expert</span></span><span class="gbar"><span class="gfill" style="width:98%"></span></span><span class="gmeta"><span>lifelong</span><span class="gnum-fake">98%</span></span></div>
					<div class="gauge in"><span class="gtop"><b>synergy</b><span class="gstate">Thought Leader</span></span><span class="gbar"><span class="gfill" style="width:99%"></span></span><span class="gmeta"><span>unbroken</span><span class="gnum-fake">99%</span></span></div>
				</template>
				<div class="skills-fake gauges" id="skills-fake" aria-hidden="true"></div>
				<div class="hobbies-real" id="hobbies-real" style="display:none">
					<p class="shore-note">Measured in enthusiasm, not competence. Self-assessed. Suspiciously precise.</p>
					<div class="gauges">
						{gaugeCards.map((card) => (
							<a class="gauge rv" href={card.href}>
								<span class="gmark" aria-hidden="true">
									{'moored' === card.hobby.state && (
										<span class="mk">
											<svg width="26" height="30" viewBox="0 0 26 30" fill="none" data-bolted={mooredLampSvg ? 'moored-lamp' : undefined}>
												{mooredLampSvg ? (
													<Fragment set:html={innerMarkup(mooredLampSvg)} />
												) : (
													<>
														<path d="M13 2 L17 9 L9 9 Z" fill="#f0d9a8" style="animation:lampPulse 4s ease-in-out infinite"></path>
														<rect x="10" y="9" width="6" height="14" fill="none" stroke="#93a0e8" stroke-width="1.4"></rect>
														<path d="M10 13 h6 M10 17 h6" stroke="#93a0e8" stroke-width="1.4"></path>
													</>
												)}
											</svg>
											<span class="isle"></span>
										</span>
									)}
									{'adrift' === card.hobby.state && (
										<span class="mk">
											<svg width="34" height="28" viewBox="0 0 30 24" fill="none" style="animation:boatDrift 5s ease-in-out infinite" data-bolted={adriftBoatSvg ? 'adrift-boat' : undefined}>
												{adriftBoatSvg ? (
													<Fragment set:html={innerMarkup(adriftBoatSvg)} />
												) : (
													<>
														<path d="M4 15 L26 15 L21 22 L9 22 Z" fill="#93a0e8"></path>
														<path d="M15 15 V3" stroke="#5f6ec4" stroke-width="1.5"></path>
														<path d="M15 3 L24 13 L15 13 Z" fill="#f0d9a8"></path>
													</>
												)}
											</svg>
										</span>
									)}
									{'marooned' === card.hobby.state && (
										<span class="mk">
											<svg width="30" height="30" viewBox="0 0 30 30" fill="none" style="position:absolute;left:2px;bottom:6px;transform-origin:14px 26px;animation:palmSway 6s ease-in-out infinite" data-bolted={maroonedPalmSvg ? 'marooned-palm' : undefined}>
												{maroonedPalmSvg ? (
													<Fragment set:html={innerMarkup(maroonedPalmSvg)} />
												) : (
													<>
														<path d="M14 28 q-2 -12 1 -20" stroke="#8a7142" stroke-width="2" fill="none" stroke-linecap="round"></path>
														<path d="M15 8 q-8 -3 -13 1 M15 8 q8 -3 13 1 M15 8 q-5 -6 -12 -6 M15 8 q5 -6 12 -6" stroke="#5f8a5f" stroke-width="1.8" fill="none" stroke-linecap="round"></path>
													</>
												)}
											</svg>
											<span class="sand"></span>
										</span>
									)}
									{'port' === card.hobby.state && (
										<span class="mk">
											<span class="pen p1"></span>
											<span class="pen p2"></span>
											<svg width="26" height="30" viewBox="0 0 26 30" fill="none" data-bolted={portAnchorSvg ? 'port-anchor' : undefined}>
												{portAnchorSvg ? (
													<Fragment set:html={innerMarkup(portAnchorSvg)} />
												) : (
													<>
														<circle cx="13" cy="5" r="3" stroke="#93a0e8" stroke-width="1.6"></circle>
														<path d="M13 8 V26" stroke="#93a0e8" stroke-width="1.6"></path>
														<path d="M6 15 H20" stroke="#93a0e8" stroke-width="1.6"></path>
														<path d="M5 22 q8 7 16 0" stroke="#93a0e8" stroke-width="1.6" fill="none" stroke-linecap="round"></path>
													</>
												)}
											</svg>
										</span>
									)}
									{'inkspill' === card.hobby.state && (
										<span class="mk ink">
											<span class="b1"></span>
											<span class="b2"></span>
											<span class="b3"></span>
											<span class="x">✕</span>
										</span>
									)}
								</span>
								<span class="gtop"><b>{card.hobby.name.toLowerCase()}</b><span class="gstate">{card.stateLabel}</span></span>
								<span class="gbar"><span class="gfill" style={`width:${card.hobby.gauge}%;transition-delay:${card.delay};animation-delay:${card.delay}`}></span></span>
								<span class="gmeta"><span>{card.hobby.service}</span><span class="gnum" data-target={card.hobby.gauge}>0%</span></span>
								<span class="gword"><span class="verdict">{card.verdict}</span><span class="glog">{card.hobby.lastLog}</span></span>
							</a>
						))}
					</div>
				</div>
			</section>
		)}
	</div>

	<!-- ================= the footer is the sea ================= -->
	<footer class="sea-footer">
		<div class="berth">
			<div class="cta-kick rv">signal the tower</div>
			<div class="big rv" style="--d:.06s">The lamp is <em>lit</em>.<br>Come in from the dark.</div>
			<p class="cta-sub rv" style="--d:.12s">Work, questions, or just a wave from a passing ship. I read everything that reaches the tower.</p>
			<div class="cta-doors rv" style="--d:.18s">
				<a class="primary" href={`mailto:${keeper.email}`}>say hello →</a>
				<a class="ghost" href="/projects">see the work first</a>
			</div>
			<div class="cta-aside rv" style="--d:.24s">or write direct: <a href={`mailto:${keeper.email}`}>{keeper.email}</a></div>
			<div class="row rv" style="--d:.28s">
				<a href="/">hello</a><a href="/projects">projects</a><a href="/hobbies">hobbies</a>
				<a href="/notes">notes</a><a href="/resume.pdf">resume ↗</a>
				{keeper.github && <a href={withScheme(keeper.github)}>github</a>}
				{keeper.linkedin && <a href={withScheme(keeper.linkedin)}>linkedin</a>}
			</div>
			<div class="colo rv" style="--d:.32s">© 2026 · built on the night watch · all well</div>
		</div>

		<div class="sea" id="sea">
			<div class="swell back">
				<svg viewBox="0 0 900 80" preserveAspectRatio="none" aria-hidden="true"><path d="M0 40 Q75 22 150 40 T300 40 T450 40 T600 40 T750 40 T900 40 L900 80 L0 80 Z" fill="#1f2446"></path><path d="M0 40 Q75 22 150 40 T300 40 T450 40 T600 40 T750 40 T900 40" stroke="rgba(223,232,245,.24)" stroke-width="1.8" stroke-dasharray="7 5" fill="none"></path></svg>
				<svg viewBox="0 0 900 80" preserveAspectRatio="none" aria-hidden="true"><path d="M0 40 Q75 22 150 40 T300 40 T450 40 T600 40 T750 40 T900 40 L900 80 L0 80 Z" fill="#1f2446"></path><path d="M0 40 Q75 22 150 40 T300 40 T450 40 T600 40 T750 40 T900 40" stroke="rgba(223,232,245,.24)" stroke-width="1.8" stroke-dasharray="7 5" fill="none"></path></svg>
			</div>
			<div class="swell mid">
				<svg viewBox="0 0 900 90" preserveAspectRatio="none" aria-hidden="true"><path d="M0 45 Q90 24 180 45 T360 45 T540 45 T720 45 T900 45 L900 90 L0 90 Z" fill="#1a1f3d"></path><path d="M0 45 Q90 24 180 45 T360 45 T540 45 T720 45 T900 45" stroke="rgba(223,232,245,.34)" stroke-width="2" stroke-dasharray="9 6" fill="none"></path></svg>
				<svg viewBox="0 0 900 90" preserveAspectRatio="none" aria-hidden="true"><path d="M0 45 Q90 24 180 45 T360 45 T540 45 T720 45 T900 45 L900 90 L0 90 Z" fill="#1a1f3d"></path><path d="M0 45 Q90 24 180 45 T360 45 T540 45 T720 45 T900 45" stroke="rgba(223,232,245,.34)" stroke-width="2" stroke-dasharray="9 6" fill="none"></path></svg>
			</div>

			<div class="boat-lane">
				<!-- the tug is a real door, not a poke: it tows the manifest into the workshop -->
				<a class="tow" href="/helm" title="the manifest, under tow" aria-label="the manifest, under tow: see the workshop">
					<span class="boat">
						<svg class="hull" width="40" height="34" viewBox="0 0 30 24" aria-hidden="true" data-bolted={boatSvg ? 'boat' : undefined}>
							{boatSvg ? (
								<Fragment set:html={innerMarkup(boatSvg)} />
							) : (
								<>
									<path d="M4 15 L26 15 L21 22 L9 22 Z" fill="#93a0e8"></path>
									<path d="M15 15 V3" stroke="#5f6ec4" stroke-width="1.5"></path>
									<path d="M15 3 L24 13 L15 13 Z" fill="#f0d9a8"></path>
								</>
							)}
							<circle class="lantern" cx="15" cy="3" r="2.2" fill="var(--lamp)"></circle>
						</svg>
					</span>
					{barges.map((crates) => (
						<>
							<span class="line" aria-hidden="true"></span>
							<span class="barge">{crates.map((crate) => <i class="crate">{crate}</i>)}</span>
						</>
					))}
				</a>
			</div>

			<BottleBoat client:idle proverbs={proverbs} bottleSvg={bottleSvg} auto={true} />

			<div class="swell front">
				<svg viewBox="0 0 900 100" preserveAspectRatio="none" aria-hidden="true"><path d="M0 50 Q112 26 225 50 T450 50 T675 50 T900 50 L900 100 L0 100 Z" fill="#131628"></path><path d="M0 50 Q112 26 225 50 T450 50 T675 50 T900 50" stroke="rgba(223,232,245,.45)" stroke-width="2.2" stroke-dasharray="11 7" fill="none"></path></svg>
				<svg viewBox="0 0 900 100" preserveAspectRatio="none" aria-hidden="true"><path d="M0 50 Q112 26 225 50 T450 50 T675 50 T900 50 L900 100 L0 100 Z" fill="#131628"></path><path d="M0 50 Q112 26 225 50 T450 50 T675 50 T900 50" stroke="rgba(223,232,245,.45)" stroke-width="2.2" stroke-dasharray="11 7" fill="none"></path></svg>
			</div>
		</div>
	</footer>
</BaseLayout>

<script>
	// The keeper's landing, client side: reveal-on-scroll, the chart-paper
	// ambience with its lamp/secrets and touch long-press, the gull that
	// occasionally roosts, and the skills gag with its count-up numbers.
	// Transcribed from design/Hello.dc.html's Component, trimmed of what this
	// static build never needs: no ARGSEA_DATA poll (the data's already in the
	// HTML), no MutationObserver wake (nothing swaps the DOM after load, so the
	// gauge count-up's own two triggers, the reveal and the gag's swap, just
	// call the sweep directly), no tilt (the mock never applies the class it
	// defines the effect for), no LED loop (src/lib/lightChar.ts's WAAPI engine
	// already drives every lamp on this page via the LightBadge island).

	// ---------- the numbers count up as the bars fill ----------
	function sweepGaugeNums() {
		const eased = (k: number) => 1 - Math.pow(1 - k, 3);
		document.querySelectorAll<HTMLElement>('.gauge.in .gnum[data-target]:not([data-run])').forEach((el, idx) => {
			el.setAttribute('data-run', '');
			const target = Number(el.dataset.target) || 0;
			const t0 = performance.now() + idx * 120;
			const step = (now: number) => {
				const k = Math.min(1, Math.max(0, (now - t0) / 1100));
				el.textContent = `${Math.round(eased(k) * target)}%`;
				if (k < 1) requestAnimationFrame(step);
			};
			requestAnimationFrame(step);
		});
	}

	// ---------- everything clicks into place ----------
	function initReveals() {
		const io = new IntersectionObserver((entries) => {
			for (const entry of entries) {
				if (!entry.isIntersecting) continue;
				entry.target.classList.add('in');
				sweepGaugeNums();
				io.unobserve(entry.target);
			}
		}, { threshold: .15 });
		document.querySelectorAll<HTMLElement>('.rv').forEach((el) => {
			const r = el.getBoundingClientRect();
			if (r.top < innerHeight - 40 && r.bottom > 0) {
				el.classList.add('in');
				sweepGaugeNums();
			} else {
				io.observe(el);
			}
		});
	}

	// ---------- once in a while, a gull lands on the chart ----------
	function initGull() {
		const g = document.getElementById('gull-mark');
		if (!g) return;
		const schedule = () => setTimeout(roost, 24000 + Math.random() * 36000);
		const roost = () => {
			const doc = document.documentElement, W = doc.clientWidth;
			const gutter = Math.max(0, (W - 1200) / 2);
			const strip = Math.max(10, gutter - 50);
			const left = Math.random() < .5;
			const x = Math.min(W - 90, Math.max(90, left ? 26 + Math.random() * strip : W - 26 - Math.random() * strip));
			const y = 180 + Math.random() * Math.max(200, doc.scrollHeight - 900);
			g.style.left = `${x}px`;
			g.style.top = `${y}px`;
			g.classList.add('up');
			setTimeout(() => { g.classList.remove('up'); schedule(); }, 12000);
		};
		setTimeout(roost, 9000 + Math.random() * 8000);
	}

	// ---------- the fake skills only exist once JS is running ----------
	function stampFakeSkills() {
		const tpl = document.getElementById('skills-fake-tpl') as HTMLTemplateElement | null;
		const host = document.getElementById('skills-fake');
		if (tpl && host) host.appendChild(tpl.content.cloneNode(true));
	}

	// ---------- the skills section is a lie ----------
	function initSkillsGag() {
		const fake = document.getElementById('skills-fake');
		const real = document.getElementById('hobbies-real');
		const title = document.getElementById('hobby-title');
		if (!fake || !real || !title) return;
		const calm = matchMedia('(prefers-reduced-motion: reduce)').matches;
		const swap = () => {
			fake.style.display = 'none';
			real.style.display = '';
			title.textContent = 'Hobbies';
			real.querySelectorAll('.gauge').forEach((gauge) => {
				gauge.classList.remove('in');
				const n = gauge.querySelector<HTMLElement>('.gnum');
				if (n) { n.removeAttribute('data-run'); n.textContent = '0%'; }
			});
			requestAnimationFrame(() => requestAnimationFrame(() => {
				real.querySelectorAll('.gauge').forEach((gauge) => gauge.classList.add('in'));
				sweepGaugeNums();
			}));
		};
		if (calm) { swap(); return; }
		let done = false;
		const io = new IntersectionObserver((entries) => {
			if (done || !entries.some((entry) => entry.isIntersecting)) return;
			done = true;
			io.disconnect();
			setTimeout(() => {
				fake.classList.add('glitching');
				title.classList.add('glitching');
				setTimeout(() => {
					swap();
					title.classList.remove('glitching');
					void title.offsetWidth;
					title.classList.add('glitching');
					real.classList.add('glitching');
					setTimeout(() => {
						title.classList.remove('glitching');
						real.classList.remove('glitching');
					}, 520);
				}, 480);
			}, 1500);
		}, { threshold: .35 });
		io.observe(fake);
	}

	// ---------- ambience: the chart of the Flannan grounds, scrolling under the page ----------
	function initWindow() {
		const cv = document.getElementById('window-scape') as HTMLCanvasElement | null;
		if (!cv) return;
		const ctx = cv.getContext('2d');
		if (!ctx) return;
		const calm = matchMedia('(prefers-reduced-motion: reduce)').matches;
		const years: string[] = JSON.parse(cv.dataset.years || '[]');
		let W = 0, H = 0, seed = 7, chartDocH = 0;
		const R = () => (seed = (seed * 16807) % 2147483647) / 2147483647;
		const chart = document.createElement('canvas');
		const docHeight = () => Math.max(innerHeight, document.documentElement.scrollHeight);

		const paintChart = () => {
			seed = 7;
			const w = W, h = chartDocH = docHeight();
			chart.width = w;
			chart.height = h;
			const c = chart.getContext('2d');
			if (!c) return;
			c.clearRect(0, 0, w, h);
			// graticule: home waters, 58°N 7°30′W give or take
			c.font = '9px ui-monospace,Menlo,monospace';
			for (let y = 130, mn = 19; y < h && mn >= 0; y += 780, mn--) {
				c.strokeStyle = 'rgba(147,160,232,.03)';
				c.beginPath(); c.moveTo(0, y); c.lineTo(w, y); c.stroke();
				c.fillStyle = 'rgba(147,160,232,.12)';
				c.fillText(`58°${mn}′N`, 10, y - 5);
			}
			for (let x = 70, mm = 38; x < w; x += 430, mm -= 2) {
				c.strokeStyle = 'rgba(147,160,232,.025)';
				c.beginPath(); c.moveTo(x, 0); c.lineTo(x, h); c.stroke();
				c.fillStyle = 'rgba(147,160,232,.1)';
				c.fillText(`7°${mm}′W`, x + 5, 16);
			}
			// the isles themselves, north to south down the page
			const isles = [
				{ fx: .24, fy: .075, s: 46, name: 'Eilean Mòr', light: true },
				{ fx: .8, fy: .24, s: 30, name: 'Eilean Taighe' },
				{ fx: .13, fy: .43, s: 26, name: 'Roareim' },
				{ fx: .7, fy: .63, s: 28, name: 'Bròna Cleit' },
				{ fx: .3, fy: .84, s: 22, name: 'Sgeir Tomain' },
			];
			for (const isle of isles) {
				const cx = isle.fx * w, cy = isle.fy * h, wob = 1 + R() * 5;
				c.strokeStyle = 'rgba(147,160,232,.042)'; c.lineWidth = 1;
				for (let k = 3; k >= 1; k--) {
					const base = isle.s * (1 + k * .7) + R() * 10;
					c.beginPath();
					for (let a = 0; a <= 40; a++) {
						const th = (a / 40) * Math.PI * 2;
						const r = base + Math.sin(th * 3 + k + wob) * base * .16 + Math.sin(th * 7 + wob * 2) * base * .08;
						const x = cx + Math.cos(th) * r * 1.3, y = cy + Math.sin(th) * r;
						if (a) c.lineTo(x, y); else c.moveTo(x, y);
					}
					c.closePath(); c.stroke();
				}
				c.strokeStyle = 'rgba(147,160,232,.1)';
				c.beginPath();
				for (let a = 0; a <= 34; a++) {
					const th = (a / 34) * Math.PI * 2;
					const r = isle.s * (1 + .3 * Math.sin(th * 3 + wob) + .16 * Math.sin(th * 5 + wob * 3));
					const x = cx + Math.cos(th) * r * 1.25, y = cy + Math.sin(th) * r;
					if (a) c.lineTo(x, y); else c.moveTo(x, y);
				}
				c.closePath(); c.stroke();
				c.font = 'italic 11px Georgia,serif'; c.fillStyle = 'rgba(147,160,232,.14)';
				c.fillText(isle.name, cx + isle.s * 1.5, cy - isle.s * .9);
				c.font = '9px ui-monospace,Menlo,monospace';
				if (isle.light) {
					c.fillStyle = 'rgba(240,217,168,.4)';
					c.beginPath(); c.arc(cx, cy - 2, 1.8, 0, 6.29); c.fill();
					c.fillStyle = 'rgba(240,217,168,.28)';
					c.fillText('Fl(2) W 30s', cx + isle.s * 1.5, cy - isle.s * .9 + 13);
				}
			}
			// soundings; some of the depths are years, if you look
			c.font = '10px ui-monospace,Menlo,monospace';
			const n = Math.max(46, Math.round(h / 80));
			for (let i = 0; i < n; i++) {
				const x = R() * w, y = R() * h;
				if (i < years.length) { c.fillStyle = 'rgba(147,160,232,.11)'; c.fillText(years[i], x, y); }
				else { c.fillStyle = 'rgba(147,160,232,.07)'; c.fillText(String(2 + ((R() * 34) | 0)), x, y); }
			}
			// compass rose
			const rx = w * .88, ry = 300;
			c.strokeStyle = 'rgba(147,160,232,.055)';
			c.beginPath(); c.arc(rx, ry, 44, 0, 6.29); c.stroke();
			c.beginPath(); c.arc(rx, ry, 58, 0, 6.29); c.stroke();
			for (let i = 0; i < 24; i++) {
				const th = (i / 24) * Math.PI * 2, l = i % 6 ? 4 : 10;
				c.beginPath(); c.moveTo(rx + Math.cos(th) * (58 - l), ry + Math.sin(th) * (58 - l));
				c.lineTo(rx + Math.cos(th) * 58, ry + Math.sin(th) * 58); c.stroke();
			}
			c.fillStyle = 'rgba(147,160,232,.07)';
			c.beginPath(); c.moveTo(rx, ry - 58); c.lineTo(rx - 5, ry - 38); c.lineTo(rx + 5, ry - 38); c.closePath(); c.fill();
			c.fillText('N', rx - 3, ry - 64);
		};

		// things that exist only under the lamp, drawn in DOCUMENT space
		const drawSecrets = (c: CanvasRenderingContext2D) => {
			const w = W, docH = chartDocH || docHeight();
			// a small sea monster, unconfirmed
			const sx0 = w * .55, sy0 = docH * .55;
			c.strokeStyle = 'rgba(147,160,232,.45)'; c.lineWidth = 1.2; c.lineCap = 'round';
			c.beginPath();
			for (let k = 0; k < 3; k++) c.arc(sx0 + k * 24, sy0, 10, Math.PI, 0);
			c.arc(sx0 + 3 * 24 + 4, sy0 - 4, 7, Math.PI * .9, Math.PI * 2.1);
			c.stroke();
			c.fillStyle = 'rgba(147,160,232,.55)';
			c.fillRect(sx0 + 3 * 24 + 5, sy0 - 9, 1.8, 1.8);
			c.font = '9px ui-monospace,Menlo,monospace'; c.fillStyle = 'rgba(122,131,173,.5)';
			c.fillText('unconfirmed', sx0 - 6, sy0 + 22);
			// here be dragons
			c.font = 'italic 14px Georgia,serif'; c.fillStyle = 'rgba(240,217,168,.5)';
			c.save(); c.translate(w * .07, docH * .42); c.rotate(-.06); c.fillText('here be dragons', 0, 0); c.restore();
			// the cat came this way
			c.fillStyle = 'rgba(239,234,219,.42)';
			let px = w * .3, py = docH * .17;
			for (let i = 0; i < 9; i++) {
				const th = -.5 + i * .16;
				px += Math.cos(th) * 26; py += Math.sin(th) * 18;
				const side = i % 2 ? 5 : -5;
				const ox = px + Math.cos(th + 1.57) * side, oy = py + Math.sin(th + 1.57) * side * .6;
				c.beginPath(); c.arc(ox, oy, 2.1, 0, 6.29); c.fill();
				for (let d2 = 0; d2 < 3; d2++) { c.beginPath(); c.arc(ox - 3 + d2 * 3, oy - 4.5, 1, 0, 6.29); c.fill(); }
			}
		};

		// the plotted course calls at every section
		const course = [document.querySelector('.hero h1')]
			.concat(Array.from(document.querySelectorAll('.sec-head')), [document.querySelector('.berth .big')])
			.filter((el): el is Element => Boolean(el));
		let mx = -999, my = -999, sx = -999, sy = -999;
		const onMove = (e: PointerEvent) => {
			if (e.pointerType === 'touch') return;
			mx = e.clientX; my = e.clientY;
			if (sx < -500) { sx = mx; sy = my; }
		};
		// on touch the lamp is held, not pointed: press half a second, then drag it around
		let holdT = 0, lampTouch = false, tx0 = 0, ty0 = 0;
		const douse = () => { mx = my = sx = sy = -999; };
		const onTouchDown = (e: PointerEvent) => {
			if (e.pointerType !== 'touch') return;
			tx0 = e.clientX; ty0 = e.clientY;
			clearTimeout(holdT);
			holdT = window.setTimeout(() => { lampTouch = true; mx = sx = tx0; my = sy = ty0; }, 450);
		};
		const onTouchMove = (e: PointerEvent) => {
			if (e.pointerType !== 'touch') return;
			if (lampTouch) { mx = e.clientX; my = e.clientY; return; }
			if (Math.abs(e.clientX - tx0) > 12 || Math.abs(e.clientY - ty0) > 12) clearTimeout(holdT);
		};
		const onTouchEnd = (e: PointerEvent) => {
			if (e.pointerType !== 'touch') return;
			clearTimeout(holdT);
			if (!lampTouch) return;
			lampTouch = false;
			window.setTimeout(() => { if (!lampTouch) douse(); }, 900);
		};
		const blockScroll = (e: TouchEvent) => { if (lampTouch) e.preventDefault(); };
		const chartOff = () => Math.max(0, Math.min(scrollY, chart.height - H));
		const frame = () => {
			requestAnimationFrame(frame);
			if (Math.abs(docHeight() - chartDocH) > 300) paintChart();
			sx += (mx - sx) * .12; sy += (my - sy) * .12;
			ctx.clearRect(0, 0, W, H);
			const off = chartOff();
			ctx.drawImage(chart, 0, off, W, H, 0, 0, W, H);
			const pts = course.map((el) => {
				const r = el.getBoundingClientRect();
				return { x: Math.max(26, r.left - 34), y: r.top + r.height / 2 };
			});
			if (pts.length > 1) {
				ctx.strokeStyle = 'rgba(240,217,168,.08)'; ctx.lineWidth = 1; ctx.setLineDash([5, 9]);
				ctx.beginPath();
				ctx.moveTo(pts[0].x - 70, pts[0].y - 170);
				ctx.lineTo(pts[0].x, pts[0].y);
				for (let i = 1; i < pts.length; i++) {
					const a = pts[i - 1], b = pts[i];
					ctx.quadraticCurveTo((a.x + b.x) / 2 + 46 * Math.sin(i * 2.1), (a.y + b.y) / 2, b.x, b.y);
				}
				ctx.lineTo(pts[pts.length - 1].x + 40, pts[pts.length - 1].y + 180);
				ctx.stroke(); ctx.setLineDash([]);
				ctx.strokeStyle = 'rgba(240,217,168,.2)';
				for (const p of pts) {
					ctx.beginPath();
					ctx.moveTo(p.x - 4, p.y - 4); ctx.lineTo(p.x + 4, p.y + 4);
					ctx.moveTo(p.x + 4, p.y - 4); ctx.lineTo(p.x - 4, p.y + 4);
					ctx.stroke();
				}
			}
			if (mx > -500) {
				// a lamp held over the paper: nearby linework comes up
				for (const rr of [190, 120, 70]) {
					ctx.save(); ctx.beginPath(); ctx.arc(sx, sy, rr, 0, 6.29); ctx.clip();
					ctx.drawImage(chart, 0, off, W, H, 0, 0, W, H); ctx.restore();
				}
				// and the things drawn in invisible ink
				ctx.save(); ctx.beginPath(); ctx.arc(sx, sy, 130, 0, 6.29); ctx.clip();
				ctx.translate(0, -scrollY); drawSecrets(ctx); ctx.restore();
			}
		};
		const calmDraw = () => {
			const off = chartOff();
			ctx.clearRect(0, 0, W, H);
			ctx.drawImage(chart, 0, off, W, H, 0, 0, W, H);
		};
		const resize = () => { W = cv.width = innerWidth; H = cv.height = innerHeight; paintChart(); calmDraw(); };
		resize();
		addEventListener('resize', resize);
		if (calm) {
			addEventListener('scroll', calmDraw, { passive: true });
		} else {
			addEventListener('pointermove', onMove);
			addEventListener('pointerdown', onTouchDown);
			addEventListener('pointermove', onTouchMove);
			addEventListener('pointerup', onTouchEnd);
			addEventListener('pointercancel', onTouchEnd);
			addEventListener('touchmove', blockScroll, { passive: false });
			requestAnimationFrame(frame);
		}
	}

	stampFakeSkills();
	initReveals();
	initGull();
	initSkillsGag();
	initWindow();
</script>

<style>
	/* Tokens carried over verbatim from design/Hello.dc.html; --brass has no
	   global token of its own (this slice's global.css edit is --lamp only),
	   so its rgba triple (198,160,82) is inlined at each call site instead. */

	.wrap {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--gutter);
		position: relative;
		z-index: 2;
	}

	/* ---------- ambience: the view from the lamp room ---------- */
	#window-scape {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	/* ---------- reveals: everything clicks into place ---------- */
	.rv {
		opacity: 0;
		transform: translateY(16px);
	}

	.rv.in {
		opacity: 1;
		transform: translateY(0);
		transition: opacity .5s ease var(--d, 0s), transform .56s cubic-bezier(.2, .9, .25, 1.06) var(--d, 0s);
	}

	.sec {
		padding: clamp(40px, 7vh, 84px) 0 0;
	}

	.sec-head {
		display: flex;
		align-items: baseline;
		gap: 16px;
		margin-bottom: clamp(18px, 3vh, 30px);
	}

	.sec-head h2 {
		font-family: var(--font-display);
		font-size: clamp(21px, 2.4vw, 27px);
		color: var(--text-head);
	}

	.sec-head .tick {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .18em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.sec-head .rule {
		flex: 1;
		height: 1px;
		background: rgba(198, 160, 82, .22);
		align-self: center;
	}

	/* ---------- hero ---------- */
	.hero {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(28px, 5vw, 64px);
		align-items: start;
		padding: clamp(44px, 9vh, 110px) 0 0;
	}

	.hero--watch {
		grid-template-columns: 1.02fr .98fr;
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(40px, 5.6vw, 72px);
		color: var(--text-head);
		line-height: 1.02;
		letter-spacing: -.01em;
		text-wrap: balance;
	}

	.hero .role {
		font-family: var(--font-mono);
		font-size: clamp(13px, 1.3vw, 15px);
		color: var(--gold);
		letter-spacing: .04em;
		margin-top: 18px;
	}

	.hero .pitch {
		color: var(--text-body);
		font-size: 16.5px;
		line-height: 1.65;
		margin-top: 20px;
		max-width: 52ch;
	}

	.hero .doors {
		display: flex;
		gap: 22px;
		margin-top: 30px;
		font-family: var(--font-mono);
		font-size: 13.5px;
	}

	.hero .doors a {
		border-bottom: 1px solid rgba(147, 160, 232, .35);
		padding-bottom: 2px;
		transition: color .18s ease, border-color .18s ease;
	}

	.hero .doors a:hover {
		color: var(--text-nav);
		border-color: var(--gold);
	}

	.now {
		background: rgba(26, 30, 51, .55);
		border: 1px solid rgba(198, 160, 82, .28);
		padding: 24px 26px;
		position: relative;
		backdrop-filter: blur(2px);
	}

	.now .tick {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .18em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.now .doodle {
		position: absolute;
		top: -56px;
		right: -14px;
		opacity: .85;
	}

	.now-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
	}

	.now .kept {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--text-dim);
	}

	.letter {
		margin-top: 12px;
	}

	.letter p {
		color: var(--text-body);
		font-size: 13.5px;
		line-height: 1.62;
		margin-top: 9px;
	}

	.letter .sig {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--text-soft);
		font-size: 14px;
	}

	.letter .aband {
		font-style: italic;
		color: var(--text-dim);
		font-size: 12.5px;
	}

	.now .chips {
		margin-top: 14px;
		padding-top: 12px;
		border-top: 1px solid rgba(147, 160, 232, .12);
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--text-dim);
		line-height: 1.9;
	}

	.now .chips b {
		color: var(--periwinkle);
		font-weight: normal;
	}

	@keyframes morseHi {
		0%, 4.9%   { opacity: 1; }
		5%, 9.9%   { opacity: .12; }
		10%, 14.9% { opacity: 1; }
		15%, 19.9% { opacity: .12; }
		20%, 24.9% { opacity: 1; }
		25%, 29.9% { opacity: .12; }
		30%, 34.9% { opacity: 1; }
		35%, 49.9% { opacity: .12; }
		50%, 54.9% { opacity: 1; }
		55%, 59.9% { opacity: .12; }
		60%, 64.9% { opacity: 1; }
		65%, 100%  { opacity: .12; }
	}

	/* ---------- the flagship rows ---------- */
	.flagship {
		position: relative;
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		align-items: center;
		margin-bottom: clamp(34px, 5vh, 56px);
	}

	.flagship.flip .shot { grid-area: 1 / 5 / 2 / 13; }
	.flagship.flip .info { grid-area: 1 / 1 / 2 / 7; align-items: flex-start; text-align: left; }

	.flagship .shot {
		grid-area: 1 / 1 / 2 / 9;
		display: block;
		aspect-ratio: 16 / 9;
		position: relative;
		overflow: hidden;
		background: #0d0f1c;
		border: 1px solid rgba(147, 160, 232, .16);
		border-radius: 5px;
		filter: grayscale(1) contrast(.92) brightness(.85);
		transition: filter .35s ease, border-color .3s ease;
	}

	.flagship .shot:hover {
		filter: none;
		border-color: rgba(198, 160, 82, .7);
	}

	.flagship .shot img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.flagship .info {
		grid-area: 1 / 7 / 2 / 13;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 12px;
		text-align: right;
	}

	.flagship .fl-facts {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--text-dim);
		letter-spacing: .06em;
	}

	.flagship .info b {
		font-family: var(--font-mono);
		font-size: 20px;
		color: var(--gold);
		font-weight: normal;
	}

	.flagship .fbox {
		position: relative;
		background: rgba(26, 30, 51, .92);
		border: 1px solid rgba(198, 160, 82, .32);
		padding: 20px 22px;
		text-align: left;
		box-shadow: 0 18px 44px rgba(0, 0, 0, .45);
		backdrop-filter: blur(2px);
	}

	.flagship .archive {
		position: absolute;
		top: 100%;
		left: 0;
		margin-top: 9px;
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: .14em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.flagship .fulllog {
		font-family: var(--font-mono);
		font-size: 12.5px;
		color: var(--periwinkle);
		border-bottom: 1px solid rgba(147, 160, 232, .35);
		padding-bottom: 2px;
		transition: color .18s ease, border-color .18s ease;
	}

	.flagship .fulllog:hover {
		color: var(--text-nav);
		border-color: var(--gold);
	}

	.flagship .fbox p {
		color: var(--text-soft);
		font-size: 14.5px;
		line-height: 1.6;
	}

	.flagship .facts {
		margin: 12px 0 0;
	}

	.flagship .frow {
		display: flex;
		align-items: baseline;
		gap: 8px;
		padding: 5px 0 5px 18px;
		position: relative;
	}

	.flagship .frow::before {
		content: "+";
		position: absolute;
		left: 0;
		color: rgba(198, 160, 82, .9);
		font-family: var(--font-mono);
	}

	.flagship .frow dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .1em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin: 0;
		flex: none;
	}

	.flagship .frow dd {
		font-size: 13.5px;
		color: var(--text-soft);
		margin: 0;
		line-height: 1.5;
	}

	.flagship .moral {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 13.5px;
		color: var(--gold);
		margin-top: 12px;
	}

	.flagship .tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-top: 14px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--text-dim);
	}

	.flagship .tags i {
		font-style: normal;
		border: 1px solid rgba(147, 160, 232, .22);
		padding: 3px 9px;
	}

	/* ---------- notes: the featured entry ---------- */
	.feat {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: clamp(20px, 4vw, 54px);
		align-items: center;
		background: var(--card-alt);
		border: 1px solid rgba(147, 160, 232, .16);
		border-radius: 5px;
		padding: clamp(22px, 3vw, 34px) clamp(22px, 3.4vw, 40px);
		margin-bottom: 20px;
		transition: border-color .2s ease, box-shadow .25s ease;
	}

	.feat:hover {
		border-color: rgba(198, 160, 82, .5);
		box-shadow: 0 16px 40px rgba(0, 0, 0, .4);
	}

	.feat-kick {
		display: flex;
		align-items: center;
		gap: 9px;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .14em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.feat-main {
		display: flex;
		flex-direction: column;
		gap: 14px;
		min-width: 0;
	}

	.feat-main b {
		font-family: var(--font-display);
		font-weight: normal;
		font-size: clamp(22px, 2.6vw, 30px);
		line-height: 1.15;
		color: var(--text-head);
		text-wrap: balance;
		transition: color .18s ease;
	}

	.feat:hover .feat-main b {
		color: var(--gold);
	}

	.feat-main p {
		color: var(--text-body);
		font-size: 15px;
		line-height: 1.62;
		max-width: 58ch;
	}

	.feat-foot {
		font-family: var(--font-mono);
		font-size: 12.5px;
		color: var(--periwinkle);
		transition: color .18s ease;
	}

	.feat:hover .feat-foot {
		color: var(--text-nav);
	}

	.feat-doodle {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		color: rgba(147, 160, 232, .55);
		transform: rotate(-2deg);
		padding: 0 8px;
		transition: color .3s ease;
	}

	.feat:hover .feat-doodle {
		color: rgba(240, 217, 168, .75);
	}

	.feat-doodle .cap {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 13px;
		color: var(--text-dim);
	}

	/* ---------- hobbies: the skills gag ---------- */
	.skills-fake .gnum-fake { color: var(--gold); }
	.skills-fake .gfill { transition: none; }

	.glitching {
		animation: glitch .5s steps(2, jump-none) both;
	}

	@keyframes glitch {
		0%   { clip-path: inset(0 0 0 0); transform: none; filter: none; }
		15%  { clip-path: inset(12% 0 64% 0); transform: translate(-7px, 2px) skewX(-4deg); filter: hue-rotate(90deg) saturate(3); }
		30%  { clip-path: inset(58% 0 8% 0); transform: translate(6px, -3px) skewX(3deg); filter: hue-rotate(-60deg) contrast(2); }
		45%  { clip-path: inset(30% 0 34% 0); transform: translate(-4px, 1px); filter: invert(.8); }
		60%  { clip-path: inset(4% 0 82% 0); transform: translate(8px, -1px) skewX(-6deg); filter: hue-rotate(140deg); }
		75%  { clip-path: inset(70% 0 3% 0); transform: translate(-6px, 3px); filter: saturate(4) brightness(1.4); }
		100% { clip-path: inset(0 0 0 0); transform: none; filter: none; }
	}

	.shore-note {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--text-dim);
		font-size: 14px;
		margin: -10px 0 22px;
	}

	.gauges {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 16px;
	}

	.gauge {
		background: var(--card-alt);
		border: 1px solid rgba(147, 160, 232, .16);
		border-radius: 5px;
		padding: 18px 20px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		position: relative;
		overflow: hidden;
		transition: border-color .2s ease, box-shadow .25s ease;
	}

	.gauge:hover {
		border-color: rgba(198, 160, 82, .5);
		box-shadow: 0 14px 34px rgba(0, 0, 0, .35);
	}

	.gauge .gtop {
		display: flex;
		align-items: baseline;
		gap: 9px;
	}

	.gauge .gmark {
		position: absolute;
		top: 2px;
		right: 6px;
		opacity: .13;
		pointer-events: none;
		filter: saturate(.35) brightness(1.25);
		transition: opacity .35s ease;
	}

	.gauge:hover .gmark {
		opacity: .24;
	}

	.gauge .mk {
		position: relative;
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-end;
		min-width: 44px;
		height: 44px;
		transform: scale(1.5);
		transform-origin: top right;
	}

	.gauge .isle {
		width: 40px;
		height: 8px;
		margin-top: -2px;
		border-radius: 60% 70% 0 0 / 100% 100% 0 0;
		background: linear-gradient(180deg, #2a3358, #141a34);
	}

	.gauge .sand {
		width: 46px;
		height: 11px;
		border-radius: 50% 50% 40% 40%;
		background: linear-gradient(180deg, #6a5a38, #3a3020);
	}

	.gauge .pen {
		position: absolute;
		left: 16px;
		animation: pennantWave 3.5s ease-in-out infinite;
		transform-origin: left;
	}

	.gauge .pen.p1 { top: 2px; width: 15px; height: 7px; background: #6fca97; clip-path: polygon(0 0, 100% 0, 80% 50%, 100% 100%, 0 100%); }
	.gauge .pen.p2 { top: 11px; width: 11px; height: 6px; background: #f0d9a8; clip-path: polygon(0 0, 100% 0, 75% 50%, 100% 100%, 0 100%); animation-delay: .4s; }

	.gauge .ink {
		width: 52px;
		animation: inkPulse 5s ease-in-out infinite;
	}

	.gauge .ink .b1 { position: absolute; left: 8px; top: 8px; width: 34px; height: 26px; border-radius: 56% 44% 62% 38% / 54% 60% 40% 46%; background: radial-gradient(circle at 40% 38%, #2a3160, #141833); }
	.gauge .ink .b2 { position: absolute; left: 2px; top: 18px; width: 16px; height: 13px; border-radius: 60% 40% 50% 50%; background: #182046; }
	.gauge .ink .b3 { position: absolute; right: 3px; top: 4px; width: 12px; height: 11px; border-radius: 50%; background: #1c2450; }
	.gauge .ink .x { position: absolute; left: 20px; top: 14px; font-family: var(--font-mono); font-size: 11px; color: rgba(147, 160, 232, .5); }

	.gauge b {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--gold);
		font-weight: normal;
		flex: 1;
	}

	.gauge .gstate {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .14em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.gauge .gbar {
		display: block;
		height: 3px;
		background: rgba(147, 160, 232, .14);
		border-radius: 2px;
		overflow: hidden;
	}

	.gauge .gfill {
		display: block;
		position: relative;
		height: 100%;
		border-radius: 2px;
		background: linear-gradient(90deg, rgba(198, 160, 82, .55), var(--gold));
		width: 0;
		transition: width 1.1s cubic-bezier(.25, .9, .3, 1);
	}

	.gauge:not(.in) .gfill {
		width: 0 !important;
	}

	.gauge .gmeta {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--text-dim);
	}

	.gauge .gnum {
		color: var(--gold);
		font-variant-numeric: tabular-nums;
		min-width: 3.2ch;
		text-align: right;
	}

	.gauge .gfill::after {
		content: "";
		position: absolute;
		top: -3px;
		bottom: -3px;
		right: -4px;
		width: 9px;
		border-radius: 50%;
		background: radial-gradient(closest-side, rgba(255, 240, 200, .95), rgba(255, 220, 140, .5) 55%, transparent);
		opacity: 0;
		animation-delay: inherit;
	}

	.gauge.in .gfill::after {
		animation: lampGlint 1.6s ease 1;
		animation-delay: inherit;
	}

	@keyframes lampGlint {
		0%, 55% { opacity: 0; }
		75%     { opacity: 1; }
		100%    { opacity: 0; }
	}

	/* the log sits in flow and sets the height, so the card never reserves dead air */
	.gauge .gword {
		position: relative;
		display: block;
		min-height: 2.9em;
	}

	.gauge .verdict, .gauge .glog {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 12.5px;
		line-height: 1.5;
		color: var(--text-dim);
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
		transition: opacity .3s ease, transform .3s cubic-bezier(.2, .9, .3, 1.25);
	}

	.gauge .verdict {
		position: absolute;
		inset: 0;
	}

	.gauge b, .gauge .gstate {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.gauge .glog {
		opacity: 0;
		transform: translateY(3px);
	}

	.gauge:hover .glog, .gauge:focus-visible .glog {
		opacity: 1;
		transform: none;
	}

	.gauge:hover .verdict, .gauge:focus-visible .verdict {
		opacity: 0;
		transform: translateY(-3px);
	}

	@keyframes boatDrift  { 0%, 100% { transform: translateX(0) rotate(-2deg); } 50% { transform: translateX(4px) rotate(2deg); } }
	@keyframes palmSway   { 0%, 100% { transform: rotate(-4deg); } 50% { transform: rotate(5deg); } }
	@keyframes pennantWave { 0%, 100% { transform: scaleX(1) skewY(0); } 50% { transform: scaleX(.92) skewY(-3deg); } }
	@keyframes inkPulse   { 0%, 100% { opacity: .85; } 50% { opacity: 1; } }
	@keyframes lampPulse  { 0%, 100% { opacity: .55; } 50% { opacity: 1; } }

	/* ---------- a gull, drawn on the chart, occasionally ---------- */
	.gull-mark {
		position: absolute;
		z-index: 4;
		transform: translateX(-50%);
		color: rgba(147, 160, 232, .55);
		opacity: 0;
		pointer-events: none;
		transition: opacity 1.4s ease, color .3s ease;
	}

	.gull-mark.up {
		opacity: 1;
		pointer-events: auto;
	}

	.gull-mark span {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translate(-50%, 2px);
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .18em;
		text-transform: uppercase;
		color: var(--text-dim);
		opacity: 0;
		transition: opacity .3s ease;
		white-space: nowrap;
	}

	.gull-mark:hover {
		color: var(--gold);
	}

	.gull-mark:hover span {
		opacity: 1;
	}

	/* ---------- the footer is the sea ---------- */
	.sea-footer {
		position: relative;
		margin-top: clamp(60px, 10vh, 120px);
		z-index: 2;
	}

	.berth {
		max-width: 1200px;
		margin: 0 auto;
		padding: clamp(30px, 6vh, 70px) var(--gutter) 26px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.cta-kick {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: .26em;
		text-transform: uppercase;
		color: var(--gold);
	}

	.cta-kick::before, .cta-kick::after {
		content: "·";
		margin: 0 10px;
		color: rgba(240, 217, 168, .5);
	}

	.berth .big {
		font-family: var(--font-display);
		font-size: clamp(38px, 5.6vw, 76px);
		color: var(--text-head);
		line-height: 1.12;
		letter-spacing: -.015em;
		margin-top: 18px;
		text-wrap: balance;
	}

	.berth .big em {
		font-style: italic;
		color: var(--gold);
	}

	.cta-sub {
		color: var(--text-body);
		font-size: clamp(15px, 1.8vw, 17.5px);
		line-height: 1.65;
		max-width: 54ch;
		margin-top: 18px;
	}

	.cta-doors {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 28px;
		font-family: var(--font-mono);
		font-size: 13.5px;
