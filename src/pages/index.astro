---
// Hello: hero (kicker + headline, the morse-HI seal), the current watch
// (build-time /1/watch: the letter, the TL;DR bearings, the season's
// postcard; an empty letter collapses the whole section), wave-with-boat
// (and its coast-in-miniature beacons), the flagship + featured cards,
// hobbies preview, journal strip, contact band, and the stores ledge riding
// just above the footer. The dictionary lives in the shared Footer now, read
// from copy.dict (no dedicated dictionary block on this page anymore). The
// flagship card is the `flagship` flag; the two small cards are the
// `featured` flag in list order, never title matching, falling back to the
// next two by order so the section never shows the flagship alone. It opens
// the Light List entry in place; the hero headline comes from the SiteCopy
// singleton and the kicker from the keeper's papers (title + city, no name:
// the wordmark owns it); the say-hi email is the keeper's; the stores ledge
// flattens the tool bench's drawers off the copy singleton into one run,
// falling back to the approved design copy. The journal strip is the newest
// notes, static links out to /notes, and disappears once there are none.
// The hobbies preview is data-driven: on-watch hobbies fill "currently
// learning", the wandering ones become the ship's log's chart pills.
import BaseLayout from '../layouts/BaseLayout.astro';
import LighthouseMark from '../components/LighthouseMark.astro';
import WaveDivider from '../components/WaveDivider.astro';
import HomeLights from '../components/islands/HomeLights';
import JournalStrip from '../components/JournalStrip.astro';
import JournalStripDirector from '../components/islands/JournalStripDirector';
import NextHobbyChip from '../components/islands/NextHobbyChip';
import WatchCat from '../components/islands/WatchCat';
import { getProjects, getSiteCopy, getKeeperProfile, getHobbies, getFigurehead, getNotes, getDoodles, getSuggestions, getCarvings, getWatch, type Hobby, type HobbyState, type WatchBearing } from '../lib/api';
import { boltedSvg, innerMarkup } from '../lib/carvings';
import { mediaUrl } from '../lib/media';

const projects = await getProjects();
const allNotes = await getNotes();

// Flagship = the flagship flag; the two small cards = featured flag order,
// never title matching. Falls back to the next two by order when nothing
// else is featured, so the section never shows the flagship alone.
const flagship = projects.find((project) => project.flagship) ?? null;
const nonFlagship = projects.filter((project) => project.id !== flagship?.id);
const featuredExplicit = nonFlagship.filter((project) => project.featured);
const featuredTwo = (featuredExplicit.length > 0 ? featuredExplicit : nonFlagship).slice(0, 2);

// getNotes() sorts newest-first; cap at three so a growing journal never
// crowds the strip below the mantel
const journalPreview = allNotes.slice(0, 3);

// The register head's "corrected to" line: a real light list is corrected to
// the date of its newest change, so the newest journal entry's date stands in.
const correctedTo = allNotes[0]?.date ?? 'jul 2026';
const journalDoodles = await getDoodles();
const copy = await getSiteCopy();
const keeper = await getKeeperProfile();
const catDesigns = await getFigurehead();
const suggestions = await getSuggestions();

// tower-stub is a carving spot inside LightEntryOverlay, reached here via
// HomeLights; that island can't reach src/lib/api.ts itself. The other three
// are this page's own mounts: the hero seal, the panel rose, the fleet wake.
const carvings = await getCarvings();
const towerSvg = boltedSvg('tower-stub', carvings);
const sealSvg = boltedSvg('morse-seal', carvings);
const roseSvg = boltedSvg('panel-rose', carvings);
const fleetWakeSvg = boltedSvg('fleet-wake', carvings);

// The smuggler's cove: the copy singleton's egg toggles gate what gets wired.
// Bottle off (or an emptied proverb list) leaves the boat sailing, unpokeable.
// The cat's per-page/per-spot picking lives client-side (the director + the
// overlay islands share one pick); the frontmatter just forwards the toggles.
const proverbs = copy.eggs.bottle ? copy.bottleProverbs : [];

// The current watch: an empty letter is the wire's "no watch kept" (and the
// unreachable-API fallback), so the whole section, panel and postcard both,
// simply doesn't render. Never an empty box under the hero.
const watch = await getWatch();
const watchKept = watch.letter !== '';
const watchParagraphs = watch.letter.split(/\n\s*\n/).map((block) => block.trim()).filter((block) => block !== '');
// The rack's two hooks: the first print and, tucked smaller below it, an
// optional second. Each hook is bare when its media id is empty; the second
// handles an absent field (an API predating the two-hook rack) identically.
const watchPostcard = watch.postcardMediaId !== '';
const watchPostcard2 = watch.postcard2MediaId !== '';

// "kept 15 jul" / "from the season · jul 2026", lowercase, no leading zero;
// UTC so every build formats the record the same. A keptAt that doesn't
// parse just drops the dates rather than printing NaN.
const MONTHS = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
const keptAt = new Date(watch.keptAt);
const keptValid = !Number.isNaN(keptAt.getTime());
const keptLine = keptValid ? `kept ${keptAt.getUTCDate()} ${MONTHS[keptAt.getUTCMonth()]}` : '';
const seasonCaption = keptValid ? `from the season · ${MONTHS[keptAt.getUTCMonth()]} ${keptAt.getUTCFullYear()}` : 'from the season';

// A bearing's destination by kind: a light steers into its full log when one
// is lit (else the coast at large), a hobby to the chart, a note to the
// journal; kind "none" stays plain text, never a link.
const bearingHref = (bearing: WatchBearing): string | null => {
	if ('light' === bearing.kind) {
		const light = projects.find((project) => project.id === bearing.targetId);
		return light?.hasLog ? `/projects/${light.slug}` : '/projects';
	}
	if ('hobby' === bearing.kind) {
		return '/hobbies';
	}
	if ('note' === bearing.kind) {
		return '/notes';
	}
	return null;
};

// The mock's own trim: the strip is a single clipped line on desktop, so a
// runaway bearing name ends on an ellipsis instead of vanishing mid-word.
const trimName = (name: string) => name.length > 24 ? `${name.slice(0, 23).trimEnd()}…` : name;

const bearings = watch.bearings.map((bearing) => ({
	verb: bearing.verb,
	name: trimName(bearing.name),
	href: bearingHref(bearing),
}));

// The stores ledge flattens the admin's tool bench (SiteCopy.stores, ≤4
// drawers) into one run, drawer order preserved, labels dropped; a copy
// document from before the bench existed, or one with nothing shelved, falls
// back to the approved design copy so the ledge never runs empty.
const benchTools = (copy.stores ?? []).flatMap((drawer) => drawer.tools ?? []);
const storesRun = benchTools.length > 0
	? benchTools.join(' · ')
	: 'java · python · node.js · go · php · mongodb · redis · rabbitmq · varnish · kubernetes · docker · nginx · linux';

// The list arrives order-sorted. On-watch hobbies (moored or made port, the
// ones the keeper still keeps a light on) fill the mantel; everything still
// wandering becomes a chart pill tagged with its state.
const hobbies = await getHobbies();
const onWatch = (hobby: Hobby) => hobby.state === 'moored' || hobby.state === 'port';
const learning = hobbies.filter(onWatch);
const wandering = hobbies.filter((hobby) => !onWatch(hobby));

// Mirrors STATE_META on the ship's log: the pill carries the label's first
// segment, so a state with a longer gloss ("adrift · lost at sea") still reads
// as one word here (e.g. "piano · adrift").
const STATE_LABEL: Record<HobbyState, string> = {
	moored:   'moored',
	adrift:   'adrift',
	marooned: 'marooned',
	port:     'made port',
	inkspill: 'bearing smudged',
};

// A pill wears its state's own ink on the chart: green for a hobby that made
// port, the smudged gray (plus the blot) for an inkspill, periwinkle for the
// rest. moored/port never wander, so only the wandering states need color here.
const PILL_STATE_CLASS: Partial<Record<HobbyState, string>> = {
	port:     'chart-pill--port',
	inkspill: 'chart-pill--smudged',
};

const hobbyPills = wandering.map((hobby) => ({
	text:       `${hobby.name.toLowerCase()} · ${STATE_LABEL[hobby.state]}`,
	stateClass: PILL_STATE_CLASS[hobby.state],
	smudged:    'inkspill' === hobby.state,
}));
---
<BaseLayout title="Justin Smith · argsea.com" active="hello" quipKey="quipHello">
	<!-- hero -->
	<section class="hero">
		<div class="firefly ff-1"></div>
		<div class="firefly ff-2"></div>
		<div class="firefly ff-3"></div>
		<div class="firefly ff-4"></div>
		<!-- the seal: the light stamped into the postmark · it blinks hi in morse -->
		<div class="postmark-circle" title="···· ··">
			<svg width="34" height="38" viewBox="0 0 18 20" fill="none" stroke="#93a0e8" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-bolted={sealSvg ? 'morse-seal' : undefined}>
				{sealSvg ? (
					<Fragment set:html={innerMarkup(sealSvg)} />
				) : (
					<>
						<path class="postmark-circle__lamp" d="M9 2 L12 6 L6 6 Z" fill="#93a0e8" stroke="none"></path>
						<path d="M7 6 L6 15 M11 6 L12 15 M7 9.5 h4"></path>
						<path d="M4 17 q5 -3 10 0"></path>
					</>
				)}
			</svg>
		</div>
		<div class="hero__copy">
			<div class="section-label fade-up fade-up--1">{keeper.title} · {keeper.location}</div>
			<h1 class="hero__headline fade-up fade-up--2">{copy.heroHeadline}</h1>
		</div>
	</section>

	<!-- the current watch · what the keeper is focused on now -->
	{watchKept && (
		<section class:list={['watch', { 'watch--postcarded': watchPostcard }]}>
			<div class="watch__panel">
				<div class="watch__head">
					<span class="watch__head-cluster">
						<span class="watch__kicker"><span class="watch__lamp"></span>Now</span>
						<span class="watch__aside">the current watch</span>
					</span>
					{/* the cat, posted in the header gap between the kicker and the dateline */}
					<span class="watch__cat-host">
						{copy.eggs.cat && <WatchCat client:idle quips={watch.quips} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} />}
					</span>
					{keptLine && <span class="watch__dateline">{keptLine}</span>}
				</div>
				<div class="watch__letter">
					{watchParagraphs.map((paragraph) => (
						<p class="watch__para">{paragraph}</p>
					))}
					{watch.rotation && <p class="watch__rotation">{watch.rotation}</p>}
				</div>
				{bearings.length > 0 && (
					<div class="watch__bearings">
						{bearings.map((bearing, index) => (
							<span class="watch__bearing">
								{index > 0 && <span class="watch__bearing-sep">·</span>}
								<span class="watch__bearing-verb">{bearing.verb}</span>
								{bearing.href
									? <a href={bearing.href} class="watch__bearing-name">{bearing.name}</a>
									: <span class="watch__bearing-name watch__bearing-name--plain">{bearing.name}</span>}
							</span>
						))}
					</div>
				)}
			</div>
			{/* the rack · two hooks: the season's print hangs big, an optional second tucks in smaller below it */}
			{watchPostcard && (
				<div class="watch__postcard">
					<div class="watch__postcard-frame">
						<div class="watch__postcard-photo">
							<img src={mediaUrl(watch.postcardMediaId)} alt="a photo from the season" />
						</div>
						<span class="watch__postcard-caption">{seasonCaption}</span>
					</div>
					{watchPostcard2 && (
						<div class="watch__postcard-frame watch__postcard-frame--second">
							<div class="watch__postcard-photo watch__postcard-photo--second">
								<img src={mediaUrl(watch.postcard2MediaId)} alt="a second photo from the season" />
							</div>
							<span class="watch__postcard-caption watch__postcard-caption--second">also from the season · the keeper liked it</span>
						</div>
					)}
				</div>
			)}
		</section>
	)}

	<WaveDivider projects={projects} proverbs={proverbs} flagship={flagship} featured={featuredTwo} />

	<!-- selected work: the light-list register (ruled rows, never cards) -->
	<section class="postcards">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Selected work</span>
				<span class="section-aside">lights I keep burning</span>
			</span>
			<a href="/projects" class="mono-link">the whole coast →</a>
		</div>
		<HomeLights client:load flagship={flagship} featured={featuredTwo} notes={allNotes} doodles={journalDoodles} signoff={keeper.signoff} correctedTo={correctedTo} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} towerSvg={towerSvg} />
	</section>

	<!-- the chart and the log, side by side (one column under 900px): doorways, not exhibits -->
	<section id="chart-log" class="chart-log">
		<div class="chart-log__chart">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Hobbies</span>
				<span class="section-aside">past and present, abridged</span>
			</span>
			<a href="/hobbies" class="mono-link">the full chart →</a>
		</div>
		<div class="hobbies-preview__grid">
			<div class="panel panel--learning">
				<span class="panel__label panel__label--gold">Currently learning</span>
				<div class="panel__rows">
					{learning.map((hobby) => (
						<div class="panel__row"><span class="panel__name">{hobby.name}</span><span class="panel__tags">{(hobby.tags ?? []).join(' · ')}</span></div>
					))}
				</div>
				<span class="panel__aside">One tweak from perfect, forever.</span>
			</div>
			<div class="panel panel--chart">
				<!-- a compass rose in the corner, from the chart -->
				<svg class="panel__rose" aria-hidden="true" width="36" height="36" viewBox="0 0 36 36" fill="none" data-bolted={roseSvg ? 'panel-rose' : undefined}>
					{roseSvg ? (
						<Fragment set:html={innerMarkup(roseSvg)} />
					) : (
						<>
							<circle cx="18" cy="18" r="8.5" stroke="#93a0e8" stroke-width=".9" opacity=".5"></circle>
							<circle cx="18" cy="18" r="12.5" stroke="#93a0e8" stroke-width=".6" opacity=".25" stroke-dasharray="1.5 3"></circle>
							<path d="M18 2 L20 16 L18 18 L16 16 Z" fill="#93a0e8" opacity=".8"></path>
							<path d="M18 34 L20 20 L18 18 L16 20 Z" fill="#93a0e8" opacity=".4"></path>
							<path d="M2 18 L16 16 L18 18 L16 20 Z" fill="#93a0e8" opacity=".4"></path>
							<path d="M34 18 L20 16 L18 18 L20 20 Z" fill="#93a0e8" opacity=".4"></path>
							<circle cx="18" cy="18" r="1.2" fill="#93a0e8"></circle>
						</>
					)}
				</svg>
				<span class="panel__label panel__label--chart">The ship's log</span>
				<div class="panel__plot">
					<!-- the fleet's wake, plotted behind the pills -->
					<svg class="panel__wake" aria-hidden="true" viewBox="0 0 800 60" preserveAspectRatio="none" data-bolted={fleetWakeSvg ? 'fleet-wake' : undefined}>
						{fleetWakeSvg ? (
							<Fragment set:html={innerMarkup(fleetWakeSvg)} />
						) : (
							<path d="M-8 44 C 110 12, 230 56, 380 30 S 640 4, 808 26" fill="none" stroke="rgba(147,160,232,.4)" stroke-width="1.4" stroke-linecap="round" stroke-dasharray="0.1 8"></path>
						)}
					</svg>
					<div class="panel__pills">
						{hobbyPills.map((pill) => (
							<span class:list={['chart-pill', pill.stateClass]}>
								{pill.text}
								{pill.smudged && <span class="chart-pill__smudge" title="the ink never dried"></span>}
								{pill.smudged && <span class="chart-pill__drip"></span>}
							</span>
						))}
					</div>
				</div>
				<div class="chart-firefly chart-firefly--a" aria-hidden="true"><span class="chart-firefly__halo"></span><span class="chart-firefly__dot"></span></div>
				<div class="chart-firefly chart-firefly--b" aria-hidden="true"><span class="chart-firefly__halo"></span><span class="chart-firefly__dot"></span></div>
				<div class="chart-firefly chart-firefly--c" aria-hidden="true"><span class="chart-firefly__halo"></span><span class="chart-firefly__dot"></span></div>
				<span class="panel__aside panel__aside--dim">None of them sank. Some are just further from port than others.</span>
			</div>
		</div>
		<div class="hobbies-preview__foot">
			<span class="mono-comment">// the chart only fills in. that's fine.</span>
			<NextHobbyChip client:load values={suggestions.map((s) => s.value)} variant="round" />
		</div>
		</div>

		<JournalStrip notes={journalPreview} doodles={journalDoodles} />
	</section>
	<JournalStripDirector client:idle notes={journalPreview} allNotes={allNotes} doodles={journalDoodles} projects={projects} hobbies={hobbies} signoff={keeper.signoff} towerSvg={towerSvg} />

	<!-- contact band -->
	<section class="contact">
		<LighthouseMark width={30} height={34} />
		<div class="contact__headline">Need a hand keeping your lights on?</div>
		<div class="contact__aside">Backend, architecture, planning, or just to talk shop.</div>
		<div class="contact__actions">
			<a href={`mailto:${keeper.email}`} class="btn btn--roomy btn--gold">say hi</a>
			<a href="/resume.pdf" class="btn btn--roomy btn--outline">resume ↗</a>
		</div>
	</section>

	<!-- the stores ledge: the tool bench flattened onto one line above the footer -->
	<div class="stores-ledge">
		<span class="stores-ledge__line"><span class="stores-ledge__kicker">the stores</span> · {storesRun}</span>
	</div>
</BaseLayout>

<style>
	/* The mock's per-section shells: every home band caps at 1480px and
	   centers, so an ultrawide screen stops flinging the sections apart
	   (JournalStrip.astro and the shared nav carry their own). */
	.hero, .watch, .postcards, .chart-log, .contact {
		width: 100%;
		max-width: 1480px;
		margin: 0 auto;
		box-sizing: border-box;
	}

	/* --- hero --- */
	.hero {
		position: relative;
		padding: clamp(48px, 7vw, 76px) var(--gutter) clamp(30px, 5vw, 44px);
		overflow: hidden;
	}

	.ff-1 { right: 14%; top: 90px;  width: 5px; height: 5px; background: var(--gold);       box-shadow: 0 0 14px 4px rgba(240, 217, 168, .4);  animation: drift 11s ease-in-out infinite; }
	.ff-2 { right: 32%; top: 220px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .35); animation: drift 14s ease-in-out 2s infinite; }
	.ff-3 { right: 9%;  top: 320px; width: 4px; height: 4px; background: var(--gold);       box-shadow: 0 0 12px 3px rgba(240, 217, 168, .3);  animation: drift 9s ease-in-out 1s infinite; }
	.ff-4 { left: 8%; bottom: 60px; width: 4px; height: 4px; background: var(--periwinkle); box-shadow: 0 0 12px 3px rgba(147, 160, 232, .3);  animation: drift 13s ease-in-out 3s infinite; }

	/* Resting tilt is a base transform: reduced-motion strips the sway, keeps the pose */
	.postmark-circle {
		position: absolute;
		right: clamp(24px, 6vw, 72px);
		top: 64px;
		width: 92px;
		height: 92px;
		border: 1.5px dashed rgba(147, 160, 232, .4);
		border-radius: 50%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		transform: rotate(12deg);
		animation: postmarkSway 9s ease-in-out infinite;
	}

	.postmark-circle__lamp {
		animation: morseHi 4s linear infinite;
	}

	@keyframes postmarkSway {
		0%, 100% { transform: rotate(9deg); }
		50%      { transform: rotate(15deg); }
	}

	/* HI in morse (···· ··): the seal's lamp blinks the greeting on a 4s loop */
	@keyframes morseHi {
		0%, 4.9%   { opacity: 1; }
		5%, 9.9%   { opacity: .12; }
		10%, 14.9% { opacity: 1; }
		15%, 19.9% { opacity: .12; }
		20%, 24.9% { opacity: 1; }
		25%, 29.9% { opacity: .12; }
		30%, 34.9% { opacity: 1; }
		35%, 49.9% { opacity: .12; }
		50%, 54.9% { opacity: 1; }
		55%, 59.9% { opacity: .12; }
		60%, 64.9% { opacity: 1; }
		65%, 100%  { opacity: .12; }
	}

	@media (max-width: 600px) {
		.postmark-circle { display: none; }
	}

	.hero__copy {
		display: flex;
		flex-direction: column;
		gap: 24px;
		max-width: 720px;
	}

	.hero__headline {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(34px, 6.5vw, 58px);
		line-height: 1.1;
		color: var(--text-strong);
		text-wrap: balance;
	}

	/* --- the current watch --- */
	.watch {
		position: relative;
		padding: 0 var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 26px;
		align-items: stretch;
	}

	.watch__panel {
		position: relative;
		flex: 1 1 440px;
		max-width: 660px;
		background: linear-gradient(160deg, #161a2e, #12162a);
		border: 1px solid var(--border-card);
		border-radius: 14px;
		padding: clamp(24px, 4vw, 34px) clamp(22px, 4vw, 36px);
		display: flex;
		flex-direction: column;
		gap: 18px;
		animation: fadeUp .7s ease .3s both;
	}

	.watch__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 8px 16px;
	}

	.watch__head-cluster {
		display: flex;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.watch__kicker {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: .14em;
		color: var(--gold);
		text-transform: uppercase;
	}

	.watch__lamp {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--gold);
		box-shadow: 0 0 8px 2px rgba(240, 217, 168, .55);
		animation: lampPulse 4s ease-in-out infinite;
	}

	.watch__aside {
		font-size: 15px;
		color: var(--periwinkle-deep);
		font-style: italic;
	}

	/* The cat's perch: the flexible gap between the kicker and the dateline
	   (WatchCat.tsx mounts into it when the page's one-cat pick lands here) */
	.watch__cat-host {
		flex: 1 1 0;
		min-width: 0;
		position: relative;
		align-self: stretch;
	}

	.watch__dateline {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--periwinkle-deep);
	}

	.watch__letter {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.watch__para {
		margin: 0;
		font-size: clamp(16px, 2.2vw, 18.5px);
		line-height: 1.7;
		color: var(--text-body);
		font-weight: 300;
		text-wrap: pretty;
	}

	.watch__rotation {
		margin: 0;
		font-size: 15.5px;
		font-style: italic;
		color: #9aa3c9;
