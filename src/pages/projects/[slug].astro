---
// A project's full case-study log, per CaseStudy.dc.html. The log is published
// as a CaseLog document of typed blocks (src/lib/caseStudy.ts); getStaticPaths
// joins published projects to published case logs on projectId and SSG's one
// page per pair. Mermaid blocks render to static SVG (src/lib/mermaid.ts) and
// code blocks to themed token spans (src/lib/codeHighlight.ts) in the same
// build pass, so the shipped page carries zero runtime mermaid, no highlighter,
// and no CDN.
//
// The header lives in the blocks: the first title/subhead/facts/meta feed the
// entry header (the kicker no., light badge, pill, and slug stay project-fed,
// and a project field backfills a header block the log omits); any later blocks
// of those kinds render in-flow. All remaining blocks render in order, headings
// auto-numbered 01, 02, ...
//
// "next log" picks the next project with a log, in list order, wrapping. Inert
// today: only the flagship carries a log, so `next` is always null.
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyInline from '../../components/CaseStudyInline.astro';
import LightBadge from '../../components/islands/LightBadge';
import { getProjects, getCaseLogs, getKeeperProfile } from '../../lib/api';
import { parseInline, numberHeadings, type CaseLogBlock } from '../../lib/caseStudy';
import { renderMermaidBlocks, closeMermaidBrowser } from '../../lib/mermaid';
import { highlightCodeBlocks } from '../../lib/codeHighlight';
import { DEFAULT_LIGHT, registryNo, codeFor } from '../../lib/lightChar';
import { mediaUrl } from '../../lib/media';
import type { Project, CaseLog } from '../../lib/api';

export async function getStaticPaths() {
	const projects = await getProjects();
	const caseLogs = await getCaseLogs();
	const logByProject = new Map(caseLogs.map((log) => [log.projectId, log]));

	const pairs = projects
		.filter((project) => project.slug && logByProject.has(project.id))
		.map((project) => ({ project, caselog: logByProject.get(project.id)! }));

	const paths = await Promise.all(pairs.map(async ({ project, caselog }, index) => {
		await renderMermaidBlocks(caselog.blocks);
		await highlightCodeBlocks(caselog.blocks);
		const next = pairs.length > 1 ? pairs[(index + 1) % pairs.length] : null;
		return {
			params: { slug: project.slug },
			props: { project, caselog, next: next ? { slug: next.project.slug, title: next.project.title } : null },
		};
	}));

	// Every diagram and code block across every log is rendered by now; let the
	// shared browser go so `astro build` can actually exit.
	await closeMermaidBrowser();
	return paths;
}

interface Props {
	project: Project;
	caselog: CaseLog;
	next:    { slug: string; title: string } | null;
}

const { project, caselog, next } = Astro.props as Props;
const keeper = await getKeeperProfile();

const light = project.light ?? DEFAULT_LIGHT;
const dark = Boolean(light.extinguished);

const blocks = caselog.blocks;

// The header lives in blocks: the first title/subhead/facts/meta feed the entry
// header; any later ones render in-flow. A project field backfills a header
// block the log omits, so a log without its own header still renders the old way.
const blockOfKind = <K extends CaseLogBlock['kind']>(kind: K) =>
	blocks.find((block): block is Extract<CaseLogBlock, { kind: K }> => block.kind === kind);

const firstTitle = blockOfKind('title');
const firstSubhead = blockOfKind('subhead');
const firstFacts = blockOfKind('facts');
const firstMeta = blockOfKind('meta');

const headerTitle = firstTitle?.text ?? project.title;
const headerSubhead = firstSubhead?.text ?? project.shortDesc;
const headerFacts = firstFacts?.rows ?? (project.facts ?? []).map((fact) => ({ heading: fact.heading, fact: fact.fact }));
const headerEst = firstMeta?.established ?? project.firstLit;
const headerTags = firstMeta?.tags ?? (project.tags ?? []);

// The first of each header kind is spent on the header above; everything else
// (including any later title/subhead/facts/meta) renders in order below.
const headerBlocks = new Set<CaseLogBlock>();
for (const block of [firstTitle, firstSubhead, firstFacts, firstMeta]) {
	if (block) {
		headerBlocks.add(block);
	}
}
const body = numberHeadings(blocks.filter((block) => !headerBlocks.has(block)));

const CALLOUT_LABEL = { note: 'note', warning: 'heads up', 'dead-end': 'dead end' } as const;
---
<BaseLayout title={`${project.title} · case study · Justin Smith`} active="projects" quipKey="quipProjects" nightWatch>
	<div class="cs-stars" aria-hidden="true">
		<div class="cs-stars__specks"></div>
		<div class="cs-stars__glow"></div>
	</div>
	{body.length > 0 ? (
		<article class="cs">
			<div class="cs-header">
				<a href="/projects" class="cs-breadcrumb fade-up fade-up--1">← the light list</a>

				<div class="cs-kicker-row fade-up fade-up--2">
					<span class="cs-kicker">THE LIGHT LIST · NO. {registryNo(project.order)}</span>
					<span class="cs-char">
						<LightBadge client:visible light={project.light} />
						{codeFor(light)}
					</span>
					<span class={`status-pill ${dark ? 'status-pill--dark' : 'status-pill--lit'}`}>{dark ? `dark · ${light.extinguished}` : 'lit'}</span>
				</div>

				<h1 class="cs-title fade-up fade-up--3">{headerTitle}</h1>
				<p class="cs-desc fade-up fade-up--3">{headerSubhead}</p>

				{headerFacts.length > 0 && (
					<div class="cs-header-facts fade-up fade-up--4">
						{headerFacts.map((fact) => (
							<div class="cs-header-facts__row">
								<span class="cs-header-facts__label">{fact.heading}</span>
								<span class="cs-header-facts__value">{fact.fact}</span>
							</div>
						))}
					</div>
				)}

				<div class="cs-meta fade-up fade-up--4">
					<span>established · <span class="cs-meta__value">{headerEst}</span></span>
					<span>tags · <span class="cs-meta__value">{headerTags.join(' · ')}</span></span>
				</div>
			</div>

			<div class="cs-log">
				<div class="cs-body">
					{body.map(({ block, no }) => {
						switch (block.kind) {
							case 'title':
								// A later title block: the display heading, in-flow.
								return <div class="cs-title">{block.text}</div>;
							case 'subhead':
								// A later subhead block: an italic paragraph, in-flow.
								return <p class="cs-desc">{block.text}</p>;
							case 'meta':
								// A later meta block: the mono meta line, in-flow.
								return (
									<div class="cs-meta">
										<span>established · <span class="cs-meta__value">{block.established}</span></span>
										<span>tags · <span class="cs-meta__value">{block.tags.join(' · ')}</span></span>
									</div>
								);
							case 'heading':
								return (
									<div class="cs-heading" style={no === '01' ? 'margin-top:18px' : undefined}>
										<span class="cs-heading__no">{no}</span>
										<span class="cs-heading__text"><CaseStudyInline nodes={parseInline(block.text)} /></span>
									</div>
								);
							case 'paragraph':
								return <p class="cs-p"><CaseStudyInline nodes={parseInline(block.text)} /></p>;
							case 'quote':
								return (
									<div class="cs-quote">
										<span class="cs-quote__label">from the log</span>
										<span class="cs-quote__text"><CaseStudyInline nodes={parseInline(block.text)} /></span>
									</div>
								);
							case 'list':
								return (
									<div class="cs-list">
										{block.items.map((item, index) => (
											<div class="cs-list__row">
												<span class={block.ordered ? 'cs-list__marker cs-list__marker--num' : 'cs-list__marker'}>{block.ordered ? `${index + 1}.` : '·'}</span>
												<span class="cs-list__text"><CaseStudyInline nodes={parseInline(item)} /></span>
											</div>
										))}
									</div>
								);
							case 'facts':
								return (
									<div class="cs-facts-block">
										{block.rows.map((row) => (
											<div class="cs-facts-block__row">
												<span class="cs-facts-block__label">{row.heading}</span>
												<span class="cs-facts-block__value"><CaseStudyInline nodes={parseInline(row.fact)} /></span>
											</div>
										))}
									</div>
								);
							case 'outcomes':
								return (
									<div class="cs-outcomes">
										{block.rows.map((row) => (
											<div class="cs-outcomes__card">
												<span class="cs-outcomes__big"><CaseStudyInline nodes={parseInline(row.value)} /></span>
												<span class="cs-outcomes__caption"><CaseStudyInline nodes={parseInline(row.caption)} /></span>
											</div>
										))}
									</div>
								);
							case 'code':
								// Highlighted at build (codeHighlight.ts) for a known lang;
								// an unknown/empty lang leaves html unset and falls back to
								// the plain pre, same as the mock.
								return block.html
									? <pre class="cs-code" set:html={block.html} />
									: <pre class="cs-code">{block.code}</pre>;
							case 'mermaid':
								return <div class="cs-mermaid" set:html={block.svg} />;
							case 'figure':
								// A print not yet pinned: the print can be struck from the
								// darkroom after the case study cites it. No React island on
								// this SSG'd page, so the fallback is the smallest thing that
								// works: the native onerror attribute swaps the frame to the
								// empty paper state and drops the broken image, no framework
								// runtime required.
								return (
									<figure class="cs-figure">
										<div class="cs-figure__frame">
											<img
												src={mediaUrl(block.image)}
												alt={block.caption}
												loading="lazy"
												onerror="this.closest('.cs-figure__frame').classList.add('cs-figure__frame--empty');this.remove();"
											/>
										</div>
										{block.caption && <figcaption class="cs-figure__caption">{block.caption}</figcaption>}
									</figure>
								);
							case 'comparison':
								// Before/after prints side by side; each frame takes the same
								// onerror empty-paper fallback as a lone figure.
								return (
									<figure class="cs-compare">
										<div class="cs-compare__grid">
											{block.stages.map((stage) => (
												<div class="cs-compare__stage">
													<span class="cs-compare__label">{stage.label}</span>
													<div class="cs-compare__frame">
														<img
															src={mediaUrl(stage.image)}
															alt={stage.label}
															loading="lazy"
															onerror="this.closest('.cs-compare__frame').classList.add('cs-compare__frame--empty');this.remove();"
														/>
													</div>
												</div>
											))}
										</div>
									</figure>
								);
							case 'timeline':
								return (
									<div class="cs-timeline">
										{block.rows.map((row) => (
											<div class="cs-timeline__row">
												<span class="cs-timeline__dot" />
												<span class="cs-timeline__date">{row.date}</span>
												<span class="cs-timeline__event"><CaseStudyInline nodes={parseInline(row.event)} /></span>
												{row.link && <a href={row.link} class="cs-timeline__link">evidence →</a>}
											</div>
										))}
									</div>
								);
							case 'links':
								return (
									<div class="cs-links">
										<span class="cs-links__label">links</span>
										{block.rows.map((row) => (
											<a href={row.url} class="cs-links__link">{row.label}</a>
										))}
									</div>
								);
							case 'callout':
								return (
									<div class={`cs-callout cs-callout--${block.register}`}>
										<span class="cs-callout__label">{CALLOUT_LABEL[block.register]}</span>
										<span class="cs-callout__text"><CaseStudyInline nodes={parseInline(block.text)} /></span>
									</div>
								);
							default:
								return null;
						}
					})}
				</div>

				<div class="cs-footer">
					<span class="cs-footer__signoff">{keeper.signoff}, the keeper · lamp checked nightly</span>
					{next && <a href={`/projects/${next.slug}`} class="cs-footer__next">next log: {next.title} →</a>}
				</div>
			</div>
		</article>
	) : (
		<div class="cs-missing">
			<div class="cs-missing__title">No log for that light.</div>
			<p class="cs-missing__body">Either the light does not exist, or the keeper has not written its entry up yet. The register knows all.</p>
			<a href="/projects" class="cs-missing__link">← back to the light list</a>
		</div>
	)}
</BaseLayout>

<style is:global>
	/* The case study flattens the site's sky gradient to one deep field
	   (CaseStudy.dc.html); every other page keeps the gradient. */
	html, body { background: #131628; }
</style>

<style>
	/* night over the log: a bounded star layer behind the header (design/CaseStudy.dc.html) */
	.cs-stars {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 460px;
		pointer-events: none;
		overflow: hidden;
		z-index: -1;
	}

	.cs-stars__specks {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(1.4px 1.4px at 10% 20%, rgba(255, 255, 255, .45), transparent),
			radial-gradient(1px 1px at 24% 8%, rgba(255, 255, 255, .32), transparent),
			radial-gradient(1.2px 1.2px at 38% 30%, rgba(232, 235, 250, .38), transparent),
			radial-gradient(1px 1px at 52% 14%, rgba(255, 255, 255, .28), transparent),
			radial-gradient(1.4px 1.4px at 64% 34%, rgba(240, 217, 168, .35), transparent),
			radial-gradient(1px 1px at 74% 8%, rgba(255, 255, 255, .3), transparent),
			radial-gradient(1.2px 1.2px at 86% 26%, rgba(232, 235, 250, .4), transparent),
			radial-gradient(1px 1px at 95% 14%, rgba(255, 255, 255, .32), transparent);
		mask-image: linear-gradient(180deg, black 45%, transparent 95%);
		-webkit-mask-image: linear-gradient(180deg, black 45%, transparent 95%);
	}

	.cs-stars__glow {
		position: absolute;
		right: -8%;
		top: 20px;
		width: 44%;
		height: 120px;
		background: radial-gradient(50% 50% at 50% 50%, rgba(147, 160, 232, .07), transparent 70%);
		filter: blur(8px);
		transform: rotate(-5deg);
	}

	.cs {
		padding: clamp(40px, 7vw, 64px) var(--gutter) clamp(48px, 8vw, 80px);
		display: flex;
		flex-direction: column;
	}

	/* Left-aligned, not centered: the mock's entry header (900px) and log
	   (860px) are two different widths, both hugging the same left gutter
	   .cs already pads, not a single centered column. */
	.cs-header {
		max-width: 900px;
	}

	.cs-log {
		max-width: 860px;
	}

	.cs-breadcrumb {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: .16em;
		color: var(--periwinkle);
		text-transform: uppercase;
	}

	.cs-kicker-row {
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
		margin-top: 22px;
	}

	.cs-kicker {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: .14em;
		color: var(--periwinkle-deep);
	}

	.cs-char {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-mono);
		font-size: 12.5px;
		letter-spacing: .08em;
		color: var(--text-soft);
	}

	.cs-title {
		margin: 10px 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(30px, 5.5vw, 44px);
		line-height: 1.12;
		color: var(--text-strong);
	}

	.cs-desc {
		margin: 10px 0 0;
		font-size: clamp(16px, 2.3vw, 18px);
		line-height: 1.6;
		max-width: 680px;
		font-style: italic;
		color: var(--text-body);
	}

	.cs-header-facts {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
		gap: 14px 26px;
		border-top: 1px solid rgba(150, 160, 220, .18);
		border-bottom: 1px solid rgba(150, 160, 220, .18);
		padding: 16px 0;
		margin-top: 20px;
	}

	.cs-header-facts__row {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.cs-header-facts__label {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: .14em;
		color: var(--periwinkle-deep);
		text-transform: uppercase;
	}

	.cs-header-facts__value {
		font-size: 15px;
		color: var(--text-soft);
		line-height: 1.45;
	}

	.cs-meta {
		display: flex;
		gap: 22px;
		flex-wrap: wrap;
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--periwinkle-deep);
		margin-top: 16px;
	}

	.cs-meta__value {
		color: var(--periwinkle);
	}

	.cs-body {
		display: flex;
		flex-direction: column;
	}

	/* --- ## heading: a numbered section --- */
	.cs-heading {
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin-top: 46px;
	}

	.cs-heading__no {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: .2em;
		color: var(--periwinkle-deep);
	}

	.cs-heading__text {
		font-family: var(--font-display);
		font-size: clamp(22px, 3.4vw, 28px);
		color: var(--text-head);
		line-height: 1.15;
	}

	/* --- plain paragraphs --- */
	.cs-p {
		margin: 16px 0 0;
		font-size: 16.5px;
		line-height: 1.72;
		color: var(--text-body-strong);
		text-wrap: pretty;
	}

	/* --- > from-the-log aside --- */
	.cs-quote {
		margin: 20px 0 0;
		border-left: 2px solid rgba(240, 217, 168, .5);
		padding: 2px 0 2px 16px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.cs-quote__label {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .18em;
		color: #8a7f63;
		text-transform: uppercase;
	}

	.cs-quote__text {
		font-size: 15.5px;
		font-style: italic;
		color: var(--text-quip);
		line-height: 1.6;
	}

	/* --- - / * lists, and 1. ordered lists --- */
	.cs-list {
		margin: 16px 0 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.cs-list__row {
		display: flex;
		gap: 12px;
		align-items: baseline;
	}

	.cs-list__marker {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--gold);
		flex: none;
	}

	/* ordered rows number in gold, wider gutter so 10. and 1. still align */
	.cs-list__marker--num {
		font-size: 12.5px;
		min-width: 20px;
	}

	.cs-list__text {
		font-size: 16px;
		line-height: 1.65;
		color: var(--text-body-strong);
	}

	/* --- :::facts::: grid --- */
	.cs-facts-block {
		margin: 18px 0 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 12px 26px;
		border: 1.5px dashed rgba(150, 160, 220, .25);
		border-radius: 12px;
		padding: 16px 18px;
	}

	.cs-facts-block__row {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.cs-facts-block__label {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: .14em;
		color: var(--periwinkle-deep);
		text-transform: uppercase;
	}

	.cs-facts-block__value {
		font-size: 15px;
		color: var(--text-soft);
		line-height: 1.5;
	}

	/* --- :::outcomes::: cards --- */
	.cs-outcomes {
		margin: 18px 0 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 14px;
	}

	.cs-outcomes__card {
		background: var(--card);
		border: 1px solid rgba(150, 160, 220, .2);
		border-radius: 12px;
		padding: 18px 20px;
		display: flex;
		flex-direction: column;
		gap: 6px;
		box-shadow: 0 8px 20px rgba(0, 0, 0, .3);
	}

	.cs-outcomes__big {
		font-family: var(--font-display);
		font-size: 22px;
		color: var(--text-strong);
		line-height: 1.15;
	}

	.cs-outcomes__caption {
		font-family: var(--font-mono);
		font-size: 11.5px;
		line-height: 1.6;
		color: var(--periwinkle);
	}

	/* --- fenced code (non-mermaid), highlighted at build via shiki --- */
	.cs-code {
		margin: 18px 0 0;
		background: #131728;
		border: 1px solid rgba(150, 160, 220, .18);
		border-radius: 12px;
		padding: 16px 18px;
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 13px;
		line-height: 1.6;
		color: var(--text-soft);
		white-space: pre;
	}

	/* --- mermaid diagrams: rendered at build time, no runtime mermaid --- */
	.cs-mermaid {
		margin: 20px 0 0;
		background: #141830;
		border: 1px solid rgba(150, 160, 220, .18);
		border-radius: 12px;
		padding: 20px 16px;
		overflow-x: auto;
	}

	.cs-mermaid :global(svg) {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 0 auto;
	}

	.cs-mermaid :global(.cs-mermaid__error) {
		margin: 0;
		color: #e77a70;
		font-family: var(--font-mono);
		font-size: 12px;
		white-space: pre-wrap;
	}

	/* --- ![caption](media-name) figures --- */
	.cs-figure {
		margin: 20px 0 0;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.cs-figure__frame {
		background: #141830;
		border: 1px solid rgba(150, 160, 220, .18);
		border-radius: 12px;
		overflow: hidden;
		height: 340px;
	}

	.cs-figure__frame img {
		display: block;
		width: 100%;
		height: 100%;
