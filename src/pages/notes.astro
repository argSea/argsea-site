---
// The Keeper's Journal — static header; the NotesList island owns the journal
// spread rows and the journal-entry overlay. The sign-off under each entry is
// the keeper's, from their profile. Doodles are fetched and joined onto notes
// here at build time so the island stays a pure renderer.
import BaseLayout from '../layouts/BaseLayout.astro';
import NotesList from '../components/islands/NotesList';
import { getNotes, getKeeperProfile, getSiteCopy, getFigurehead, getDoodles } from '../lib/api';

const notes = await getNotes();
const keeper = await getKeeperProfile();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();
const doodles = await getDoodles();
---
<BaseLayout title="Notes · argsea.com" active="notes" quipKey="quipNotes">
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">THE OTHER BOOK</span>
		<h1 class="head__title fade-up fade-up--1">The keeper's journal</h1>
		{/* TODO: operator voice pass */}
		<p class="head__intro fade-up fade-up--2">The official log stays in the tower — weather, tides, the lamp. This is where the rest goes. No schedule. No newsletter. No promises.</p>
	</section>

	<section class="list">
		<NotesList client:load notes={notes} doodles={doodles} signoff={keeper.signoff} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} />
	</section>
</BaseLayout>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 24px;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.head__kicker {
		margin-bottom: 8px;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(32px, 5.5vw, 46px);
		color: var(--text-strong);
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 560px;
		line-height: 1.6;
	}

	.list {
		padding: 16px var(--gutter) clamp(40px, 7vw, 64px);
		display: flex;
		flex-direction: column;
	}
</style>
