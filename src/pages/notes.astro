---
// The Keeper's Journal: static header; the NotesList island owns the journal
// spread rows and the journal-entry overlay. The sign-off under each entry is
// the keeper's, from their profile. Doodles are fetched here and passed to the
// island, which resolves each note's doodle by id.
import BaseLayout from '../layouts/BaseLayout.astro';
import NotesList from '../components/islands/NotesList';
import { getNotes, getProjects, getKeeperProfile, getSiteCopy, getFigurehead, getDoodles, getCarvings } from '../lib/api';
import { boltedSvg } from '../lib/carvings';

const notes = await getNotes();
const projects = await getProjects();
const keeper = await getKeeperProfile();
const copy = await getSiteCopy();
const catDesigns = await getFigurehead();
const doodles = await getDoodles();

// tower-stub is a carving spot inside LightEntryOverlay, reached here when a
// journal entry steps into its light; NotesList can't reach src/lib/api.ts itself.
const towerSvg = boltedSvg('tower-stub', await getCarvings());
---
<BaseLayout title="Notes · argsea.com" active="notes" quipKey="quipNotes">
	<section class="head">
		<span class="head__kicker section-label fade-up fade-up--1">Notes · the other book</span>
		<h1 class="head__title fade-up fade-up--1">The keeper's journal</h1>
		<p class="head__intro fade-up fade-up--2">The official log lives up in the lamp room: weather, ships, uptime. This is where the rest goes. No schedule. No newsletter. No promises.</p>
	</section>

	<section class="list">
		<NotesList client:load notes={notes} doodles={doodles} projects={projects} signoff={keeper.signoff} catEnabled={copy.eggs.cat} catPages={copy.catPages} catSpots={copy.catSpots} catDesigns={catDesigns} towerSvg={towerSvg} />
	</section>
</BaseLayout>

<style>
	.head {
		padding: clamp(40px, 7vw, 64px) var(--gutter) 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 10px;
	}

	.head__kicker {
		margin-bottom: 8px;
		font-size: 12px;
		letter-spacing: .18em;
	}

	.head__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(32px, 5.5vw, 46px);
		color: var(--text-strong);
	}

	.head__intro {
		margin: 0;
		font-size: clamp(16px, 2.3vw, 18px);
		color: var(--text-body);
		max-width: 560px;
		line-height: 1.6;
	}

	.list {
		padding: 16px var(--gutter) clamp(40px, 7vw, 64px);
		display: flex;
		flex-direction: column;
	}
</style>
