---
import LighthouseMark from './LighthouseMark.astro';
import NavMenu from './islands/NavMenu';
import type { CatPage } from '../lib/catSpots';
import type { FigureheadDesign } from '../lib/api';

// Borderless nav: lighthouse mark + name on the left, mono links on the
// right. `active` underlines the current page in gold; the 404 page passes
// 'none'. Below the hamburger breakpoint the right-hand links collapse into the
// NavMenu island's toggle + panel.
interface Props {
	active:     'hello' | 'projects' | 'hobbies' | 'notes' | 'none';
	catPage:    CatPage;
	catEnabled: boolean;
	catPages:   Record<string, boolean>;
	catSpots:   Record<string, boolean>;
	catDesigns: FigureheadDesign[];
}

const { active, catPage, catEnabled, catPages, catSpots, catDesigns } = Astro.props;

const links = [
	{ id: 'hello',    label: 'hello',    href: '/' },
	{ id: 'projects', label: 'projects', href: '/projects' },
	{ id: 'hobbies',  label: 'hobbies',  href: '/hobbies' },
	{ id: 'notes',    label: 'notes',    href: '/notes' },
];
---
<header class="site-nav">
	<a class="brand" href="/">
		<LighthouseMark width={24} height={28} tilt />
		<span class="brand-name">Justin Smith</span>
	</a>
	<nav class="links">
		{links.map((link) => (
			<a href={link.href} class:list={[{ active: active === link.id }]}>{link.label}</a>
		))}
		<a href="/resume.pdf">resume ↗</a>
	</nav>
	{/* Only functions below the hamburger breakpoint, so only hydrate there:
	    on desktop the director owns the header cat and this never mounts */}
	<NavMenu client:media="(max-width: 600px)" active={active} page={catPage} links={links} catEnabled={catEnabled} catPages={catPages} catSpots={catSpots} catDesigns={catDesigns} />
</header>

<style>
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		padding: clamp(18px, 3vw, 30px) var(--gutter) 10px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.brand-name {
		font-family: var(--font-display);
		font-size: 19px;
		color: var(--text-nav);
	}

	.links {
		display: flex;
		gap: clamp(14px, 3vw, 32px);
		font-family: var(--font-mono);
		font-size: 13px;
	}

	.links a {
		color: var(--periwinkle);
	}

	.links a.active {
		color: var(--text-nav);
		border-bottom: 2px solid var(--gold);
		padding-bottom: 2px;
	}

	/* Below the hamburger breakpoint the desktop links give way to the NavMenu
	   toggle (kept in sync with NAV_HAMBURGER_MAX in src/lib/catSpots.ts) */
	@media (max-width: 600px) {
		.links {
			display: none;
		}
	}
</style>
