---
// The wave divider with the crossing sailboat and the coast-in-miniature: a
// beacon dot per project, blinking that light's real characteristic at a
// glance, dark and unclickable for an extinguished light (Hello.dc.html's
// waveBeacons; every beacon there carries pointerEvents:'none', lit or dark,
// so none of them open anything). The wave line itself is static; the boat
// and its message-in-a-bottle egg live in the BottleBoat island, positioned
// against this strip via [data-wave]. With no proverbs the egg is off: the
// boat renders build-time only (no client directive, no JS) and just sails.
// wave-line/boat/bottle/boat-wake are all carving spots here; BottleBoat is
// an island, so its bolted markup is resolved here (build-time only) and
// passed down as props rather than fetched inside it.
//
// The strip is also the coast's wayfinding (split-watch round, promoted from
// decoration by ruling): up to four clickable anchors sit on top of the
// decorative beacons and scroll straight down to the register row (or the
// chart+log band) they name. Plain build-time markup + one small vanilla
// <script>, same idiom as the projects page's mousemove parallax: nothing
// here needs React state, just a DOM id to scroll to and a class to toggle.
import BottleBoat from './islands/BottleBoat';
import { getCarvings } from '../lib/api';
import type { Project } from '../lib/api';
import { DEFAULT_LIGHT, registryNo } from '../lib/lightChar';
import { boltedSvg, svgBackground } from '../lib/carvings';

interface Props {
	projects?: Project[];
	proverbs?: string[];
	flagship?: Project | null; // the register's flagship + featured rows, so the wayfinding anchors know their real registry numbers
	featured?: Project[];
}

const { projects = [], proverbs = [], flagship = null, featured = [] } = Astro.props;

interface Wayfinder {
	targetId: string;
	label:    string;
	left:     string;
	anim:     string; // a light background dot's own characteristic, so the anchor's dot echoes the row it points to
	kind:     'flagship' | 'featured' | 'chart'; // the mock differentiates the dots: flagship big and bright, featured smaller and softer, the chart periwinkle
}

function clampWfPeriod(period: number): number {
	return Math.min(6, Math.max(3, period || 4));
}

const WF_CHAR_ANIM: Record<string, string> = { flash: 'flashChar', occult: 'occultChar', iso: 'isoChar', quick: 'flashChar', veryquick: 'flashChar', morse: 'flashChar' };

function wfAnim(project: Project | null): string {
	if (!project) {
		return 'none';
	}
	const light = project.light ?? DEFAULT_LIGHT;
	if (light.extinguished || light.kind === 'fixed') {
		return 'none';
	}
	const dur = clampWfPeriod(light.period);
	return `${WF_CHAR_ANIM[light.kind] ?? 'flashChar'} ${dur}s ease-in-out infinite`;
}

// Left offsets verbatim from Hello.dc.html's own four anchors (flagship,
// two featured, the chart); the register's real registry numbers (gapped,
// src/lib/lightChar.ts's registryNo) drive the label and the scroll target.
const WF_LEFTS = ['20%', '45%', '63%', '82%'];

const wayfinders: Wayfinder[] = [
	flagship && { targetId: `light-${registryNo(flagship.order)}`, label: `no. ${registryNo(flagship.order)} · flagship`, left: WF_LEFTS[0], anim: wfAnim(flagship), kind: 'flagship' as const },
	...featured.slice(0, 2).map((project, index) => ({ targetId: `light-${registryNo(project.order)}`, label: `no. ${registryNo(project.order)}`, left: WF_LEFTS[index + 1], anim: wfAnim(project), kind: 'featured' as const })),
	{ targetId: 'chart-log', label: 'the chart', left: WF_LEFTS[3], anim: 'none', kind: 'chart' as const },
].filter((wf): wf is Wayfinder => Boolean(wf));

const carvings = await getCarvings();
const waveLineSvg = boltedSvg('wave-line', carvings);
const boatSvg = boltedSvg('boat', carvings);
const bottleSvg = boltedSvg('bottle', carvings);
const wakeSvg = boltedSvg('boat-wake', carvings);

// Beacon glow per color, dark once extinguished regardless of the light's own
// color, same palette the coast/register/overlay all share (src/lib/
// lightChar.ts's GLOW), just inlined here since these dots are plain CSS
// decoration rather than characteristic-engine lamps.
const GLOW: Record<string, string> = { white: '246,236,207', red: '231,122,112', green: '111,202,151', dark: '120,132,170' };

// The mock's own per-kind CSS keyframe (not the phase-locked WAAPI engine the
// real lamps run on): a decorative background strip doesn't need to
// phase-lock with anything else on the page.
const CHAR_ANIM: Record<string, string> = { flash: 'flashChar', occult: 'occultChar', iso: 'isoChar', quick: 'flashChar', veryquick: 'flashChar', morse: 'flashChar' };

interface Beacon {
	left:      string;
	dark:      boolean;
	glow:      string;
	haloAnim:  string;
	coreAnim:  string;
}

function clampPeriod(period: number): number {
	return Math.min(6, Math.max(3, period || 4));
}

const beacons: Beacon[] = projects.map((project, index) => {
	const light = project.light ?? DEFAULT_LIGHT;
	const dark = Boolean(light.extinguished);
	const glow = dark ? GLOW.dark : (GLOW[light.color] ?? GLOW.white);
	const left = `${6 + ((index * 0.618034) % 1) * 90}%`;
	const dur = clampPeriod(light.period);
	const charAnim = CHAR_ANIM[light.kind];

	if (dark) {
		return { left, dark, glow, haloAnim: 'none', coreAnim: 'none' };
	}
	if (light.kind === 'fixed') {
		return { left, dark, glow, haloAnim: 'haloBreath 5s ease-in-out infinite', coreAnim: 'none' };
	}
	const anim = `${charAnim ?? 'flashChar'} ${dur}s ease-in-out infinite`;
	return { left, dark, glow, haloAnim: anim, coreAnim: anim };
});
---
<div class="wave" data-wave style={waveLineSvg ? `background:${svgBackground(waveLineSvg)} repeat-x` : undefined} data-bolted={waveLineSvg ? 'wave-line' : undefined}>
	{beacons.map((beacon) => (
		<div class="wave-beacon" style={`left:${beacon.left}`} aria-hidden="true">
			<div class="wave-beacon__halo" style={`background:radial-gradient(circle, rgba(${beacon.glow},${beacon.dark ? .08 : .5}) 0%, transparent 64%);animation:${beacon.haloAnim}`}></div>
			<div class="wave-beacon__core" style={`background:${beacon.dark ? '#4d5670' : '#fff'};box-shadow:0 0 5px 1.5px rgba(${beacon.glow},${beacon.dark ? .15 : .75});animation:${beacon.coreAnim}`}></div>
		</div>
	))}
	{proverbs.length > 0
		? <BottleBoat client:load proverbs={proverbs} boatSvg={boatSvg} bottleSvg={bottleSvg} wakeSvg={wakeSvg} />
		: <BottleBoat proverbs={[]} boatSvg={boatSvg} bottleSvg={bottleSvg} wakeSvg={wakeSvg} />}

	<!-- coast wayfinding: anchors down the coast to their register row (or the chart+log band) -->
	{wayfinders.map((wf) => (
		<a href={`#${wf.targetId}`} class="wave-wayfinder" data-wf-target={wf.targetId} title={`down the coast to ${wf.label}`} style={`left:${wf.left}`}>
			<span class:list={['wave-wayfinder__dot', `wave-wayfinder__dot--${wf.kind}`]} style={`animation:${wf.anim}`}></span>
			<span class="wave-wayfinder__label">{wf.label}</span>
		</a>
	))}
</div>

<script>
	// Coast wayfinding: click-scroll to the target row/band, then flare its
	// lamp and brighten its numeral once (Hello.dc.html's anchorTo). Plain DOM,
	// no framework: the targets live in a separate React island (HomeLights)
	// and a sibling Astro section, so a shared id is the only contract needed.
	document.querySelectorAll<HTMLAnchorElement>('.wave-wayfinder').forEach((anchor) => {
		anchor.addEventListener('click', (event) => {
			event.preventDefault();
			const id = anchor.dataset.wfTarget;
			const el = id ? document.getElementById(id) : null;
			if (!el) {
				return;
			}
			const y = el.getBoundingClientRect().top + window.scrollY - 90;
			const from = window.scrollY;
			window.scrollTo({ top: y, behavior: 'smooth' });
			// Some embeds ignore smooth scrolling; verify progress and fall back to instant.
			setTimeout(() => {
				if (Math.abs(window.scrollY - from) < 4 && Math.abs(y - from) > 8) {
					window.scrollTo(0, y);
				}
			}, 120);
			setTimeout(() => {
				const lamp = el.querySelector('[data-lamp]');
				const num = el.querySelector('[data-num]');
				if (lamp) {
					lamp.classList.add('home-register__arrival');
					setTimeout(() => lamp.classList.remove('home-register__arrival'), 950);
				}
				if (num) {
					num.classList.add('home-register__arrival');
					setTimeout(() => num.classList.remove('home-register__arrival'), 1200);
				}
			}, 650);
		});
	});
</script>

<style>
	.wave {
		position: relative;
		height: 48px;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2253%22%20height=%2218%22%3E%3Cpath%20d=%22M0%209%20Q%2013.25%200,%2026.5%209%20T%2053%209%22%20stroke=%22rgba(147,160,232,0.3)%22%20stroke-width=%221.5%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
	}

	/* A tiny coast-in-miniature: one dot per project, unclickable (a
	   preview, not an entry point; /projects is where you click through). */
	.wave-beacon {
		position: absolute;
		top: 9px;
		width: 14px;
		height: 14px;
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 1;
	}

	.wave-beacon__halo {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 14px;
		height: 14px;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		filter: blur(1px);
	}

	.wave-beacon__core {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 3px;
		height: 3px;
		transform: translate(-50%, -50%);
		border-radius: 50%;
	}

	@keyframes flashChar {
		0%, 68%  { opacity: .08; }
		78%      { opacity: 1; }
		88%, 100% { opacity: .08; }
	}

	@keyframes occultChar {
		0%, 70%  { opacity: 1; }
		80%      { opacity: .09; }
		90%, 100% { opacity: 1; }
	}

	@keyframes isoChar {
		0%, 42%   { opacity: 1; }
		54%, 96%  { opacity: .12; }
		100%      { opacity: .12; }
	}

	/* Coast wayfinding: real anchors sitting on top of the decorative beacon
	   strip, one per register row plus the chart+log band. */
	.wave-wayfinder {
		position: absolute;
		top: 23px;
		display: flex;
		align-items: center;
		gap: 7px;
		cursor: pointer;
		z-index: 2;
		padding: 4px 6px;
		margin: -4px -6px;
		transform: translateX(-50%);
	}

	/* The mock differentiates the dots: the flagship's biggest and brightest,
	   the featured ones smaller and softer, the chart's periwinkle (its target
	   is a band, not a light), each transcribed from Hello.dc.html verbatim. */
	.wave-wayfinder__dot {
		border-radius: 50%;
		display: inline-block;
		flex: none;
	}

	.wave-wayfinder__dot--flagship {
		width: 7px;
		height: 7px;
		background: #fff;
		box-shadow: 0 0 10px 3px rgba(246, 236, 207, .85);
	}

	.wave-wayfinder__dot--featured {
		width: 6px;
		height: 6px;
		background: #fff;
		box-shadow: 0 0 8px 2.5px rgba(246, 236, 207, .6);
	}

	.wave-wayfinder__dot--chart {
		width: 6px;
		height: 6px;
		background: #5f6ec4;
		box-shadow: 0 0 8px 2px rgba(147, 160, 232, .5);
	}

	.wave-wayfinder__label {
		font-family: var(--font-mono);
		font-size: 9.5px;
		letter-spacing: .1em;
		color: var(--periwinkle-deep);
	}
</style>
