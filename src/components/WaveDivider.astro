---
// The wave divider with the crossing sailboat (homepage only). The wave line
// itself is static; the boat and its message-in-a-bottle egg live in the
// BottleBoat island, positioned against this strip via [data-wave]. With no
// proverbs the egg is off — the boat renders build-time only (no client
// directive, no JS) and just sails.
import BottleBoat from './islands/BottleBoat';

interface Props {
	proverbs?: string[];
}

const { proverbs = [] } = Astro.props;
---
<div class="wave" data-wave>
	{proverbs.length > 0
		? <BottleBoat client:load proverbs={proverbs} />
		: <BottleBoat proverbs={[]} />}
</div>

<style>
	.wave {
		position: relative;
		height: 18px;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2253%22%20height=%2218%22%3E%3Cpath%20d=%22M0%209%20Q%2013.25%200,%2026.5%209%20T%2053%209%22%20stroke=%22rgba(147,160,232,0.3)%22%20stroke-width=%221.5%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
	}
</style>
