---
// The wave divider with the crossing sailboat (homepage only). The wave line
// itself is static; the boat sails left to right over 70s, bobbing, with a
// gold rippling wake trailing behind it, masked to fade with distance.
---
<div class="wave">
	<div class="boat-track">
		<div class="boat-wake"></div>
		<svg class="boat" width="30" height="24" viewBox="0 0 30 24" fill="none">
			<path d="M4 15 L26 15 L21 22 L9 22 Z" fill="#93a0e8" />
			<path d="M15 15 V3" stroke="#5f6ec4" stroke-width="1.5" />
			<path d="M15 3 L24 13 L15 13 Z" fill="#f0d9a8" />
		</svg>
	</div>
</div>

<style>
	.wave {
		position: relative;
		height: 18px;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2253%22%20height=%2218%22%3E%3Cpath%20d=%22M0%209%20Q%2013.25%200,%2026.5%209%20T%2053%209%22%20stroke=%22rgba(147,160,232,0.3)%22%20stroke-width=%221.5%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
	}

	.boat-track {
		position: absolute;
		top: -15px;
		left: -60px;
		animation: sail 70s linear infinite;
	}

	.boat {
		position: relative;
		animation: bobBoat 3s ease-in-out infinite;
	}

	.boat-wake {
		position: absolute;
		top: 15px;
		right: 24px;
		width: 110px;
		height: 18px;
		background: url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2253%22%20height=%2218%22%3E%3Cpath%20d=%22M0%209%20Q%2013.25%200,%2026.5%209%20T%2053%209%22%20stroke=%22rgba(240,217,168,0.5)%22%20stroke-width=%221.5%22%20fill=%22none%22/%3E%3C/svg%3E') repeat-x;
		animation: wakeRipple 2.2s linear infinite;
		pointer-events: none;
		mask-image: linear-gradient(90deg, transparent, black 70%);
		-webkit-mask-image: linear-gradient(90deg, transparent, black 70%);
	}

	@keyframes sail {
		0%   { left: -60px; }
		100% { left: 102%; }
	}

	@keyframes bobBoat {
		0%, 100% { transform: translateY(0) rotate(-2deg); }
		50%      { transform: translateY(-3px) rotate(2deg); }
	}

	@keyframes wakeRipple {
		to { background-position-x: -53px; }
	}
</style>
