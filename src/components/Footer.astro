---
// The site-wide footer: the argsea dictionary one-liner on the left, a right
// stack of socials over copyright + a per-page quip. The dictionary line
// reads from the SiteCopy singleton's `dict` field, never hardcoded, so the
// keeper can edit the one-liner from the admin like any other copy field. The
// socials come from the keeper's profile; a cleared field drops its link
// rather than shipping a dead href.
import { getKeeperProfile, getSiteCopy } from '../lib/api';

interface Props {
	quip: string;
}

const { quip } = Astro.props;
const keeper = await getKeeperProfile();
const copy = await getSiteCopy();

// The profile stores socials as host paths ("github.com/argsea"); links need a scheme
const withScheme = (link: string) => /^https?:\/\//.test(link) ? link : `https://${link}`;

// Dictionary presentation: the copy is one plain-text string; the mono
// treatment lands on the word "argc" (sense 2's own joke), not the sense
// numbers, per the mock.
const dictSegments = copy.dict
	.split(/\b(argc)\b/)
	.map((text) => ({ text, isArgc: text === 'argc' }));
---
<footer class="site-footer">
	<div class="site-footer__dict">
		<span class="site-footer__word">argsea</span>
		<span class="site-footer__pron">/ˈɑːrɡ·siː/ · noun</span>
		{dictSegments.map((segment) => segment.isArgc ? <span class="site-footer__argc">{segment.text}</span> : segment.text)}
	</div>
	<div class="site-footer__right">
		<div class="socials">
			{keeper.github && <a href={withScheme(keeper.github)}>github</a>}
			{keeper.linkedin && <a href={withScheme(keeper.linkedin)}>linkedin</a>}
			{keeper.email && <a href={`mailto:${keeper.email}`}>email</a>}
		</div>
		<div class="site-footer__meta">
			<span class="copyright">© 2026 · argsea.com</span>
			<span class="quip">{quip}</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px 28px;
		padding: 20px var(--gutter) 24px;
		border-top: 1px solid rgba(150, 160, 220, .07);
	}

	.site-footer__dict {
		flex: 1 1 240px;
		max-width: 400px;
		font-size: 11px;
		line-height: 1.55;
		color: #6b74a0;
		font-style: italic;
		text-wrap: pretty;
	}

	.site-footer__word {
		font-family: var(--font-display);
		font-style: normal;
		font-size: 12.5px;
		color: var(--text-body);
	}

	.site-footer__pron {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 10px;
		color: var(--periwinkle-deep);
	}

	.site-footer__argc {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 11px;
	}

	.site-footer__right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 5px;
	}

	.socials {
		display: flex;
		gap: 14px;
		font-family: var(--font-mono);
		font-size: 11px;
	}

	.socials a {
		color: var(--periwinkle);
	}

	.site-footer__meta {
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: 10.5px;
		color: var(--periwinkle-deep);
	}

	.quip {
		font-size: 12.5px;
		color: var(--text-quip);
		font-style: italic;
	}
</style>
