---
// The site-wide footer: a right stack of socials over copyright + a per-page
// quip. The argsea dictionary one-liner retired to the Gull Post's filler ad
// (ratified 2026-07-21); the SiteCopy singleton still carries the `dict`
// field for that ad, the footer just no longer renders it. The socials come
// from the keeper's profile; a cleared field drops its link rather than
// shipping a dead href.
import { getKeeperProfile } from '../lib/api';

interface Props {
	quip: string;
}

const { quip } = Astro.props;
const keeper = await getKeeperProfile();

// The profile stores socials as host paths ("github.com/argsea"); links need a scheme
const withScheme = (link: string) => /^https?:\/\//.test(link) ? link : `https://${link}`;
---
<footer class="site-footer">
	<div class="site-footer__right">
		<div class="socials">
			{keeper.github && <a href={withScheme(keeper.github)}>github</a>}
			{keeper.linkedin && <a href={withScheme(keeper.linkedin)}>linkedin</a>}
			{keeper.email && <a href={`mailto:${keeper.email}`}>email</a>}
		</div>
		<div class="site-footer__meta">
			<span class="copyright">© 2026 · Justin Smith</span>
			<span class="quip">{quip}</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 16px 28px;
		padding: 20px var(--gutter) 24px;
		border-top: 1px solid rgba(150, 160, 220, .07);
	}

	.site-footer__right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 5px;
	}

	.socials {
		display: flex;
		gap: 14px;
		font-family: var(--font-mono);
		font-size: 11px;
	}

	.socials a {
		color: var(--periwinkle);
	}

	.site-footer__meta {
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: 10.5px;
		color: var(--periwinkle-deep);
	}

	.quip {
		font-size: 12.5px;
		color: var(--text-quip);
		font-style: italic;
	}
</style>
