---
// Three items, space-between, wrapping: copyright · a per-page quip · social
// links. The socials come from the keeper's profile; a cleared field drops
// its link rather than shipping a dead href.
import { getKeeperProfile } from '../lib/api';

interface Props {
	quip: string;
}

const { quip } = Astro.props;
const keeper = await getKeeperProfile();

// The profile stores socials as host paths ("github.com/argsea"); links need a scheme
const withScheme = (link: string) => /^https?:\/\//.test(link) ? link : `https://${link}`;
---
<footer class="site-footer">
	<span class="copyright">© 2026 · argsea.com</span>
	<span class="quip">{quip}</span>
	<div class="socials">
		{keeper.github && <a href={withScheme(keeper.github)}>github</a>}
		{keeper.linkedin && <a href={withScheme(keeper.linkedin)}>linkedin</a>}
		{keeper.email && <a href={`mailto:${keeper.email}`}>email</a>}
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 12px;
		padding: 26px var(--gutter) 24px;
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--periwinkle-deep);
	}

	.quip {
		font-size: 15px;
		color: var(--text-quip);
		font-style: italic;
	}

	.socials {
		display: flex;
		gap: 16px;
		font-family: var(--font-mono);
		font-size: 12px;
	}

	.socials a {
		color: var(--periwinkle);
	}
</style>
