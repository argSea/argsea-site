---
// The site-wide footer: a left definition block over a right stack of socials
// and the colophon. The definition is the argsea entry itself (operator
// ruling 2026-07-22: people should understand the domain name), rendered from
// the copy singleton's `dict` field, passed down as a prop from BaseLayout
// (it already holds `copy`) rather than fetched here; the "argc" mono
// treatment mirrors gazette.astro's own dictSegments split, this footer being
// the ad's sibling. It renders on every BaseLayout page, including the 404.
// The socials come from the keeper's profile; a cleared field drops its link
// rather than shipping a dead href.
import { getKeeperProfile } from '../lib/api';

interface Props {
	quip: string;
	dict: string;
}

const { quip, dict } = Astro.props;
const keeper = await getKeeperProfile();

// The profile stores socials as host paths ("github.com/argsea"); links need a scheme
const withScheme = (link: string) => /^https?:\/\//.test(link) ? link : `https://${link}`;

// mirrors gazette.astro's own dictSegments split
const dictSegments = dict
	.split(/\b(argc)\b/)
	.map((text) => ({ text, isArgc: text === 'argc' }));
---
<footer class="site-footer">
	<div class="definition">
		<span class="definition__word">argsea</span> <span class="definition__ipa">/ˈɑːrɡ·siː/ · noun</span> &nbsp;{dictSegments.map((segment) => (segment.isArgc ? <span class="definition__argc">{segment.text}</span> : segment.text))}
	</div>
	<div class="site-footer__right">
		<div class="socials">
			{keeper.github && <a href={withScheme(keeper.github)}>github</a>}
			{keeper.linkedin && <a href={withScheme(keeper.linkedin)}>linkedin</a>}
			{keeper.email && <a href={`mailto:${keeper.email}`}>email</a>}
		</div>
		<div class="site-footer__meta">
			<span class="copyright">© 2026 · {quip}</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px 28px;
		padding: 20px var(--gutter) 24px;
		border-top: 1px solid rgba(150, 160, 220, .07);
	}

	.definition {
		flex: 1 1 240px;
		max-width: 400px;
		font-size: 11px;
		line-height: 1.55;
		color: #6b74a0;
		font-style: italic;
		text-wrap: pretty;
	}

	.definition__word {
		font-family: var(--font-display);
		font-style: normal;
		font-size: 12.5px;
		color: var(--text-body);
	}

	.definition__ipa {
		font-family: var(--font-mono);
		font-size: 10px;
		font-style: normal;
		color: var(--periwinkle-deep);
	}

	.definition__argc {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 10px;
	}

	.site-footer__right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 5px;
	}

	.socials {
		display: flex;
		gap: 14px;
		font-family: var(--font-mono);
		font-size: 11px;
	}

	.socials a {
		color: var(--periwinkle);
	}

	.site-footer__meta {
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: 10.5px;
		color: var(--periwinkle-deep);
	}
</style>
