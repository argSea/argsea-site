---
// The phone-line bottom bar: four tabs (hello / projects / hobbies / notes)
// fixed to the foot of the screen below 600px, standing in for the desktop nav
// links. It replaces the old hamburger outright; there is no menu island. The
// active tab lights gold from `active`; the 404 passes 'none' so none light.
// Static markup, no JS. BaseLayout renders one per page. The icons are the
// design mocks' own (design/*.dc.html [data-mob-tabs]); currentColor carries
// each tab's tint into them. All three icons mount carving spots the same way
// LighthouseMark.astro does (the lighthouse rides the site-wide
// lighthouse-logo; the compass and notes letter have their own spots), so a
// bolted swap in the shop reaches the tab bar instead of leaving it the one
// place still wearing the old art; only the built-in fallbacks keep
// currentColor (a bolted carving paints its own colors, as at every other
// mount).
import { getCarvings } from '../lib/api';
import { boltedSvg, innerMarkup } from '../lib/carvings';

interface Props {
	active: 'hello' | 'projects' | 'hobbies' | 'notes' | 'none';
}

const { active } = Astro.props;

const carvings = await getCarvings();
const bolted = boltedSvg('lighthouse-logo', carvings);
const compassSvg = boltedSvg('compass', carvings);
const letterSvg = boltedSvg('notes-letter', carvings);
---
<nav class="tab-bar" aria-label="sections">
	<a href="/" class:list={['tab', { active: active === 'hello' }]}>
		<svg width="19" height="22" viewBox="0 0 26 30" fill="none" data-bolted={bolted ? 'lighthouse-logo' : undefined}>
			{bolted ? (
				<Fragment set:html={innerMarkup(bolted)} />
			) : (
				<>
					<path d="M13 2 L17 9 L9 9 Z" fill="currentColor"></path>
					<rect x="10" y="9" width="6" height="14" fill="none" stroke="currentColor" stroke-width="1.4"></rect>
					<path d="M10 13 h6 M10 17 h6" stroke="currentColor" stroke-width="1.4"></path>
					<path d="M6 27 q7 -4 14 0" stroke="currentColor" stroke-width="1.4" fill="none"></path>
				</>
			)}
		</svg>
		<span class="tab__label">hello</span>
	</a>
	<a href="/projects" class:list={['tab', { active: active === 'projects' }]}>
		<span class="tab__beacon"><span class="tab__beacon-halo"></span><span class="tab__beacon-core"></span></span>
		<span class="tab__label">projects</span>
	</a>
	<a href="/hobbies" class:list={['tab', { active: active === 'hobbies' }]}>
		<svg width="20" height="20" viewBox="0 0 22 22" fill="none" data-bolted={compassSvg ? 'compass' : undefined}>
			{compassSvg ? (
				<Fragment set:html={innerMarkup(compassSvg)} />
			) : (
				<>
					<circle cx="11" cy="11" r="8.5" stroke="currentColor" stroke-width="1.4"></circle>
					<path d="M11 3 L12.4 11 L11 19 L9.6 11 Z" fill="currentColor"></path>
					<path d="M3 11 L11 9.6 L19 11 L11 12.4 Z" fill="currentColor" opacity="0.55"></path>
				</>
			)}
		</svg>
		<span class="tab__label">hobbies</span>
	</a>
	<a href="/notes" class:list={['tab', { active: active === 'notes' }]}>
		<svg width="19" height="22" viewBox="0 0 20 22" fill="none" data-bolted={letterSvg ? 'notes-letter' : undefined}>
			{letterSvg ? (
				<Fragment set:html={innerMarkup(letterSvg)} />
			) : (
				<>
					<rect x="4" y="3" width="12" height="16" rx="1.5" stroke="currentColor" stroke-width="1.5"></rect>
					<path d="M7 7 h6 M7 10 h6 M7 13 h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
				</>
			)}
		</svg>
		<span class="tab__label">notes</span>
	</a>
</nav>

<style>
	/* Hidden above the phone line: the desktop nav owns navigation there */
	.tab-bar {
		display: none;
		position: fixed;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 50;
		background: rgba(15, 18, 32, .97);
		backdrop-filter: blur(10px);
		border-top: 1px solid rgba(150, 160, 220, .16);
		padding: 7px 4px calc(4px + env(safe-area-inset-bottom));
		font-family: var(--font-mono);
	}

	.tab {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 5px 2px;
		color: var(--periwinkle);
	}

	.tab.active {
		color: var(--gold);
	}

	.tab__label {
		font-size: 9.5px;
	}

	/* The projects tab's lit beacon: a soft halo behind a glowing core, both on
	   currentColor so the active tint reaches them */
	.tab__beacon {
		position: relative;
		width: 19px;
		height: 22px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.tab__beacon-halo {
		position: absolute;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: radial-gradient(circle, currentColor, transparent 62%);
		opacity: .4;
	}

	.tab__beacon-core {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: currentColor;
		box-shadow: 0 0 6px 1.5px currentColor;
	}

	@media (max-width: 600px) {
		.tab-bar {
			display: flex;
		}
	}
</style>
