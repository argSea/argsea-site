---
// Homepage journal preview: static rows straight to /notes, no overlay of its
// own (the full spread with its binding/ribbon lives on the Notes page).
// Renders nothing once the keeper has zero published notes.
import type { Note } from '../lib/api';

interface Props {
	notes: Note[];
}

const { notes } = Astro.props;
---
{notes.length > 0 && (
	<section class="journal-strip">
		<div class="row-head">
			<span class="section-label">From the keeper's journal</span>
			<a href="/notes" class="mono-link">the full journal →</a>
		</div>
		<div class="journal-strip__block">
			{notes.map((note) => (
				<a href="/notes" class="journal-strip__row">
					<span class="journal-strip__date">{note.date}</span>
					<span class="journal-strip__middle">
						<span class="journal-strip__title">{note.title}</span>
						<span class="journal-strip__teaser">{note.teaser}</span>
					</span>
					<span class="journal-strip__conditions">{note.conditions}</span>
				</a>
			))}
		</div>
	</section>
)}

<style>
	.journal-strip {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	/* Night-vocabulary rows, bare like the manifest columns below it on this
	   same page: no paper card, just dividers. The one wink at the journal's
	   own stitched binding (see design/Notes.dc.html) is this dashed
	   periwinkle spine down the left edge. */
	.journal-strip__block {
		padding-left: clamp(18px, 3.5vw, 28px);
		border-left: 1.5px dashed rgba(147, 160, 232, .4);
	}

	.journal-strip__row {
		display: flex;
		gap: 8px 20px;
		align-items: baseline;
		flex-wrap: wrap;
		border-top: 1px solid var(--border-card);
		padding: 18px 0;
		transition: transform .2s;
	}

	.journal-strip__row:first-child {
		border-top: none;
	}

	.journal-strip__row:hover {
		transform: translateX(5px);
	}

	.journal-strip__date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--text-dim);
		flex: none;
		width: 72px;
	}

	.journal-strip__middle {
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex: 1 1 300px;
		min-width: 0;
	}

	.journal-strip__title {
		font-family: var(--font-display);
		font-size: 18.5px;
		color: var(--text-head);
		line-height: 1.3;
		transition: color .2s;
	}

	.journal-strip__row:hover .journal-strip__title {
		color: var(--gold);
	}

	.journal-strip__teaser {
		font-size: 15px;
		font-style: italic;
		color: var(--text-body);
		line-height: 1.5;
		text-wrap: pretty;
	}

	/* The second wink: conditions read as a right-aligned mono weather-log
	   column instead of trailing prose, the journal's own distinctive tic. */
	.journal-strip__conditions {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--periwinkle-deep);
		margin-left: auto;
		flex: none;
	}

	@media (max-width: 560px) {
		.journal-strip__conditions {
			margin-left: 0;
		}
	}
</style>
