---
// Homepage journal preview: static rows straight to /notes (JournalStripDirector
// intercepts a plain click to open the shared journal-entry overlay in place;
// no JS or a modified click just navigates there instead). Renders nothing
// once the keeper has zero published notes. Paw prints and the hover doodle
// are pure CSS decoration, no JS needed to show them.
import type { Doodle, Note } from '../lib/api';

interface Props {
	notes:   Note[];
	doodles: Doodle[];
}

const { notes, doodles } = Astro.props;

const doodleFor = (doodleId: string | null): Doodle | null =>
	doodleId ? doodles.find((doodle) => doodle.id === doodleId) ?? null : null;

// The animation transform-origin a shape carries, as an inline style (mirrors
// HarborCat.tsx / JournalEntryOverlay.tsx's shape rendering; Astro can't
// share that React helper with a static component, so the shape-to-SVG
// mapping is repeated here for the row's hover-ghost doodle).
const shapeOriginStyle = (origin?: [number, number]) =>
	origin ? `transform-origin:${origin[0]}px ${origin[1]}px` : undefined;

// Astro's SVG typings want the linecap/linejoin literal unions; the shape
// contract stores them as plain strings, so cast at the boundary, same as
// HarborCat.tsx / JournalEntryOverlay.tsx do for the React version.
const linecap = (value?: string) => value as 'butt' | 'round' | 'square' | 'inherit' | undefined;
const linejoin = (value?: string) => value as 'miter' | 'round' | 'bevel' | 'inherit' | undefined;

// The paw-print "sneak" walks row 1 → row 2 → row 3 across one shared 13s
// loop; each row gets its own resting position/tilt and its three paws their
// own stagger, straight from the design mock. Notes beyond three recycle them.
const PAW_ROWS = [
	{ style: 'top:8px;right:16px', rotate: -9, paws: [
		{ transform: 'rotate(-12deg)', delay: 0 },
		{ transform: 'translateY(7px) rotate(-4deg)', delay: .6 },
		{ transform: 'rotate(-16deg)', delay: 1.2 },
	] },
	{ style: 'top:16px;right:44px', rotate: 6, paws: [
		{ transform: 'rotate(9deg)', delay: 4.3 },
		{ transform: 'translateY(-7px) rotate(3deg)', delay: 4.9 },
		{ transform: 'rotate(13deg)', delay: 5.5 },
	] },
	{ style: 'bottom:8px;right:24px', rotate: -15, paws: [
		{ transform: 'rotate(-20deg)', delay: 8.6 },
		{ transform: 'translateY(6px) rotate(-10deg)', delay: 9.2 },
		{ transform: 'rotate(-24deg)', delay: 9.8 },
	] },
];

const rows = notes.map((note, index) => ({
	note,
	doodle: doodleFor(note.doodleId),
	paw:    PAW_ROWS[index % PAW_ROWS.length],
}));
---
{notes.length > 0 && (
	<section class="journal-strip">
		<div class="row-head">
			<span class="section-head-cluster">
				<span class="section-label">Writing</span>
				<span class="section-aside">from the keeper's journal</span>
			</span>
			<a href="/notes" class="mono-link">the full journal →</a>
		</div>
		<div class="journal-strip__panel">
			<div class="journal-strip__ribbon" title="the keeper's bookmark"></div>
			<div class="journal-strip__inner">
				<div class="journal-strip__vol">
					<span>log book · vol. 2026 · {notes.length} {notes.length === 1 ? 'entry' : 'entries'} of many</span>
				</div>
				<div class="journal-strip__rows">
					{rows.map(({ note, doodle, paw }) => (
						<a href="/notes" class="journal-strip__row" data-journal-row={note.id}>
					<span class="journal-strip__date">{note.date}</span>
					<span class="journal-strip__middle">
						<span class="journal-strip__title">{note.title}</span>
						<span class="journal-strip__teaser">{note.teaser}</span>
					</span>
					<span class="journal-strip__conditions">{note.conditions}</span>
					<span class="journal-strip__paws" aria-hidden="true" title="the cat read this one" style={`${paw.style};transform:rotate(${paw.rotate}deg)`}>
						{paw.paws.map((p) => (
							<svg width="13" height="12" viewBox="0 0 15 14" class="journal-strip__paw" style={`transform:${p.transform};animation-delay:${p.delay}s`}>
								<ellipse cx="7.5" cy="9.5" rx="3.4" ry="2.9" />
								<ellipse cx="2.6" cy="5.4" rx="1.5" ry="1.9" />
								<ellipse cx="6.2" cy="3.4" rx="1.5" ry="1.9" />
								<ellipse cx="9.8" cy="3.6" rx="1.5" ry="1.9" />
								<ellipse cx="12.6" cy="6" rx="1.4" ry="1.8" />
							</svg>
						))}
					</span>
					{doodle && (
						<span class="journal-strip__doodle" aria-hidden="true">
							<svg viewBox={doodle.viewBox} class="journal-strip__doodle-svg">
								{doodle.shapes.map((shape) => (
									shape.type === 'path' ? (
										<path d={shape.d} style={shapeOriginStyle(shape.origin)} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={linecap(shape.linecap)} stroke-linejoin={linejoin(shape.linejoin)} />
									) : shape.type === 'ellipse' ? (
										<ellipse cx={shape.cx} cy={shape.cy} rx={shape.rx} ry={shape.ry} style={shapeOriginStyle(shape.origin)} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={linecap(shape.linecap)} stroke-linejoin={linejoin(shape.linejoin)} />
									) : shape.type === 'rect' ? (
										<rect x={shape.x} y={shape.y} width={shape.w} height={shape.h} style={shapeOriginStyle(shape.origin)} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={linecap(shape.linecap)} stroke-linejoin={linejoin(shape.linejoin)} />
									) : (
										<line x1={shape.x1} y1={shape.y1} x2={shape.x2} y2={shape.y2} style={shapeOriginStyle(shape.origin)} fill={shape.fill} stroke={shape.stroke} stroke-width={shape.strokeWidth} opacity={shape.opacity} stroke-linecap={linecap(shape.linecap)} stroke-linejoin={linejoin(shape.linejoin)} />
									)
								))}
							</svg>
						</span>
					)}
				</a>
					))}
				</div>
			</div>
		</div>
	</section>
)}

<style>
	.journal-strip {
		padding: clamp(28px, 5vw, 44px) var(--gutter) clamp(36px, 6vw, 56px);
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	/* The log book: a dark gradient panel (not the journal page's warm paper,
	   see design/Notes.dc.html for that one) with its own dashed inner border
	   and a bookmark ribbon poking up from the top edge. */
	.journal-strip__panel {
		position: relative;
		background: linear-gradient(160deg, #1b1f38, #141830);
		border: 1px solid var(--border-card);
		border-radius: 14px;
		box-shadow: 0 14px 34px rgba(0, 0, 0, .4);
		padding: 7px;
	}

	.journal-strip__ribbon {
		position: absolute;
		top: -3px;
		right: 54px;
		width: 9px;
		height: 38px;
		background: linear-gradient(180deg, var(--gold), #c9a96a);
		clip-path: polygon(0 0, 100% 0, 100% 100%, 50% 86%, 0 100%);
		z-index: 2;
	}

	.journal-strip__inner {
		border: 1.5px dashed rgba(150, 160, 220, .22);
		border-radius: 9px;
		padding: 6px clamp(16px, 3vw, 26px) 12px;
		display: flex;
		flex-direction: column;
	}

	.journal-strip__vol {
		display: flex;
		justify-content: flex-end;
		padding: 10px 60px 4px 2px;
	}

	.journal-strip__vol span {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: .16em;
		color: var(--periwinkle-deep);
		text-transform: uppercase;
	}

	.journal-strip__rows {
		display: flex;
		flex-direction: column;
	}

	.journal-strip__row {
		position: relative;
		display: flex;
		gap: 8px 20px;
		align-items: baseline;
		flex-wrap: wrap;
		border-top: 1.5px dashed rgba(150, 160, 220, .18);
		padding: 15px 0;
		transition: transform .2s;
	}

	.journal-strip__row:first-child {
		border-top: none;
	}

	.journal-strip__row:hover {
		transform: translateX(5px);
	}

	.journal-strip__date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--periwinkle-deep);
		flex: none;
		width: 72px;
	}

	.journal-strip__middle {
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex: 1 1 300px;
		min-width: 0;
	}

	.journal-strip__title {
		font-family: var(--font-body);
		font-weight: 500;
		font-size: 18.5px;
		color: var(--text-nav);
		line-height: 1.3;
		transition: color .2s;
	}

	.journal-strip__row:hover .journal-strip__title {
		color: var(--gold);
	}

	.journal-strip__teaser {
		font-size: 15px;
		font-style: italic;
		color: var(--text-body);
		line-height: 1.5;
		text-wrap: pretty;
	}

	/* The second wink: conditions read as a right-aligned mono weather-log
	   column instead of trailing prose, the journal's own distinctive tic. */
	.journal-strip__conditions {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--periwinkle-deep);
		margin-left: auto;
		flex: none;
	}

	/* The cat's paw prints, sneaking across the rows: a shared 13s loop, each
	   paw's own opacity keyframe staggered so the walk reads row to row. The
	   base opacity is 0 (only pawStep ever raises it), so the reduced-motion
	   kill-switch, which drops the animation, leaves them fully absent rather
	   than frozen mid-step. */
	.journal-strip__paws {
		position: absolute;
		display: flex;
		gap: 15px;
		opacity: .62;
	}

	.journal-strip__paw {
		fill: var(--periwinkle);
		opacity: 0;
		animation: pawStep 13s linear infinite both;
	}

	@keyframes pawStep {
		0%, 1.5%  { opacity: 0; }
		5%        { opacity: 1; }
		33%       { opacity: 1; }
		45%, 100% { opacity: 0; }
	}

	/* The hover-ghost doodle: the note's real doodle, low-opacity, a small
	   rotate/rise on reveal. Centered on the row via translateY(-50%), chained
	   ahead of the same rotate/rise the hover state adds. */
	.journal-strip__doodle {
		position: absolute;
		right: 210px;
		top: 50%;
		pointer-events: none;
	}

	.journal-strip__doodle-svg {
		width: 70px;
		height: auto;
		overflow: visible;
		opacity: 0;
		transform: translateY(-50%) rotate(-2deg) translateY(3px);
		transition: opacity .3s ease, transform .3s ease;
	}

	.journal-strip__row:hover .journal-strip__doodle-svg {
		opacity: .5;
		transform: translateY(-50%) rotate(-2deg) translateY(0);
	}

	@media (max-width: 760px) {
		.journal-strip__paws,
		.journal-strip__doodle {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.journal-strip__conditions {
			margin-left: 0;
		}
	}
</style>
